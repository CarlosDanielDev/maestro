[2026-04-01T04:29:07.351Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CGqHhTNoE2XNhD6Rezp57i","type":"tool_result","content":"1\tmod budget;\n2\tmod config;\n3\tmod gates;\n4\tmod git;\n5\tmod github;\n6\tmod models;\n7\tmod modes;\n8\tmod notifications;\n9\tmod plugins;\n10\tmod prompts;\n11\tmod provider;\n12\tmod review;\n13\tmod session;\n14\tmod state;\n15\tmod tui;\n16\tmod util;\n17\tmod work;\n18\t\n19\tuse clap::{Parser, Subcommand};\n20\tuse config::Config;\n21\tuse github::client::{GhCliClient, GitHubClient};\n22\tuse session::types::Session;\n23\tuse session::worktree::GitWorktreeManager;\n24\tuse state::store::StateStore;\n25\tuse tui::app::App;\n26\tuse work::assigner::WorkAssigner;\n27\tuse work::types::WorkItem;\n28\t\n29\t#[derive(Parser)]\n30\t#[command(\n31\t    name = \"maestro\",\n32\t    version,\n33\t    about = \"Multi-session Claude Code orchestrator\"\n34\t)]\n35\tstruct Cli {\n36\t    #[command(subcommand)]\n37\t    command: Option<Commands>,\n38\t}\n39\t\n40\t#[derive(Subcommand)]\n41\tenum Commands {\n42\t    /// Run sessions from GitHub issues or a prompt\n43\t    Run {\n44\t        /// Prompt to send to Claude\n45\t        #[arg(short, long)]\n46\t        prompt: Option<String>,\n47\t\n48\t        /// GitHub issue number(s), comma-separated\n49\t        #[arg(short, long)]\n50\t        issue: Option<String>,\n51\t\n52\t        /// Milestone to fetch all issues from\n53\t        #[arg(short = 'M', long)]\n54\t        milestone: Option<String>,\n55\t\n56\t        /// Model to use (opus, sonnet, haiku)\n57\t        #[arg(short, long)]\n58\t        model: Option<String>,\n59\t\n60\t        /// Session mode (orchestrator, vibe, review, or custom)\n61\t        #[arg(long)]\n62\t        mode: Option<String>,\n63\t\n64\t        /// Max concurrent sessions (overrides config)\n65\t        #[arg(long)]\n66\t        max_concurrent: Option<usize>,\n67\t\n68\t        /// Resume from previous state after a crash\n69\t        #[arg(long)]\n70\t        resume: bool,\n71\t    },\n72\t    /// Show queued/pending issues from GitHub\n73\t    Queue,\n74\t    /// Add an issue to the work queue manually\n75\t    Add {\n76\t        /// Issue number to add\n77\t        issue_number: u64,\n78\t    },\n79\t    /// Show current state without TUI\n80\t    Status,\n81\t    /// Show spending report\n82\t    Cost,\n83\t    /// Initialize maestro.toml in current directory\n84\t    Init,\n85\t    /// Clean orphaned worktrees left by crashed sessions\n86\t    Clean {\n87\t        /// Show what would be cleaned without actually doing it\n88\t        #[arg(long)]\n89\t        dry_run: bool,\n90\t    },\n91\t    /// Show session transcript logs\n92\t    Logs {\n93\t        /// Show full log for a specific session ID\n94\t        #[arg(long)]\n95\t        session: Option<String>,\n96\t        /// Export as JSON\n97\t        #[arg(long)]\n98\t        export: Option<String>,\n99\t    },\n100\t    /// Resume interrupted sessions from saved state\n101\t    Resume {\n102\t        /// Resume a specific session by ID\n103\t        #[arg(long)]\n104\t        session: Option<String>,\n105\t    },\n106\t    /// Generate shell completions\n107\t    Completions {\n108\t        /// Shell to generate completions for (bash, zsh, fish)\n109\t        shell: String,\n110\t    },\n111\t}\n112\t\n113\t#[tokio::main]\n114\tasync fn main() -> anyhow::Result<()> {\n115\t    // Init logging (to file, not terminal — TUI owns stdout)\n116\t    tracing_subscriber::fmt()\n117\t        .with_env_filter(\"maestro=debug\")\n118\t        .with_writer(|| {\n119\t            std::fs::OpenOptions::new()\n120\t                .create(true)\n121\t                .append(true)\n122\t                .open(\"maestro.log\")\n123\t                .unwrap_or_else(|_| {\n124\t                    std::fs::OpenOptions::new()\n125\t                        .write(true)\n126\t                        .open(\"/dev/null\")\n127\t                        .unwrap()\n128\t                })\n129\t        })\n130\t        .init();\n131\t\n132\t    let cli = Cli::parse();\n133\t\n134\t    match cli.command {\n135\t        Some(Commands::Init) => cmd_init(),\n136\t        Some(Commands::Clean { dry_run }) => cmd_clean(dry_run),\n137\t        Some(Commands::Logs { session, export }) => cmd_logs(session, export),\n138\t        Some(Commands::Resume { session }) => cmd_resume(session).await,\n139\t        Some(Commands::Completions { shell }) => cmd_completions(&shell),\n140\t        Some(Commands::Status) => cmd_status(),\n141\t        Some(Commands::Cost) => cmd_cost(),\n142\t        Some(Commands::Queue) => cmd_queue().await,\n143\t        Some(Commands::Add { issue_number }) => cmd_add(issue_number).await,\n144\t        Some(Commands::Run {\n145\t            prompt,\n146\t            issue,\n147\t            milestone,\n148\t            model,\n149\t            mode,\n150\t            max_concurrent,\n151\t            resume,\n152\t        }) => {\n153\t            cmd_run(\n154\t                prompt,\n155\t                issue,\n156\t                milestone,\n157\t                model,\n158\t                mode,\n159\t                max_concurrent,\n160\t                resume,\n161\t            )\n162\t            .await\n163\t        }\n164\t        // Default: launch TUI with no sessions (dashboard mode)\n165\t        None => cmd_dashboard().await,\n166\t    }\n167\t}\n168\t\n169\tfn cmd_init() -> anyhow::Result<()> {\n170\t    let path = std::path::PathBuf::from(\"maestro.toml\");\n171\t    if path.exists() {\n172\t        println!(\"maestro.toml already exists.\");\n173\t        return Ok(());\n174\t    }\n175\t\n176\t    let content = r#\"[project]\n177\trepo = \"\"\n178\tbase_branch = \"main\"\n179\t\n180\t[sessions]\n181\tmax_concurrent = 3\n182\tstall_timeout_secs = 300\n183\tdefault_model = \"opus\"\n184\tdefault_mode = \"orchestrator\"\n185\tpermission_mode = \"bypassPermissions\"  # Options: default, acceptEdits, bypassPermissions, dontAsk, plan, auto\n186\tallowed_tools = []                      # Empty = all tools. Example: [\"Bash\", \"Read\", \"Write\", \"Edit\"]\n187\t\n188\t[budget]\n189\tper_session_usd = 5.0\n190\ttotal_usd = 50.0\n191\talert_threshold_pct = 80\n192\t\n193\t[github]\n194\tissue_filter_labels = [\"maestro:ready\"]\n195\tauto_pr = true\n196\tauto_merge = false                      # Set to true to auto-merge PRs after CI + review pass\n197\tmerge_method = \"squash\"                 # Options: merge, squash, rebase\n198\tcache_ttl_secs = 300\n199\t\n200\t[gates]\n201\tenabled = true\n202\ttest_command = \"cargo test\"\n203\tci_poll_interval_secs = 30\n204\tci_max_wait_secs = 1800\n205\t\n206\t[notifications]\n207\tdesktop = true\n208\tslack = false\n209\t\n210\t[review]\n211\tenabled = false\n212\tcommand = \"gh pr review {pr_number} --comment --body 'Automated review by Maestro'\"\n213\t# reviewers = [\n214\t#   { name = \"claude\", command = \"claude --print 'review PR #{pr_number}'\", required = true },\n215\t#   { name = \"codex\", command = \"codex review {pr_number}\", required = false },\n216\t# ]\n217\t\n218\t[concurrency]\n219\theavy_task_labels = []                  # Labels that mark a task as resource-intensive\n220\theavy_task_limit = 2                    # Max concurrent heavy tasks\n221\t\n222\t[monitoring]\n223\twork_tick_interval_secs = 10\n224\t\n225\t# Plugin hooks — shell commands triggered on lifecycle events\n226\t# [[plugins]]\n227\t# name = \"notify-team\"\n228\t# on = \"session_completed\"             # Hook points: session_started, session_completed, tests_passed,\n229\t#                                      #   tests_failed, budget_threshold, file_conflict, pr_created\n230\t# run = \"curl -X POST https://slack.webhook/...\"\n231\t# timeout_secs = 30                    # Optional per-plugin timeout\n232\t\n233\t# Custom modes — define system prompt and allowed tools\n234\t# [modes.review]\n235\t# system_prompt = \"You are a code reviewer. Review the PR and leave comments.\"\n236\t# allowed_tools = [\"Read\", \"Grep\", \"Glob\"]\n237\t# permission_mode = \"plan\"\n238\t\"#;\n239\t\n240\t    std::fs::write(&path, content)?;\n241\t    println!(\"Created maestro.toml\");\n242\t    Ok(())\n243\t}\n244\t\n245\tfn cmd_status() -> anyhow::Result<()> {\n246\t    let store = StateStore::new(StateStore::default_path());\n247\t    let state = store.load()?;\n248\t\n249\t    if state.sessions.is_empty() {\n250\t        println!(\"No sessions recorded.\");\n251\t        return Ok(());\n252\t    }\n253\t\n254\t    println!(\n255\t        \"Sessions: {} total, {} active\",\n256\t        state.sessions.len(),\n257\t        state.active_sessions().len()\n258\t    );\n259\t    println!(\"Total cost: ${:.2}\", state.total_cost_usd);\n260\t    println!();\n261\t\n262\t    for session in &state.sessions {\n263\t        let label = match session.issue_number {\n264\t            Some(n) => format!(\"#{}\", n),\n265\t            None => session.id.to_string()[..8].to_string(),\n266\t        };\n267\t        println!(\n268\t            \"  {} {} {} ${:.2} {}\",\n269\t            session.status.symbol(),\n270\t            label,\n271\t            session.status.label(),\n272\t            session.cost_usd,\n273\t            session.elapsed_display(),\n274\t        );\n275\t    }\n276\t\n277\t    Ok(())\n278\t}\n279\t\n280\tfn cmd_cost() -> anyhow::Result<()> {\n281\t    let store = StateStore::new(StateStore::default_path());\n282\t    let state = store.load()?;\n283\t\n284\t    println!(\"=== Maestro Spending Report ===\");\n285\t    println!(\"Total: ${:.2}\", state.total_cost_usd);\n286\t    println!();\n287\t\n288\t    for session in &state.sessions {\n289\t        let label = match session.issue_number {\n290\t            Some(n) => format!(\"#{:<6}\", n),\n291\t            None => session.id.to_string()[..8].to_string(),\n292\t        };\n293\t        println!(\n294\t            \"  {} ${:.2} ({})\",\n295\t            label,\n296\t            session.cost_usd,\n297\t            session.status.label(),\n298\t        );\n299\t    }\n300\t\n301\t    Ok(())\n302\t}\n303\t\n304\tasync fn cmd_queue() -> anyhow::Result<()> {\n305\t    let config = Config::find_and_load()?;\n306\t    let client = GhCliClient::new();\n307\t    let label_refs: Vec<&str> = config\n308\t        .github\n309\t        .issue_filter_labels\n310\t        .iter()\n311\t        .map(|s| s.as_str())\n312\t        .collect();\n313\t    let issues = client.list_issues(&label_refs).await?;\n314\t\n315\t    if issues.is_empty() {\n316\t        println!(\n317\t            \"No issues found with labels: {:?}\",\n318\t            config.github.issue_filter_labels\n319\t        );\n320\t        return Ok(());\n321\t    }\n322\t\n323\t    let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n324\t    let assigner = WorkAssigner::new(items);\n325\t\n326\t    println!(\n327\t        \"{:<10} {:<8} {:<50} {:<10} {:<15}\",\n328\t        \"Priority\", \"Issue\", \"Title\", \"Status\", \"Blocked By\"\n329\t    );\n330\t    println!(\"{}\", \"-\".repeat(93));\n331\t\n332\t    for item in assigner.all_items() {\n333\t        let blocked_str = if item.blocked_by.is_empty() {\n334\t            \"-\".to_string()\n335\t        } else {\n336\t            item.blocked_by\n337\t                .iter()\n338\t                .map(|n| format!(\"#{}\", n))\n339\t                .collect::<Vec<_>>()\n340\t                .join(\", \")\n341\t        };\n342\t        let title: String = if item.title().chars().count() > 48 {\n343\t            let truncated: String = item.title().chars().take(45).collect();\n344\t            format!(\"{}...\", truncated)\n345\t        } else {\n346\t            item.title().to_string()\n347\t        };\n348\t        let no_completed = std::collections::HashSet::new();\n349\t        let ready_str = if item.is_ready(&no_completed) {\n350\t            \"Ready\"\n351\t        } else {\n352\t            \"Blocked\"\n353\t        };\n354\t        println!(\n355\t            \"{:<10} #{:<7} {:<50} {:<10} {}\",\n356\t            format!(\"{:?}\", item.priority),\n357\t            item.number(),\n358\t            title,\n359\t            ready_str,\n360\t            blocked_str\n361\t        );\n362\t    }\n363\t\n364\t    let counts = assigner.count_by_status();\n365\t    println!(\n366\t        \"\\nTotal: {} issues ({} ready, {} blocked)\",\n367\t        assigner.total(),\n368\t        counts.pending,\n369\t        assigner.total() - counts.pending\n370\t    );\n371\t\n372\t    Ok(())\n373\t}\n374\t\n375\tasync fn cmd_add(issue_number: u64) -> anyhow::Result<()> {\n376\t    let client = GhCliClient::new();\n377\t    // Add the maestro:ready label to the issue\n378\t    client.add_label(issue_number, \"maestro:ready\").await?;\n379\t    println!(\"Added 'maestro:ready' label to issue #{}\", issue_number);\n380\t    Ok(())\n381\t}\n382\t\n383\tfn cmd_logs(session: Option<String>, export: Option<String>) -> anyhow::Result<()> {\n384\t    let logger = session::logger::SessionLogger::new(session::logger::SessionLogger::default_dir());\n385\t\n386\t    if let Some(session_id_str) = session {\n387\t        let session_id: uuid::Uuid = session_id_str\n388\t            .parse()\n389\t            .map_err(|_| anyhow::anyhow!(\"Invalid session ID: {}\", session_id_str))?;\n390\t        let content = logger.read_log(session_id)?;\n391\t\n392\t        if export.as_deref() == Some(\"json\") {\n393\t            let lines: Vec<&str> = content.lines().collect();\n394\t            let json = serde_json::json!({\n395\t                \"session_id\": session_id_str,\n396\t                \"lines\": lines,\n397\t            });\n398\t            println!(\"{}\", serde_json::to_string_pretty(&json)?);\n399\t        } else {\n400\t            println!(\"{}\", content);\n401\t        }\n402\t    } else {\n403\t        let logs = logger.list_logs()?;\n404\t        if logs.is_empty() {\n405\t            println!(\"No session logs found.\");\n406\t            return Ok(());\n407\t        }\n408\t\n409\t        if export.as_deref() == Some(\"json\") {\n410\t            let entries: Vec<serde_json::Value> = logs\n411\t                .iter()\n412\t                .map(|l| {\n413\t                    serde_json::json!({\n414\t                        \"session_id\": l.session_id,\n415\t                        \"size_bytes\": l.size_bytes,\n416\t                        \"path\": l.path.display().to_string(),\n417\t                    })\n418\t                })\n419\t                .collect();\n420\t            println!(\"{}\", serde_json::to_string_pretty(&entries)?);\n421\t        } else {\n422\t            println!(\"{:<40} {:>10}\", \"Session ID\", \"Size\");\n423\t            println!(\"{}\", \"-\".repeat(52));\n424\t            for log in &logs {\n425\t                println!(\n426\t                    \"{:<40} {:>10}\",\n427\t                    log.session_id,\n428\t                    format_bytes(log.size_bytes)\n429\t                );\n430\t            }\n431\t            println!(\"\\n{} log(s) found.\", logs.len());\n432\t        }\n433\t    }\n434\t    Ok(())\n435\t}\n436\t\n437\tfn format_bytes(bytes: u64) -> String {\n438\t    if bytes < 1024 {\n439\t        format!(\"{}B\", bytes)\n440\t    } else if bytes < 1024 * 1024 {\n441\t        format!(\"{:.1}KB\", bytes as f64 / 1024.0)\n442\t    } else {\n443\t        format!(\"{:.1}MB\", bytes as f64 / (1024.0 * 1024.0))\n444\t    }\n445\t}\n446\t\n447\tfn cmd_clean(dry_run: bool) -> anyhow::Result<()> {\n448\t    let repo_root = std::env::current_dir()?;\n449\t    let mgr = session::cleanup::CleanupManager::new(&repo_root);\n450\t    let orphans = mgr.scan_orphans()?;\n451\t\n452\t    if orphans.is_empty() {\n453\t        println!(\"No orphaned worktrees found.\");\n454\t        return Ok(());\n455\t    }\n456\t\n457\t    println!(\"Found {} orphaned worktree(s):\", orphans.len());\n458\t    for orphan in &orphans {\n459\t        println!(\"  {} ({})\", orphan.name, orphan.path.display());\n460\t    }\n461\t\n462\t    if dry_run {\n463\t        println!(\"\\nDry run — no changes made.\");\n464\t    } else {\n465\t        let removed = mgr.remove_orphans(&orphans)?;\n466\t        println!(\"\\nRemoved {} worktree(s).\", removed);\n467\t    }\n468\t\n469\t    Ok(())\n470\t}\n471\t\n472\tasync fn cmd_resume(session_filter: Option<String>) -> anyhow::Result<()> {\n473\t    let config = Config::find_and_load()?;\n474\t    let store = StateStore::new(StateStore::default_path());\n475\t    let state = store.load()?;\n476\t    let repo_root = std::env::current_dir()?;\n477\t\n478\t    // Find incomplete sessions\n479\t    let incomplete: Vec<&Session> = state\n480\t        .sessions\n481\t        .iter()\n482\t        .filter(|s| {\n483\t            matches!(\n484\t                s.status,\n485\t                session::types::SessionStatus::Running\n486\t                    | session::types::SessionStatus::Spawning\n487\t                    | session::types::SessionStatus::Queued\n488\t                    | session::types::SessionStatus::Stalled\n489\t                    | session::types::SessionStatus::Errored\n490\t                    | session::types::SessionStatus::Retrying\n491\t            )\n492\t        })\n493\t        .filter(|s| {\n494\t            if let Some(ref filter) = session_filter {\n495\t                s.id.to_string().starts_with(filter)\n496\t                    || s.issue_number\n497\t                        .map(|n| n.to_string() == *filter)\n498\t                        .unwrap_or(false)\n499\t            } else {\n500\t                true\n501\t            }\n502\t        })\n503\t        .collect();\n504\t\n505\t    if incomplete.is_empty() {\n506\t        println!(\"No incomplete sessions to resume.\");\n507\t        return Ok(());\n508\t    }\n509\t\n510\t    println!(\"Resuming {} incomplete session(s)...\", incomplete.len());\n511\t\n512\t    let worktree_mgr = Box::new(GitWorktreeManager::new(repo_root));\n513\t    let max_concurrent = config.sessions.max_concurrent;\n514\t\n515\t    let mut app = App::new(\n516\t        store,\n517\t        max_concurrent,\n518\t        worktree_mgr,\n519\t        config.sessions.permission_mode.clone(),\n520\t        config.sessions.allowed_tools.clone(),\n521\t    );\n522\t\n523\t    // Wire up from config\n524\t    app.budget_enforcer = Some(crate::budget::BudgetEnforcer::new(\n525\t        config.budget.per_session_usd,\n526\t        config.budget.total_usd,\n527\t        config.budget.alert_threshold_pct,\n528\t    ));\n529\t    app.model_router = Some(crate::models::ModelRouter::new(\n530\t        config.models.routing.clone(),\n531\t        config.sessions.default_model.clone(),\n532\t    ));\n533\t    app.notifications =\n534\t        crate::notifications::dispatcher::NotificationDispatcher::new(config.notifications.desktop);\n535\t    if !config.plugins.is_empty() {\n536\t        app.plugin_runner = Some(crate::plugins::runner::PluginRunner::new(\n537\t            config.plugins.clone(),\n538\t            30,\n539\t        ));\n540\t    }\n541\t\n542\t    // Re-enqueue incomplete sessions with their original prompts\n543\t    for s in &incomplete {\n544\t        let mut new_session = Session::new(\n545\t            s.prompt.clone(),\n546\t            s.model.clone(),\n547\t            s.mode.clone(),\n548\t            s.issue_number,\n549\t        );\n550\t        new_session.issue_title = s.issue_title.clone();\n551\t        new_session.retry_count = s.retry_count;\n552\t        app.add_session(new_session).await?;\n553\t    }\n554\t\n555\t    // Set up GitHub client for label management\n556\t    let client = GhCliClient::new();\n557\t    app.github_client = Some(Box::new(client));\n558\t    app.configure(config);\n559\t\n560\t    tui::run(app).await\n561\t}\n562\t\n563\tfn cmd_completions(shell: &str) -> anyhow::Result<()> {\n564\t    use clap::CommandFactory;\n565\t    use clap_complete::{Shell, generate};\n566\t\n567\t    let shell = match shell.to_lowercase().as_str() {\n568\t        \"bash\" => Shell::Bash,\n569\t        \"zsh\" => Shell::Zsh,\n570\t        \"fish\" => Shell::Fish,\n571\t        other => anyhow::bail!(\"Unsupported shell: {}. Use bash, zsh, or fish.\", other),\n572\t    };\n573\t\n574\t    let mut cmd = Cli::command();\n575\t    generate(shell, &mut cmd, \"maestro\", &mut std::io::stdout());\n576\t    Ok(())\n577\t}\n578\t\n579\tasync fn cmd_run(\n580\t    prompt: Option<String>,\n581\t    issue: Option<String>,\n582\t    milestone: Option<String>,\n583\t    model: Option<String>,\n584\t    mode: Option<String>,\n585\t    max_concurrent_override: Option<usize>,\n586\t    resume: bool,\n587\t) -> anyhow::Result<()> {\n588\t    let config = Config::find_and_load()?;\n589\t    let model = model.unwrap_or(config.sessions.default_model.clone());\n590\t    let session_mode = mode.unwrap_or(config.sessions.default_mode.clone());\n591\t    let max_concurrent = max_concurrent_override.unwrap_or(config.sessions.max_concurrent);\n592\t\n593\t    let store = StateStore::new(StateStore::default_path());\n594\t    let repo_root = std::env::current_dir()?;\n595\t\n596\t    // Startup cleanup: remove orphaned worktrees (non-blocking)\n597\t    {\n598\t        let cleanup_mgr = session::cleanup::CleanupManager::new(&repo_root);\n599\t        if let Ok(orphans) = cleanup_mgr.scan_orphans()\n600\t            && !orphans.is_empty()\n601\t        {\n602\t            tracing::info!(\"Cleaning {} orphaned worktrees on startup\", orphans.len());\n603\t            let _ = cleanup_mgr.remove_orphans(&orphans);\n604\t        }\n605\t    }\n606\t\n607\t    // Startup log cleanup: remove logs older than 30 days\n608\t    {\n609\t        let logger =\n610\t            session::logger::SessionLogger::new(session::logger::SessionLogger::default_dir());\n611\t        if let Ok(removed) = logger.cleanup_old_logs(30)\n612\t            && removed > 0\n613\t        {\n614\t            tracing::info!(\"Cleaned {} old session logs\", removed);\n615\t        }\n616\t    }\n617\t    let worktree_mgr = Box::new(GitWorktreeManager::new(repo_root));\n618\t\n619\t    let mut app = App::new(\n620\t        store,\n621\t        max_concurrent,\n622\t        worktree_mgr,\n623\t        config.sessions.permission_mode.clone(),\n624\t        config.sessions.allowed_tools.clone(),\n625\t    );\n626\t\n627\t    // Wire up budget enforcer from config\n628\t    app.budget_enforcer = Some(crate::budget::BudgetEnforcer::new(\n629\t        config.budget.per_session_usd,\n630\t        config.budget.total_usd,\n631\t        config.budget.alert_threshold_pct,\n632\t    ));\n633\t\n634\t    // Wire up model router from config\n635\t    app.model_router = Some(crate::models::ModelRouter::new(\n636\t        config.models.routing.clone(),\n637\t        config.sessions.default_model.clone(),\n638\t    ));\n639\t\n640\t    // Wire up notification dispatcher from config\n641\t    app.notifications =\n642\t        crate::notifications::dispatcher::NotificationDispatcher::new(config.notifications.desktop);\n643\t\n644\t    // Wire up plugin runner from config\n645\t    if !config.plugins.is_empty() {\n646\t        app.plugin_runner = Some(crate::plugins::runner::PluginRunner::new(\n647\t            config.plugins.clone(),\n648\t            30, // default timeout\n649\t        ));\n650\t    }\n651\t\n652\t    // Resume from previous state if requested\n653\t    if resume {\n654\t        let mut recovered = 0;\n655\t        for session in &mut app.state.sessions {\n656\t            if matches!(\n657\t                session.status,\n658\t                session::types::SessionStatus::Running | session::types::SessionStatus::Spawning\n659\t            ) {\n660\t                session.status = session::types::SessionStatus::Errored;\n661\t                recovered += 1;\n662\t            }\n663\t        }\n664\t        if recovered > 0 {\n665\t            tracing::info!(\n666\t                \"Resume: marked {} incomplete sessions as errored (retry will pick them up)\",\n667\t                recovered\n668\t            );\n669\t        }\n670\t    }\n671\t\n672\t    // Determine what to run\n673\t    if let Some(prompt_text) = prompt {\n674\t        let session = Session::new(prompt_text, model, session_mode.clone(), None);\n675\t        app.add_session(session).await?;\n676\t    } else if let Some(milestone_name) = milestone {\n677\t        // Fetch all issues in the milestone\n678\t        let client = GhCliClient::new();\n679\t        let issues = client.list_issues_by_milestone(&milestone_name).await?;\n680\t        if issues.is_empty() {\n681\t            anyhow::bail!(\"No open issues found in milestone '{}'\", milestone_name);\n682\t        }\n683\t\n684\t        let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n685\t        let assigner = WorkAssigner::new(items);\n686\t\n687\t        // Store assigner and config in app for work management\n688\t        app.work_assigner = Some(assigner);\n689\t        app.github_client = Some(Box::new(client));\n690\t        app.configure(config.clone());\n691\t    } else if let Some(issue_str) = issue {\n692\t        let client = GhCliClient::new();\n693\t\n694\t        // Parse comma-separated issue numbers and fetch full issue data\n695\t        for num_str in issue_str.split(',') {\n696\t            let num: u64 = num_str\n697\t                .trim()\n698\t                .parse()\n699\t                .map_err(|_| anyhow::anyhow!(\"Invalid issue number: {}\", num_str.trim()))?;\n700\t\n701\t            let gh_issue = client.get_issue(num).await?;\n702\t            // Use mode from label (maestro:mode:X) or CLI --mode or config default\n703\t            let issue_mode = crate::modes::mode_from_labels(&gh_issue.labels)\n704\t                .unwrap_or_else(|| session_mode.clone());\n705\t            let mut session = Session::new(\n706\t                gh_issue.unattended_prompt(),\n707\t                model.clone(),\n708\t                issue_mode,\n709\t                Some(num),\n710\t            );\n711\t            session.issue_title = Some(gh_issue.title.clone());\n712\t\n713\t            // Cache issue data\n714\t            app.state.issue_cache.insert(num, gh_issue);\n715\t\n716\t            app.add_session(session).await?;\n717\t        }\n718\t\n719\t        // Set github client + config so label lifecycle and auto-PR work\n720\t        app.github_client = Some(Box::new(client));\n721\t        app.configure(config.clone());\n722\t    } else {\n723\t        // No prompt, issue, or milestone — auto-fetch maestro:ready issues\n724\t        let client = GhCliClient::new();\n725\t        let label_refs: Vec<&str> = config\n726\t            .github\n727\t            .issue_filter_labels\n728\t            .iter()\n729\t            .map(|s| s.as_str())\n730\t            .collect();\n731\t        let issues = client.list_issues(&label_refs).await?;\n732\t\n733\t        if issues.is_empty() {\n734\t            anyhow::bail!(\n735\t                \"No issues found with labels {:?}. Use --prompt or --issue instead.\",\n736\t                config.github.issue_filter_labels\n737\t            );\n738\t        }\n739\t\n740\t        let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n741\t        let assigner = WorkAssigner::new(items);\n742\t\n743\t        app.work_assigner = Some(assigner);\n744\t        app.github_client = Some(Box::new(client));\n745\t        app.configure(config.clone());\n746\t    }\n747\t\n748\t    // Launch TUI\n749\t    tui::run(app).await\n750\t}\n751\t\n752\tasync fn cmd_dashboard() -> anyhow::Result<()> {\n753\t    let store = StateStore::new(StateStore::default_path());\n754\t    let state = store.load().unwrap_or_default();\n755\t    let repo_root = std::env::current_dir()?;\n756\t\n757\t    // Check for incomplete sessions and offer auto-resume\n758\t    let has_incomplete = state.sessions.iter().any(|s| {\n759\t        matches!(\n760\t            s.status,\n761\t            session::types::SessionStatus::Running\n762\t                | session::types::SessionStatus::Spawning\n763\t                | session::types::SessionStatus::Queued\n764\t                | session::types::SessionStatus::Stalled\n765\t                | session::types::SessionStatus::Retrying\n766\t        )\n767\t    });\n768\t\n769\t    if has_incomplete {\n770\t        eprintln!(\n771\t            \"Found incomplete sessions from previous run. Use `maestro resume` to continue them.\"\n772\t        );\n773\t    }\n774\t\n775\t    let worktree_mgr = Box::new(GitWorktreeManager::new(repo_root));\n776\t    let app = App::new(\n777\t        store,\n778\t        3,\n779\t        worktree_mgr,\n780\t        \"bypassPermissions\".into(),\n781\t        Vec::new(),\n782\t    );\n783\t    tui::run(app).await\n784\t}\n785\t"}]},"parent_tool_use_id":null,"session_id":"ed5b4c3b-17c9-4623-aff8-aa315e2f73f6","uuid":"f5deeb65-17a4-4efa-8a57-481029f4abdb","timestamp":"2026-04-01T04:29:07.329Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/carlos/projects/maestro/.maestro/worktrees/issue-14/src/main.rs","content":"mod budget;\nmod config;\nmod gates;\nmod git;\nmod github;\nmod models;\nmod modes;\nmod notifications;\nmod plugins;\nmod prompts;\nmod provider;\nmod review;\nmod session;\nmod state;\nmod tui;\nmod util;\nmod work;\n\nuse clap::{Parser, Subcommand};\nuse config::Config;\nuse github::client::{GhCliClient, GitHubClient};\nuse session::types::Session;\nuse session::worktree::GitWorktreeManager;\nuse state::store::StateStore;\nuse tui::app::App;\nuse work::assigner::WorkAssigner;\nuse work::types::WorkItem;\n\n#[derive(Parser)]\n#[command(\n    name = \"maestro\",\n    version,\n    about = \"Multi-session Claude Code orchestrator\"\n)]\nstruct Cli {\n    #[command(subcommand)]\n    command: Option<Commands>,\n}\n\n#[derive(Subcommand)]\nenum Commands {\n    /// Run sessions from GitHub issues or a prompt\n    Run {\n        /// Prompt to send to Claude\n        #[arg(short, long)]\n        prompt: Option<String>,\n\n        /// GitHub issue number(s), comma-separated\n        #[arg(short, long)]\n        issue: Option<String>,\n\n        /// Milestone to fetch all issues from\n        #[arg(short = 'M', long)]\n        milestone: Option<String>,\n\n        /// Model to use (opus, sonnet, haiku)\n        #[arg(short, long)]\n        model: Option<String>,\n\n        /// Session mode (orchestrator, vibe, review, or custom)\n        #[arg(long)]\n        mode: Option<String>,\n\n        /// Max concurrent sessions (overrides config)\n        #[arg(long)]\n        max_concurrent: Option<usize>,\n\n        /// Resume from previous state after a crash\n        #[arg(long)]\n        resume: bool,\n    },\n    /// Show queued/pending issues from GitHub\n    Queue,\n    /// Add an issue to the work queue manually\n    Add {\n        /// Issue number to add\n        issue_number: u64,\n    },\n    /// Show current state without TUI\n    Status,\n    /// Show spending report\n    Cost,\n    /// Initialize maestro.toml in current directory\n    Init,\n    /// Clean orphaned worktrees left by crashed sessions\n    Clean {\n        /// Show what would be cleaned without actually doing it\n        #[arg(long)]\n        dry_run: bool,\n    },\n    /// Show session transcript logs\n    Logs {\n        /// Show full log for a specific session ID\n        #[arg(long)]\n        session: Option<String>,\n        /// Export as JSON\n        #[arg(long)]\n        export: Option<String>,\n    },\n    /// Resume interrupted sessions from saved state\n    Resume {\n        /// Resume a specific session by ID\n        #[arg(long)]\n        session: Option<String>,\n    },\n    /// Generate shell completions\n    Completions {\n        /// Shell to generate completions for (bash, zsh, fish)\n        shell: String,\n    },\n}\n\n#[tokio::main]\nasync fn main() -> anyhow::Result<()> {\n    // Init logging (to file, not terminal — TUI owns stdout)\n    tracing_subscriber::fmt()\n        .with_env_filter(\"maestro=debug\")\n        .with_writer(|| {\n            std::fs::OpenOptions::new()\n                .create(true)\n                .append(true)\n                .open(\"maestro.log\")\n                .unwrap_or_else(|_| {\n                    std::fs::OpenOptions::new()\n                        .write(true)\n                        .open(\"/dev/null\")\n                        .unwrap()\n                })\n        })\n        .init();\n\n    let cli = Cli::parse();\n\n    match cli.command {\n        Some(Commands::Init) => cmd_init(),\n        Some(Commands::Clean { dry_run }) => cmd_clean(dry_run),\n        Some(Commands::Logs { session, export }) => cmd_logs(session, export),\n        Some(Commands::Resume { session }) => cmd_resume(session).await,\n        Some(Commands::Completions { shell }) => cmd_completions(&shell),\n        Some(Commands::Status) => cmd_status(),\n        Some(Commands::Cost) => cmd_cost(),\n        Some(Commands::Queue) => cmd_queue().await,\n        Some(Commands::Add { issue_number }) => cmd_add(issue_number).await,\n        Some(Commands::Run {\n            prompt,\n            issue,\n            milestone,\n            model,\n            mode,\n            max_concurrent,\n            resume,\n        }) => {\n            cmd_run(\n                prompt,\n                issue,\n                milestone,\n                model,\n                mode,\n                max_concurrent,\n                resume,\n            )\n            .await\n        }\n        // Default: launch TUI with no sessions (dashboard mode)\n        None => cmd_dashboard().await,\n    }\n}\n\nfn cmd_init() -> anyhow::Result<()> {\n    let path = std::path::PathBuf::from(\"maestro.toml\");\n    if path.exists() {\n        println!(\"maestro.toml already exists.\");\n        return Ok(());\n    }\n\n    let content = r#\"[project]\nrepo = \"\"\nbase_branch = \"main\"\n\n[sessions]\nmax_concurrent = 3\nstall_timeout_secs = 300\ndefault_model = \"opus\"\ndefault_mode = \"orchestrator\"\npermission_mode = \"bypassPermissions\"  # Options: default, acceptEdits, bypassPermissions, dontAsk, plan, auto\nallowed_tools = []                      # Empty = all tools. Example: [\"Bash\", \"Read\", \"Write\", \"Edit\"]\n\n[budget]\nper_session_usd = 5.0\ntotal_usd = 50.0\nalert_threshold_pct = 80\n\n[github]\nissue_filter_labels = [\"maestro:ready\"]\nauto_pr = true\nauto_merge = false                      # Set to true to auto-merge PRs after CI + review pass\nmerge_method = \"squash\"                 # Options: merge, squash, rebase\ncache_ttl_secs = 300\n\n[gates]\nenabled = true\ntest_command = \"cargo test\"\nci_poll_interval_secs = 30\nci_max_wait_secs = 1800\n\n[notifications]\ndesktop = true\nslack = false\n\n[review]\nenabled = false\ncommand = \"gh pr review {pr_number} --comment --body 'Automated review by Maestro'\"\n# reviewers = [\n#   { name = \"claude\", command = \"claude --print 'review PR #{pr_number}'\", required = true },\n#   { name = \"codex\", command = \"codex review {pr_number}\", required = false },\n# ]\n\n[concurrency]\nheavy_task_labels = []                  # Labels that mark a task as resource-intensive\nheavy_task_limit = 2                    # Max concurrent heavy tasks\n\n[monitoring]\nwork_tick_interval_secs = 10\n\n# Plugin hooks — shell commands triggered on lifecycle events\n# [[plugins]]\n# name = \"notify-team\"\n# on = \"session_completed\"             # Hook points: session_started, session_completed, tests_passed,\n#                                      #   tests_failed, budget_threshold, file_conflict, pr_created\n# run = \"curl -X POST https://slack.webhook/...\"\n# timeout_secs = 30                    # Optional per-plugin timeout\n\n# Custom modes — define system prompt and allowed tools\n# [modes.review]\n# system_prompt = \"You are a code reviewer. Review the PR and leave comments.\"\n# allowed_tools = [\"Read\", \"Grep\", \"Glob\"]\n# permission_mode = \"plan\"\n\"#;\n\n    std::fs::write(&path, content)?;\n    println!(\"Created maestro.toml\");\n    Ok(())\n}\n\nfn cmd_status() -> anyhow::Result<()> {\n    let store = StateStore::new(StateStore::default_path());\n    let state = store.load()?;\n\n    if state.sessions.is_empty() {\n        println!(\"No sessions recorded.\");\n        return Ok(());\n    }\n\n    println!(\n        \"Sessions: {} total, {} active\",\n        state.sessions.len(),\n        state.active_sessions().len()\n    );\n    println!(\"Total cost: ${:.2}\", state.total_cost_usd);\n    println!();\n\n    for session in &state.sessions {\n        let label = match session.issue_number {\n            Some(n) => format!(\"#{}\", n),\n            None => session.id.to_string()[..8].to_string(),\n        };\n        println!(\n            \"  {} {} {} ${:.2} {}\",\n            session.status.symbol(),\n            label,\n            session.status.label(),\n            session.cost_usd,\n            session.elapsed_display(),\n        );\n    }\n\n    Ok(())\n}\n\nfn cmd_cost() -> anyhow::Result<()> {\n    let store = StateStore::new(StateStore::default_path());\n    let state = store.load()?;\n\n    println!(\"=== Maestro Spending Report ===\");\n    println!(\"Total: ${:.2}\", state.total_cost_usd);\n    println!();\n\n    for session in &state.sessions {\n        let label = match session.issue_number {\n            Some(n) => format!(\"#{:<6}\", n),\n            None => session.id.to_string()[..8].to_string(),\n        };\n        println!(\n            \"  {} ${:.2} ({})\",\n            label,\n            session.cost_usd,\n            session.status.label(),\n        );\n    }\n\n    Ok(())\n}\n\nasync fn cmd_queue() -> anyhow::Result<()> {\n    let config = Config::find_and_load()?;\n    let client = GhCliClient::new();\n    let label_refs: Vec<&str> = config\n        .github\n        .issue_filter_labels\n        .iter()\n        .map(|s| s.as_str())\n        .collect();\n    let issues = client.list_issues(&label_refs).await?;\n\n    if issues.is_empty() {\n        println!(\n            \"No issues found with labels: {:?}\",\n            config.github.issue_filter_labels\n        );\n        return Ok(());\n    }\n\n    let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n    let assigner = WorkAssigner::new(items);\n\n    println!(\n        \"{:<10} {:<8} {:<50} {:<10} {:<15}\",\n        \"Priority\", \"Issue\", \"Title\", \"Status\", \"Blocked By\"\n    );\n    println!(\"{}\", \"-\".repeat(93));\n\n    for item in assigner.all_items() {\n        let blocked_str = if item.blocked_by.is_empty() {\n            \"-\".to_string()\n        } else {\n            item.blocked_by\n                .iter()\n                .map(|n| format!(\"#{}\", n))\n                .collect::<Vec<_>>()\n                .join(\", \")\n        };\n        let title: String = if item.title().chars().count() > 48 {\n            let truncated: String = item.title().chars().take(45).collect();\n            format!(\"{}...\", truncated)\n        } else {\n            item.title().to_string()\n        };\n        let no_completed = std::collections::HashSet::new();\n        let ready_str = if item.is_ready(&no_completed) {\n            \"Ready\"\n        } else {\n            \"Blocked\"\n        };\n        println!(\n            \"{:<10} #{:<7} {:<50} {:<10} {}\",\n            format!(\"{:?}\", item.priority),\n            item.number(),\n            title,\n            ready_str,\n            blocked_str\n        );\n    }\n\n    let counts = assigner.count_by_status();\n    println!(\n        \"\\nTotal: {} issues ({} ready, {} blocked)\",\n        assigner.total(),\n        counts.pending,\n        assigner.total() - counts.pending\n    );\n\n    Ok(())\n}\n\nasync fn cmd_add(issue_number: u64) -> anyhow::Result<()> {\n    let client = GhCliClient::new();\n    // Add the maestro:ready label to the issue\n    client.add_label(issue_number, \"maestro:ready\").await?;\n    println!(\"Added 'maestro:ready' label to issue #{}\", issue_number);\n    Ok(())\n}\n\nfn cmd_logs(session: Option<String>, export: Option<String>) -> anyhow::Result<()> {\n    let logger = session::logger::SessionLogger::new(session::logger::SessionLogger::default_dir());\n\n    if let Some(session_id_str) = session {\n        let session_id: uuid::Uuid = session_id_str\n            .parse()\n            .map_err(|_| anyhow::anyhow!(\"Invalid session ID: {}\", session_id_str))?;\n        let content = logger.read_log(session_id)?;\n\n        if export.as_deref() == Some(\"json\") {\n            let lines: Vec<&str> = content.lines().collect();\n            let json = serde_json::json!({\n                \"session_id\": session_id_str,\n                \"lines\": lines,\n            });\n            println!(\"{}\", serde_json::to_string_pretty(&json)?);\n        } else {\n            println!(\"{}\", content);\n        }\n    } else {\n        let logs = logger.list_logs()?;\n        if logs.is_empty() {\n            println!(\"No session logs found.\");\n            return Ok(());\n        }\n\n        if export.as_deref() == Some(\"json\") {\n            let entries: Vec<serde_json::Value> = logs\n                .iter()\n                .map(|l| {\n                    serde_json::json!({\n                        \"session_id\": l.session_id,\n                        \"size_bytes\": l.size_bytes,\n                        \"path\": l.path.display().to_string(),\n                    })\n                })\n                .collect();\n            println!(\"{}\", serde_json::to_string_pretty(&entries)?);\n        } else {\n            println!(\"{:<40} {:>10}\", \"Session ID\", \"Size\");\n            println!(\"{}\", \"-\".repeat(52));\n            for log in &logs {\n                println!(\n                    \"{:<40} {:>10}\",\n                    log.session_id,\n                    format_bytes(log.size_bytes)\n                );\n            }\n            println!(\"\\n{} log(s) found.\", logs.len());\n        }\n    }\n    Ok(())\n}\n\nfn format_bytes(bytes: u64) -> String {\n    if bytes < 1024 {\n        format!(\"{}B\", bytes)\n    } else if bytes < 1024 * 1024 {\n        format!(\"{:.1}KB\", bytes as f64 / 1024.0)\n    } else {\n        format!(\"{:.1}MB\", bytes as f64 / (1024.0 * 1024.0))\n    }\n}\n\nfn cmd_clean(dry_run: bool) -> anyhow::Result<()> {\n    let repo_root = std::env::current_dir()?;\n    let mgr = session::cleanup::CleanupManager::new(&repo_root);\n    let orphans = mgr.scan_orphans()?;\n\n    if orphans.is_empty() {\n        println!(\"No orphaned worktrees found.\");\n        return Ok(());\n    }\n\n    println!(\"Found {} orphaned worktree(s):\", orphans.len());\n    for orphan in &orphans {\n        println!(\"  {} ({})\", orphan.name, orphan.path.display());\n    }\n\n    if dry_run {\n        println!(\"\\nDry run — no changes made.\");\n    } else {\n        let removed = mgr.remove_orphans(&orphans)?;\n        println!(\"\\nRemoved {} worktree(s).\", removed);\n    }\n\n    Ok(())\n}\n\nasync fn cmd_resume(session_filter: Option<String>) -> anyhow::Result<()> {\n    let config = Config::find_and_load()?;\n    let store = StateStore::new(StateStore::default_path());\n    let state = store.load()?;\n    let repo_root = std::env::current_dir()?;\n\n    // Find incomplete sessions\n    let incomplete: Vec<&Session> = state\n        .sessions\n        .iter()\n        .filter(|s| {\n            matches!(\n                s.status,\n                session::types::SessionStatus::Running\n                    | session::types::SessionStatus::Spawning\n                    | session::types::SessionStatus::Queued\n                    | session::types::SessionStatus::Stalled\n                    | session::types::SessionStatus::Errored\n                    | session::types::SessionStatus::Retrying\n            )\n        })\n        .filter(|s| {\n            if let Some(ref filter) = session_filter {\n                s.id.to_string().starts_with(filter)\n                    || s.issue_number\n                        .map(|n| n.to_string() == *filter)\n                        .unwrap_or(false)\n            } else {\n                true\n            }\n        })\n        .collect();\n\n    if incomplete.is_empty() {\n        println!(\"No incomplete sessions to resume.\");\n        return Ok(());\n    }\n\n    println!(\"Resuming {} incomplete session(s)...\", incomplete.len());\n\n    let worktree_mgr = Box::new(GitWorktreeManager::new(repo_root));\n    let max_concurrent = config.sessions.max_concurrent;\n\n    let mut app = App::new(\n        store,\n        max_concurrent,\n        worktree_mgr,\n        config.sessions.permission_mode.clone(),\n        config.sessions.allowed_tools.clone(),\n    );\n\n    // Wire up from config\n    app.budget_enforcer = Some(crate::budget::BudgetEnforcer::new(\n        config.budget.per_session_usd,\n        config.budget.total_usd,\n        config.budget.alert_threshold_pct,\n    ));\n    app.model_router = Some(crate::models::ModelRouter::new(\n        config.models.routing.clone(),\n        config.sessions.default_model.clone(),\n    ));\n    app.notifications =\n        crate::notifications::dispatcher::NotificationDispatcher::new(config.notifications.desktop);\n    if !config.plugins.is_empty() {\n        app.plugin_runner = Some(crate::plugins::runner::PluginRunner::new(\n            config.plugins.clone(),\n            30,\n        ));\n    }\n\n    // Re-enqueue incomplete sessions with their original prompts\n    for s in &incomplete {\n        let mut new_session = Session::new(\n            s.prompt.clone(),\n            s.model.clone(),\n            s.mode.clone(),\n            s.issue_number,\n        );\n        new_session.issue_title = s.issue_title.clone();\n        new_session.retry_count = s.retry_count;\n        app.add_session(new_session).await?;\n    }\n\n    // Set up GitHub client for label management\n    let client = GhCliClient::new();\n    app.github_client = Some(Box::new(client));\n    app.configure(config);\n\n    tui::run(app).await\n}\n\nfn cmd_completions(shell: &str) -> anyhow::Result<()> {\n    use clap::CommandFactory;\n    use clap_complete::{Shell, generate};\n\n    let shell = match shell.to_lowercase().as_str() {\n        \"bash\" => Shell::Bash,\n        \"zsh\" => Shell::Zsh,\n        \"fish\" => Shell::Fish,\n        other => anyhow::bail!(\"Unsupported shell: {}. Use bash, zsh, or fish.\", other),\n    };\n\n    let mut cmd = Cli::command();\n    generate(shell, &mut cmd, \"maestro\", &mut std::io::stdout());\n    Ok(())\n}\n\nasync fn cmd_run(\n    prompt: Option<String>,\n    issue: Option<String>,\n    milestone: Option<String>,\n    model: Option<String>,\n    mode: Option<String>,\n    max_concurrent_override: Option<usize>,\n    resume: bool,\n) -> anyhow::Result<()> {\n    let config = Config::find_and_load()?;\n    let model = model.unwrap_or(config.sessions.default_model.clone());\n    let session_mode = mode.unwrap_or(config.sessions.default_mode.clone());\n    let max_concurrent = max_concurrent_override.unwrap_or(config.sessions.max_concurrent);\n\n    let store = StateStore::new(StateStore::default_path());\n    let repo_root = std::env::current_dir()?;\n\n    // Startup cleanup: remove orphaned worktrees (non-blocking)\n    {\n        let cleanup_mgr = session::cleanup::CleanupManager::new(&repo_root);\n        if let Ok(orphans) = cleanup_mgr.scan_orphans()\n            && !orphans.is_empty()\n        {\n            tracing::info!(\"Cleaning {} orphaned worktrees on startup\", orphans.len());\n            let _ = cleanup_mgr.remove_orphans(&orphans);\n        }\n    }\n\n    // Startup log cleanup: remove logs older than 30 days\n    {\n        let logger =\n            session::logger::SessionLogger::new(session::logger::SessionLogger::default_dir());\n        if let Ok(removed) = logger.cleanup_old_logs(30)\n            && removed > 0\n        {\n            tracing::info!(\"Cleaned {} old session logs\", removed);\n        }\n    }\n    let worktree_mgr = Box::new(GitWorktreeManager::new(repo_root));\n\n    let mut app = App::new(\n        store,\n        max_concurrent,\n        worktree_mgr,\n        config.sessions.permission_mode.clone(),\n        config.sessions.allowed_tools.clone(),\n    );\n\n    // Wire up budget enforcer from config\n    app.budget_enforcer = Some(crate::budget::BudgetEnforcer::new(\n        config.budget.per_session_usd,\n        config.budget.total_usd,\n        config.budget.alert_threshold_pct,\n    ));\n\n    // Wire up model router from config\n    app.model_router = Some(crate::models::ModelRouter::new(\n        config.models.routing.clone(),\n        config.sessions.default_model.clone(),\n    ));\n\n    // Wire up notification dispatcher from config\n    app.notifications =\n        crate::notifications::dispatcher::NotificationDispatcher::new(config.notifications.desktop);\n\n    // Wire up plugin runner from config\n    if !config.plugins.is_empty() {\n        app.plugin_runner = Some(crate::plugins::runner::PluginRunner::new(\n            config.plugins.clone(),\n            30, // default timeout\n        ));\n    }\n\n    // Resume from previous state if requested\n    if resume {\n        let mut recovered = 0;\n        for session in &mut app.state.sessions {\n            if matches!(\n                session.status,\n                session::types::SessionStatus::Running | session::types::SessionStatus::Spawning\n            ) {\n                session.status = session::types::SessionStatus::Errored;\n                recovered += 1;\n            }\n        }\n        if recovered > 0 {\n            tracing::info!(\n                \"Resume: marked {} incomplete sessions as errored (retry will pick them up)\",\n                recovered\n            );\n        }\n    }\n\n    // Determine what to run\n    if let Some(prompt_text) = prompt {\n        let session = Session::new(prompt_text, model, session_mode.clone(), None);\n        app.add_session(session).await?;\n    } else if let Some(milestone_name) = milestone {\n        // Fetch all issues in the milestone\n        let client = GhCliClient::new();\n        let issues = client.list_issues_by_milestone(&milestone_name).await?;\n        if issues.is_empty() {\n            anyhow::bail!(\"No open issues found in milestone '{}'\", milestone_name);\n        }\n\n        let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n        let assigner = WorkAssigner::new(items);\n\n        // Store assigner and config in app for work management\n        app.work_assigner = Some(assigner);\n        app.github_client = Some(Box::new(client));\n        app.configure(config.clone());\n    } else if let Some(issue_str) = issue {\n        let client = GhCliClient::new();\n\n        // Parse comma-separated issue numbers and fetch full issue data\n        for num_str in issue_str.split(',') {\n            let num: u64 = num_str\n                .trim()\n                .parse()\n                .map_err(|_| anyhow::anyhow!(\"Invalid issue number: {}\", num_str.trim()))?;\n\n            let gh_issue = client.get_issue(num).await?;\n            // Use mode from label (maestro:mode:X) or CLI --mode or config default\n            let issue_mode = crate::modes::mode_from_labels(&gh_issue.labels)\n                .unwrap_or_else(|| session_mode.clone());\n            let mut session = Session::new(\n                gh_issue.unattended_prompt(),\n                model.clone(),\n                issue_mode,\n                Some(num),\n            );\n            session.issue_title = Some(gh_issue.title.clone());\n\n            // Cache issue data\n            app.state.issue_cache.insert(num, gh_issue);\n\n            app.add_session(session).await?;\n        }\n\n        // Set github client + config so label lifecycle and auto-PR work\n        app.github_client = Some(Box::new(client));\n        app.configure(config.clone());\n    } else {\n        // No prompt, issue, or milestone — auto-fetch maestro:ready issues\n        let client = GhCliClient::new();\n        let label_refs: Vec<&str> = config\n            .github\n            .issue_filter_labels\n            .iter()\n            .map(|s| s.as_str())\n            .collect();\n        let issues = client.list_issues(&label_refs).await?;\n\n        if issues.is_empty() {\n            anyhow::bail!(\n                \"No issues found with labels {:?}. Use --prompt or --issue instead.\",\n                config.github.issue_filter_labels\n            );\n        }\n\n        let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n        let assigner = WorkAssigner::new(items);\n\n        app.work_assigner = Some(assigner);\n        app.github_client = Some(Box::new(client));\n        app.configure(config.clone());\n    }\n\n    // Launch TUI\n    tui::run(app).await\n}\n\nasync fn cmd_dashboard() -> anyhow::Result<()> {\n    let store = StateStore::new(StateStore::default_path());\n    let state = store.load().unwrap_or_default();\n    let repo_root = std::env::current_dir()?;\n\n    // Check for incomplete sessions and offer auto-resume\n    let has_incomplete = state.sessions.iter().any(|s| {\n        matches!(\n            s.status,\n            session::types::SessionStatus::Running\n                | session::types::SessionStatus::Spawning\n                | session::types::SessionStatus::Queued\n                | session::types::SessionStatus::Stalled\n                | session::types::SessionStatus::Retrying\n        )\n    });\n\n    if has_incomplete {\n        eprintln!(\n            \"Found incomplete sessions from previous run. Use `maestro resume` to continue them.\"\n        );\n    }\n\n    let worktree_mgr = Box::new(GitWorktreeManager::new(repo_root));\n    let app = App::new(\n        store,\n        3,\n        worktree_mgr,\n        \"bypassPermissions\".into(),\n        Vec::new(),\n    );\n    tui::run(app).await\n}\n","numLines":785,"startLine":1,"totalLines":785}}}
