[2026-03-24T20:20:30.460Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FrENAdRddNo7qnPvM4deZM","type":"tool_result","content":"     1→use std::collections::HashMap;\n     2→\n     3→use crate::github::types::GhIssue;\n     4→\n     5→/// Routes issues to specific models based on label-matching rules.\n     6→pub struct ModelRouter {\n     7→    /// Ordered rules: pattern -> model name. First match wins.\n     8→    rules: Vec<(String, String)>,\n     9→    default_model: String,\n    10→}\n    11→\n    12→impl ModelRouter {\n    13→    pub fn new(rules: HashMap<String, String>, default_model: String) -> Self {\n    14→        // Convert to ordered vec sorted by key for deterministic matching\n    15→        let mut rules: Vec<(String, String)> = rules.into_iter().collect();\n    16→        rules.sort_by(|a, b| a.0.cmp(&b.0));\n    17→        Self {\n    18→            rules,\n    19→            default_model,\n    20→        }\n    21→    }\n    22→\n    23→    /// Resolve which model to use for a given issue.\n    24→    /// Checks issue labels against routing rules. First match wins.\n    25→    /// Rules are patterns like \"priority:P0\" or \"type:docs\".\n    26→    pub fn resolve(&self, issue: &GhIssue) -> &str {\n    27→        for (pattern, model) in &self.rules {\n    28→            if issue.labels.iter().any(|l| l == pattern) {\n    29→                return model;\n    30→            }\n    31→        }\n    32→        &self.default_model\n    33→    }\n    34→}\n    35→\n    36→#[cfg(test)]\n    37→mod tests {\n    38→    use super::*;\n    39→\n    40→    fn make_issue(labels: &[&str]) -> GhIssue {\n    41→        GhIssue {\n    42→            number: 1,\n    43→            title: \"Test\".into(),\n    44→            body: String::new(),\n    45→            labels: labels.iter().map(|s| s.to_string()).collect(),\n    46→            state: \"open\".into(),\n    47→            html_url: String::new(),\n    48→        }\n    49→    }\n    50→\n    51→    #[test]\n    52→    fn resolve_returns_default_when_no_rules() {\n    53→        let router = ModelRouter::new(HashMap::new(), \"sonnet\".into());\n    54→        let issue = make_issue(&[\"priority:P0\"]);\n    55→        assert_eq!(router.resolve(&issue), \"sonnet\");\n    56→    }\n    57→\n    58→    #[test]\n    59→    fn resolve_matches_priority_label() {\n    60→        let mut rules = HashMap::new();\n    61→        rules.insert(\"priority:P0\".into(), \"opus\".into());\n    62→        let router = ModelRouter::new(rules, \"sonnet\".into());\n    63→\n    64→        let issue = make_issue(&[\"priority:P0\", \"maestro:ready\"]);\n    65→        assert_eq!(router.resolve(&issue), \"opus\");\n    66→    }\n    67→\n    68→    #[test]\n    69→    fn resolve_returns_default_when_no_match() {\n    70→        let mut rules = HashMap::new();\n    71→        rules.insert(\"priority:P0\".into(), \"opus\".into());\n    72→        let router = ModelRouter::new(rules, \"sonnet\".into());\n    73→\n    74→        let issue = make_issue(&[\"priority:P2\"]);\n    75→        assert_eq!(router.resolve(&issue), \"sonnet\");\n    76→    }\n    77→\n    78→    #[test]\n    79→    fn resolve_first_matching_rule_wins() {\n    80→        let mut rules = HashMap::new();\n    81→        rules.insert(\"priority:P0\".into(), \"opus\".into());\n    82→        rules.insert(\"type:docs\".into(), \"haiku\".into());\n    83→        let router = ModelRouter::new(rules, \"sonnet\".into());\n    84→\n    85→        // Issue has both labels — sorted rules mean \"priority:P0\" comes first\n    86→        let issue = make_issue(&[\"type:docs\", \"priority:P0\"]);\n    87→        assert_eq!(router.resolve(&issue), \"opus\");\n    88→    }\n    89→\n    90→    #[test]\n    91→    fn resolve_type_docs_routes_to_configured_model() {\n    92→        let mut rules = HashMap::new();\n    93→        rules.insert(\"type:docs\".into(), \"haiku\".into());\n    94→        let router = ModelRouter::new(rules, \"sonnet\".into());\n    95→\n    96→        let issue = make_issue(&[\"type:docs\"]);\n    97→        assert_eq!(router.resolve(&issue), \"haiku\");\n    98→    }\n    99→\n   100→    #[test]\n   101→    fn resolve_with_empty_labels() {\n   102→        let mut rules = HashMap::new();\n   103→        rules.insert(\"priority:P0\".into(), \"opus\".into());\n   104→        let router = ModelRouter::new(rules, \"sonnet\".into());\n   105→\n   106→        let issue = make_issue(&[]);\n   107→        assert_eq!(router.resolve(&issue), \"sonnet\");\n   108→    }\n   109→}\n   110→"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"b5117ec7-6e16-40c1-b8c2-2c0e49e046c1","timestamp":"2026-03-24T20:20:30.452Z"}
