});\n   140→\n   141→        // Stderr reader task — capture errors from Claude CLI\n   142→        if let Some(stderr) = stderr {\n   143→            tokio::spawn(async move {\n   144→                let reader = BufReader::new(stderr);\n   145→                let mut lines = reader.lines();\n   146→                let mut stderr_buf = String::new();\n   147→\n   148→                while let Ok(Some(line)) = lines.next_line().await {\n   149→                    if !line.trim().is_empty() {\n   150→                        if !stderr_buf.is_empty() {\n   151→                            stderr_buf.push('\\n');\n   152→                        }\n   153→                        stderr_buf.push_str(&line);\n   154→                    }\n   155→                }\n   156→\n   157→                if !stderr_buf.is_empty() {\n   158→                    let _ = tx2.send(SessionEvent {\n   159→                        session_id,\n   160→                        event: StreamEvent::Error {\n   161→                            message: stderr_buf,\n   162→                        },\n   163→                    });\n   164→                }\n   165→            });\n   166→        }\n   167→\n   168→        self.child = Some(child);\n   169→        Ok(())\n   170→    }\n   171→\n   172→    /// Send SIGSTOP to pause.\n   173→    #[cfg(unix)]\n   174→    pub fn pause(&self) -> Result<()> {\n   175→        if let Some(pid) = self.session.pid {\n   176→            unsafe {\n   177→                libc::kill(pid as i32, libc::SIGSTOP);\n   178→            }\n   179→        }\n   180→        Ok(())\n   181→    }\n   182→\n   183→    /// Send SIGCONT to resume.\n   184→    #[cfg(unix)]\n   185→    pub fn resume(&self) -> Result<()> {\n   186→        if let Some(pid) = self.session.pid {\n   187→            unsafe {\n   188→                libc::kill(pid as i32, libc::SIGCONT);\n   189→            }\n   190→        }\n   191→        Ok(())\n   192→    }\n   193→\n   194→    /// Kill the chil