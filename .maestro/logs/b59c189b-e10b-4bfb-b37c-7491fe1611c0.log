[2026-03-24T20:20:40.464Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y9D7h4aXigBE6gcn8ky8mu","type":"tool_result","content":"     1→use crate::config::Config;\n     2→use crate::github::types::GhIssue;\n     3→\n     4→/// Builds structured prompts for Claude sessions based on issue type and config.\n     5→pub struct PromptBuilder;\n     6→\n     7→impl PromptBuilder {\n     8→    /// Build a structured prompt for an issue-based session.\n     9→    pub fn build_issue_prompt(issue: &GhIssue, config: &Config) -> String {\n    10→        let task_type = Self::detect_task_type(issue);\n    11→        let phase_instructions = Self::phase_instructions(&task_type);\n    12→        let safety_guards = Self::safety_guards();\n    13→        let reasoning_steps = Self::structured_reasoning();\n    14→\n    15→        format!(\n    16→            \"Work on GitHub issue #{issue_number}.\\n\\n\\\n    17→             Title: {title}\\n\\n\\\n    18→             Description:\\n{body}\\n\\n\\\n    19→             ## Task Type: {task_type_label}\\n\\n\\\n    20→             {phase_instructions}\\n\\n\\\n    21→             ## Safety Guards\\n\\n\\\n    22→             {safety_guards}\\n\\n\\\n    23→             ## Approach\\n\\n\\\n    24→             {reasoning_steps}\\n\\n\\\n    25→             ## Runtime Context\\n\\n\\\n    26→             - Base branch: {base_branch}\\n\\\n    27→             - Model: {model}\\n\\\n    28→             - Mode: {mode}\\n\\n\\\n    29→             IMPORTANT: You are running in unattended mode (no human at the terminal). \\\n    30→             Do NOT use AskUserQuestion or ask for clarification — make your best judgment \\\n    31→             and proceed autonomously.\",\n    32→            issue_number = issue.number,\n    33→            title = issue.title,\n    34→            body = issue.body,\n    35→            task_type_label = task_type,\n    36→            phase_instructions = phase_instructions,\n    37→            safety_guards = safety_guards,\n    38→            reasoning_steps = reasoning_steps,\n    39→            base_branch = config.project.base_branch,\n    40→            model = config.sessions.default_model,\n    41→            mode = config.sessions.default_mode,\n    42→        )\n    43→    }\n    44→\n    45→    /// Detect the task type from issue labels.\n    46→    fn detect_task_type(issue: &GhIssue) -> String {\n    47→        for label in &issue.labels {\n    48→            match label.as_str() {\n    49→                \"type:docs\" | \"documentation\" => return \"Documentation\".into(),\n    50→                \"type:refactor\" | \"refactor\" => return \"Refactoring\".into(),\n    51→                \"type:bug\" | \"bug\" => return \"Bug Fix\".into(),\n    52→                \"type:test\" | \"test\" => return \"Testing\".into(),\n    53→                \"type:feature\" | \"enhancement\" => return \"Feature\".into(),\n    54→                \"type:backend\" => return \"Backend\".into(),\n    55→                _ => {}\n    56→            }\n    57→        }\n    58→        \"General\".into()\n    59→    }\n    60→\n    61→    /// Phase-specific instructions based on task type.\n    62→    fn phase_instructions(task_type: &str) -> String {\n    63→        match task_type {\n    64→            \"Documentation\" => \"Focus on documentation quality:\\n\\\n    65→                 - Read existing docs to understand the style and conventions\\n\\\n    66→                 - Update or create documentation files as needed\\n\\\n    67→                 - Ensure code examples are accurate and tested\\n\\\n    68→                 - Do NOT modify source code unless fixing doc comments\"\n    69→                .into(),\n    70→            \"Refactoring\" => \"Focus on preserving existing behavior:\\n\\\n    71→                 - Run tests BEFORE making any changes to establish a baseline\\n\\\n    72→                 - Make incremental changes, running tests after each step\\n\\\n    73→                 - Do NOT change public API signatures unless explicitly requested\\n\\\n    74→                 - Do NOT add new features — only restructure existing code\"\n    75→                .into(),\n    76→            \"Bug Fix\" => \"Follow a reproduce-first approach:\\n\\\n    77→                 - First, understand the bug by reading related code and tests\\n\\\n    78→                 - Write a failing test that reproduces the bug\\n\\\n    79→                 - Fix the bug with the minimum change necessary\\n\\\n    80→                 - Verify the fix by running all tests\\n\\\n    81→                 - Do NOT refactor surrounding code — fix only the bug\"\n    82→                .into(),\n    83→            \"Testing\" => \"Focus on test coverage:\\n\\\n    84→                 - Read the source code to understand the behavior to test\\n\\\n    85→                 - Write tests for edge cases and error conditions\\n\\\n    86→                 - Ensure tests are deterministic and do not depend on external state\\n\\\n    87→                 - Do NOT modify source code — only add or update tests\"\n    88→                .into(),\n    89→            _ => \"Follow standard development practices:\\n\\\n    90→                 - Read and understand the codebase before making changes\\n\\\n    91→                 - Write tests for new functionality\\n\\\n    92→                 - Keep changes focused on the issue scope\"\n    93→                .into(),\n    94→        }\n    95→    }\n    96→\n    97→    /// Safety guards common to all task types.\n    98→    fn safety_guards() -> &'static str {\n    99→        \"- Do NOT delete existing test files\\n\\\n   100→         - Run tests before committing changes\\n\\\n   101→         - Do NOT modify files outside the issue scope\\n\\\n   102→         - Do NOT introduce breaking changes to public APIs without explicit instruction\\n\\\n   103→         - Do NOT add unnecessary dependencies\"\n   104→    }\n   105→\n   106→    /// Structured reasoning steps.\n   107→    fn structured_reasoning() -> &'static str {\n   108→        \"1. Read and understand the relevant codebase sections\\n\\\n   109→         2. Plan your approach — identify which files need changes\\n\\\n   110→         3. Implement changes incrementally\\n\\\n   111→         4. Run tests to verify your changes\\n\\\n   112→         5. Review your changes for correctness and completeness\"\n   113→    }\n   114→}\n   115→\n   116→#[cfg(test)]\n   117→mod tests {\n   118→    use super::*;\n   119→\n   120→    fn make_issue(labels: &[&str]) -> GhIssue {\n   121→        GhIssue {\n   122→            number: 42,\n   123→            title: \"Test issue\".into(),\n   124→            body: \"Fix the thing\".into(),\n   125→            labels: labels.iter().map(|s| s.to_string()).collect(),\n   126→            state: \"open\".into(),\n   127→            html_url: String::new(),\n   128→        }\n   129→    }\n   130→\n   131→    fn make_config() -> Config {\n   132→        toml::from_str(\n   133→            r#\"\n   134→            [project]\n   135→            repo = \"owner/repo\"\n   136→            base_branch = \"main\"\n   137→            [sessions]\n   138→            [budget]\n   139→            [github]\n   140→            [notifications]\n   141→            \"#,\n   142→        )\n   143→        .unwrap()\n   144→    }\n   145→\n   146→    #[test]\n   147→    fn build_issue_prompt_contains_issue_number_and_title() {\n   148→        let issue = make_issue(&[]);\n   149→        let config = make_config();\n   150→        let prompt = PromptBuilder::build_issue_prompt(&issue, &config);\n   151→        assert!(prompt.contains(\"#42\"));\n   152→        assert!(prompt.contains(\"Test issue\"));\n   153→        assert!(prompt.contains(\"Fix the thing\"));\n   154→    }\n   155→\n   156→    #[test]\n   157→    fn build_issue_prompt_contains_safety_guards() {\n   158→        let issue = make_issue(&[]);\n   159→        let config = make_config();\n   160→        let prompt = PromptBuilder::build_issue_prompt(&issue, &config);\n   161→        assert!(prompt.contains(\"Do NOT delete existing test files\"));\n   162→        assert!(prompt.contains(\"Run tests before committing\"));\n   163→    }\n   164→\n   165→    #[test]\n   166→    fn build_issue_prompt_contains_unattended_mode() {\n   167→        let issue = make_issue(&[]);\n   168→        let config = make_config();\n   169→        let prompt = PromptBuilder::build_issue_prompt(&issue, &config);\n   170→        assert!(prompt.contains(\"unattended mode\"));\n   171→    }\n   172→\n   173→    #[test]\n   174→    fn detect_task_type_docs() {\n   175→        let issue = make_issue(&[\"type:docs\"]);\n   176→        assert_eq!(PromptBuilder::detect_task_type(&issue), \"Documentation\");\n   177→    }\n   178→\n   179→    #[test]\n   180→    fn detect_task_type_bug() {\n   181→        let issue = make_issue(&[\"type:bug\"]);\n   182→        assert_eq!(PromptBuilder::detect_task_type(&issue), \"Bug Fix\");\n   183→    }\n   184→\n   185→    #[test]\n   186→    fn detect_task_type_refactor() {\n   187→        let issue = make_issue(&[\"type:refactor\"]);\n   188→        assert_eq!(PromptBuilder::detect_task_type(&issue), \"Refactoring\");\n   189→    }\n   190→\n   191→    #[test]\n   192→    fn detect_task_type_feature() {\n   193→        let issue = make_issue(&[\"type:feature\"]);\n   194→        assert_eq!(PromptBuilder::detect_task_type(&issue), \"Feature\");\n   195→    }\n   196→\n   197→    #[test]\n   198→    fn detect_task_type_default_general() {\n   199→        let issue = make_issue(&[\"priority:P0\"]);\n   200→        assert_eq!(PromptBuilder::detect_task_type(&issue), \"General\");\n   201→    }\n   202→\n   203→    #[test]\n   204→    fn bug_prompt_contains_reproduce_first() {\n   205→        let issue = make_issue(&[\"type:bug\"]);\n   206→        let config = make_config();\n   207→        let prompt = PromptBuilder::build_issue_prompt(&issue, &config);\n   208→        assert!(prompt.contains(\"reproduce-first\"));\n   209→    }\n   210→\n   211→    #[test]\n   212→    fn refactor_prompt_contains_preserve_behavior() {\n   213→        let issue = make_issue(&[\"type:refactor\"]);\n   214→        let config = make_config();\n   215→        let prompt = PromptBuilder::build_issue_prompt(&issue, &config);\n   216→        assert!(prompt.contains(\"preserving existing behavior\"));\n   217→    }\n   218→\n   219→    #[test]\n   220→    fn docs_prompt_contains_documentation_focus() {\n   221→        let issue = make_issue(&[\"type:docs\"]);\n   222→        let config = make_config();\n   223→        let prompt = PromptBuilder::build_issue_prompt(&issue, &config);\n   224→        assert!(prompt.contains(\"documentation quality\"));\n   225→    }\n   226→\n   227→    #[test]\n   228→    fn prompt_contains_base_branch() {\n   229→        let issue = make_issue(&[]);\n   230→        let config = make_config();\n   231→        let prompt = PromptBuilder::build_issue_prompt(&issue, &config);\n   232→        assert!(prompt.contains(\"Base branch: main\"));\n   233→    }\n   234→}\n   235→"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"4941562f-2e3c-4381-8ea0-fc9041f5ef73","timestamp":"2026-03-24T20:20:40.376Z"}
