[2026-03-24T20:20:37.498Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MpMu5CSiMj8hUAaoBwCGNA","type":"tool_result","content":"     1→use super::dependencies::DependencyGraph;\n     2→use super::types::{WorkItem, WorkStatus};\n     3→use std::collections::{HashMap, HashSet};\n     4→\n     5→/// Counts of work items by status.\n     6→pub struct StatusCounts {\n     7→    pub pending: usize,\n     8→    pub in_progress: usize,\n     9→    pub done: usize,\n    10→    pub failed: usize,\n    11→}\n    12→\n    13→/// Manages the work queue: priority ordering, dependency resolution,\n    14→/// and assignment of issues to session slots.\n    15→pub struct WorkAssigner {\n    16→    items: Vec<WorkItem>,\n    17→    completed_issues: HashSet<u64>,\n    18→    /// Topological order index for tiebreaking (lower = earlier in dependency chain).\n    19→    topo_order: HashMap<u64, usize>,\n    20→    /// Cached dependency graph for cascade operations.\n    21→    graph: DependencyGraph,\n    22→}\n    23→\n    24→impl WorkAssigner {\n    25→    /// Create a new WorkAssigner, running cycle detection on the dependency graph.\n    26→    /// Items involved in cycles are immediately marked as Failed.\n    27→    pub fn new(mut items: Vec<WorkItem>) -> Self {\n    28→        let graph = DependencyGraph::build(&items);\n    29→        let topo_order = match graph.topological_sort() {\n    30→            Ok(order) => {\n    31→                let map: HashMap<u64, usize> = order\n    32→                    .into_iter()\n    33→                    .enumerate()\n    34→                    .map(|(idx, num)| (num, idx))\n    35→                    .collect();\n    36→                map\n    37→            }\n    38→            Err(_) => {\n    39→                // Cycle detected — do a partial sort to identify which items are in cycles\n    40→                // Items not in the successful partial order are cycling\n    41→                let partial = Self::partial_topo_sort(&graph, &items);\n    42→                let ordered: HashSet<u64> = partial.keys().copied().collect();\n    43→                for item in &mut items {\n    44→                    if !ordered.contains(&item.number()) {\n    45→                        item.status = WorkStatus::Failed;\n    46→                    }\n    47→                }\n    48→                partial\n    49→            }\n    50→        };\n    51→\n    52→        Self {\n    53→            graph,\n    54→            items,\n    55→            completed_issues: HashSet::new(),\n    56→            topo_order,\n    57→        }\n    58→    }\n    59→\n    60→    /// Get the next batch of ready work items (up to `count`),\n    61→    /// sorted by priority (P0 first), then by topo order, then by issue number.\n    62→    pub fn next_ready(&self, count: usize) -> Vec<&WorkItem> {\n    63→        let mut ready: Vec<&WorkItem> = self\n    64→            .items\n    65→            .iter()\n    66→            .filter(|item| item.is_ready(&self.completed_issues))\n    67→            .collect();\n    68→\n    69→        ready.sort_by(|a, b| {\n    70→            a.priority.cmp(&b.priority).then_with(|| {\n    71→                let a_topo = self\n    72→                    .topo_order\n    73→                    .get(&a.number())\n    74→                    .copied()\n    75→                    .unwrap_or(usize::MAX);\n    76→                let b_topo = self\n    77→                    .topo_order\n    78→                    .get(&b.number())\n    79→                    .copied()\n    80→                    .unwrap_or(usize::MAX);\n    81→                a_topo\n    82→                    .cmp(&b_topo)\n    83→                    .then_with(|| a.number().cmp(&b.number()))\n    84→            })\n    85→        });\n    86→\n    87→        ready.into_iter().take(count).collect()\n    88→    }\n    89→\n    90→    /// Get issues that were detected as part of a dependency cycle (marked Failed at init).\n    91→    pub fn cycling_issues(&self) -> Vec<u64> {\n    92→        let ordered: HashSet<u64> = self.topo_order.keys().copied().collect();\n    93→        self.items\n    94→            .iter()\n    95→            .filter(|i| !ordered.contains(&i.number()) && i.status == WorkStatus::Failed)\n    96→            .map(|i| i.number())\n    97→            .collect()\n    98→    }\n    99→\n   100→    /// Build a partial topological order, skipping cycle nodes.\n   101→    fn partial_topo_sort(graph: &DependencyGraph, items: &[WorkItem]) -> HashMap<u64, usize> {\n   102→        // Try ordering each item independently — items reachable from roots get ordered\n   103→        let mut in_degree: HashMap<u64, usize> = HashMap::new();\n   104→        let all_nums: HashSet<u64> = items.iter().map(|i| i.number()).collect();\n   105→\n   106→        for item in items {\n   107→            in_degree.entry(item.number()).or_insert(0);\n   108→            let dep_count = item\n   109→                .blocked_by\n   110→                .iter()\n   111→                .filter(|b| all_nums.contains(b))\n   112→                .count();\n   113→            *in_degree.entry(item.number()).or_insert(0) = dep_count;\n   114→        }\n   115→\n   116→        let mut queue: std::collections::VecDeque<u64> = in_degree\n   117→            .iter()\n   118→            .filter(|(_, deg)| **deg == 0)\n   119→            .map(|(&n, _)| n)\n   120→            .collect();\n   121→\n   122→        let mut result = HashMap::new();\n   123→        let mut idx = 0;\n   124→\n   125→        while let Some(node) = queue.pop_front() {\n   126→            result.insert(node, idx);\n   127→            idx += 1;\n   128→            for dep in graph.dependents_of(node) {\n   129→                if let Some(deg) = in_degree.get_mut(&dep) {\n   130→                    *deg = deg.saturating_sub(1);\n   131→                    if *deg == 0 {\n   132→                        queue.push_back(dep);\n   133→                    }\n   134→                }\n   135→            }\n   136→        }\n   137→\n   138→        result\n   139→    }\n   140→\n   141→    /// Mark an issue as in-progress.\n   142→    pub fn mark_in_progress(&mut self, issue_number: u64) {\n   143→        if let Some(item) = self.items.iter_mut().find(|i| i.number() == issue_number) {\n   144→            item.status = WorkStatus::InProgress;\n   145→        }\n   146→    }\n   147→\n   148→    /// Mark an issue as completed. Returns newly unblocked work items.\n   149→    pub fn mark_done(&mut self, issue_number: u64) -> Vec<&WorkItem> {\n   150→        self.completed_issues.insert(issue_number);\n   151→        if let Some(item) = self.items.iter_mut().find(|i| i.number() == issue_number) {\n   152→            item.status = WorkStatus::Done;\n   153→        }\n   154→        self.get_newly_unblocked()\n   155→    }\n   156→\n   157→    /// Mark an issue as failed.\n   158→    pub fn mark_failed(&mut self, issue_number: u64) {\n   159→        if let Some(item) = self.items.iter_mut().find(|i| i.number() == issue_number) {\n   160→            item.status = WorkStatus::Failed;\n   161→        }\n   162→    }\n   163→\n   164→    /// Mark an issue as failed AND cascade failure to all transitive dependents.\n   165→    /// Returns the list of issue numbers that were cascade-failed.\n   166→    pub fn mark_failed_cascade(&mut self, issue_number: u64) -> Vec<u64> {\n   167→        self.mark_failed(issue_number);\n   168→\n   169→        // BFS to find all transitive dependents using cached graph\n   170→        let mut visited: HashSet<u64> = HashSet::new();\n   171→        let mut queue = std::collections::VecDeque::new();\n   172→        queue.push_back(issue_number);\n   173→\n   174→        while let Some(current) = queue.pop_front() {\n   175→            for dep in self.graph.dependents_of(current) {\n   176→                if dep != issue_number && visited.insert(dep) {\n   177→                    queue.push_back(dep);\n   178→                }\n   179→            }\n   180→        }\n   181→\n   182→        // Mark all transitive dependents as failed\n   183→        for &num in &visited {\n   184→            if let Some(item) = self.items.iter_mut().find(|i| i.number() == num)\n   185→                && !matches!(item.status, WorkStatus::Done | WorkStatus::Failed)\n   186→            {\n   187→                item.status = WorkStatus::Failed;\n   188→            }\n   189→        }\n   190→\n   191→        visited.into_iter().collect()\n   192→    }\n   193→\n   194→    /// Get all work items for display.\n   195→    pub fn all_items(&self) -> &[WorkItem] {\n   196→        &self.items\n   197→    }\n   198→\n   199→    /// Count of items by status.\n   200→    pub fn count_by_status(&self) -> StatusCounts {\n   201→        let mut counts = StatusCounts {\n   202→            pending: 0,\n   203→            in_progress: 0,\n   204→            done: 0,\n   205→            failed: 0,\n   206→        };\n   207→        for item in &self.items {\n   208→            match item.status {\n   209→                WorkStatus::Pending | WorkStatus::Blocked => counts.pending += 1,\n   210→                WorkStatus::InProgress => counts.in_progress += 1,\n   211→                WorkStatus::Done => counts.done += 1,\n   212→                WorkStatus::Failed => counts.failed += 1,\n   213→            }\n   214→        }\n   215→        counts\n   216→    }\n   217→\n   218→    /// Total items in the assigner.\n   219→    pub fn total(&self) -> usize {\n   220→        self.items.len()\n   221→    }\n   222→\n   223→    /// Check if all items are in terminal states (Done or Failed).\n   224→    pub fn all_terminal(&self) -> bool {\n   225→        self.items\n   226→            .iter()\n   227→            .all(|i| matches!(i.status, WorkStatus::Done | WorkStatus::Failed))\n   228→    }\n   229→\n   230→    /// Find items that just became ready after a completion.\n   231→    fn get_newly_unblocked(&self) -> Vec<&WorkItem> {\n   232→        self.items\n   233→            .iter()\n   234→            .filter(|item| item.is_ready(&self.completed_issues))\n   235→            .collect()\n   236→    }\n   237→}\n   238→\n   239→#[cfg(test)]\n   240→mod tests {\n   241→    use super::*;\n   242→    use crate::github::types::{GhIssue, Priority};\n   243→\n   244→    fn make_item(number: u64, priority: Priority, blocked_by: &[u64]) -> WorkItem {\n   245→        let mut labels: Vec<String> = blocked_by\n   246→            .iter()\n   247→            .map(|b| format!(\"blocked-by:#{}\", b))\n   248→            .collect();\n   249→        // Encode priority as a label\n   250→        labels.push(format!(\"priority:{:?}\", priority));"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"84cc3b70-306b-4704-8197-493fb9969dbb","timestamp":"2026-03-24T20:20:37.451Z"}
