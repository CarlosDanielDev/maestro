[2026-03-24T20:20:33.580Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016S5hkFnv3FmF1xqJPY7Dnp","type":"tool_result","content":"     1→pub mod activity_log;\n     2→pub mod app;\n     3→pub mod dep_graph;\n     4→pub mod detail;\n     5→pub mod panels;\n     6→pub mod ui;\n     7→\n     8→use app::App;\n     9→use crossterm::{\n    10→    event::{self, Event, KeyCode, KeyModifiers},\n    11→    execute,\n    12→    terminal::{EnterAlternateScreen, LeaveAlternateScreen, disable_raw_mode, enable_raw_mode},\n    13→};\n    14→use ratatui::{Terminal, backend::CrosstermBackend};\n    15→use std::io;\n    16→use std::time::Duration;\n    17→\n    18→/// Run the TUI event loop.\n    19→pub async fn run(mut app: App) -> anyhow::Result<()> {\n    20→    // Setup terminal\n    21→    enable_raw_mode()?;\n    22→    let mut stdout = io::stdout();\n    23→    execute!(stdout, EnterAlternateScreen)?;\n    24→    let backend = CrosstermBackend::new(stdout);\n    25→    let mut terminal = Terminal::new(backend)?;\n    26→\n    27→    let result = event_loop(&mut terminal, &mut app).await;\n    28→\n    29→    // Restore terminal\n    30→    disable_raw_mode()?;\n    31→    execute!(terminal.backend_mut(), LeaveAlternateScreen)?;\n    32→    terminal.show_cursor()?;\n    33→\n    34→    // Cleanup: kill any remaining sessions\n    35→    app.kill_all().await;\n    36→\n    37→    // Save final state (ensures state is persisted on exit/crash)\n    38→    app.state.sessions = app.pool.all_sessions().into_iter().cloned().collect();\n    39→    app.state.update_total_cost();\n    40→    app.state.last_updated = Some(chrono::Utc::now());\n    41→    if let Err(e) = app.store.save(&app.state) {\n    42→        eprintln!(\"Warning: failed to save state: {}\", e);\n    43→    }\n    44→\n    45→    // Print session summary to stdout after TUI exits\n    46→    print_summary(&app);\n    47→\n    48→    result\n    49→}\n    50→\n    51→async fn event_loop(\n    52→    terminal: &mut Terminal<CrosstermBackend<io::Stdout>>,\n    53→    app: &mut App,\n    54→) -> anyhow::Result<()> {\n    55→    loop {\n    56→        // Draw\n    57→        terminal.draw(|f| ui::draw(f, app))?;\n    58→\n    59→        // Process session events (non-blocking drain)\n    60→        while let Ok(evt) = app.event_rx.try_recv() {\n    61→            app.handle_session_event(evt);\n    62→        }\n    63→\n    64→        // Check for completed sessions and promote queued ones\n    65→        app.check_completions().await?;\n    66→\n    67→        // Check for keyboard input (with timeout for responsive updates)\n    68→        if event::poll(Duration::from_millis(50))?\n    69→            && let Event::Key(key) = event::read()?\n    70→        {\n    71→            match (key.code, key.modifiers) {\n    72→                (KeyCode::Char('q'), _) | (KeyCode::Char('c'), KeyModifiers::CONTROL) => {\n    73→                    app.running = false;\n    74→                    return Ok(());\n    75→                }\n    76→                #[cfg(unix)]\n    77→                (KeyCode::Char('p'), _) => {\n    78→                    app.pause_all();\n    79→                }\n    80→                #[cfg(unix)]\n    81→                (KeyCode::Char('r'), _) => {\n    82→                    app.resume_all();\n    83→                }\n    84→                (KeyCode::Char('k'), _) => {\n    85→                    app.kill_all().await;\n    86→                }\n    87→                // Tab cycles TUI modes: Overview -> DependencyGraph -> Overview\n    88→                (KeyCode::Tab, _) => {\n    89→                    app.tui_mode = match app.tui_mode {\n    90→                        app::TuiMode::Overview => app::TuiMode::DependencyGraph,\n    91→                        app::TuiMode::DependencyGraph => app::TuiMode::Overview,\n    92→                        app::TuiMode::Detail(_) => app::TuiMode::Overview,\n    93→                    };\n    94→                }\n    95→                // Esc returns to overview from any mode\n    96→                (KeyCode::Esc, _) => {\n    97→                    app.tui_mode = app::TuiMode::Overview;\n    98→                }\n    99→                // Enter opens detail view for selected session\n   100→                (KeyCode::Enter, _) => {\n   101→                    let selected = app.panel_view.selected_index();\n   102→                    app.tui_mode = app::TuiMode::Detail(selected);\n   103→                }\n   104→                // 1-9 jump to session detail by index\n   105→                (KeyCode::Char(c), _) if c.is_ascii_digit() && c != '0' => {\n   106→                    let idx = (c as usize) - ('1' as usize);\n   107→                    if idx < app.pool.all_sessions().len() {\n   108→                        app.tui_mode = app::TuiMode::Detail(idx);\n   109→                    }\n   110→                }\n   111→                // Dismiss notification\n   112→                (KeyCode::Char('d'), _) => {\n   113→                    app.notifications.dismiss_latest();\n   114→                }\n   115→                // Scroll activity log (Shift+arrows)\n   116→                (KeyCode::Up, KeyModifiers::SHIFT) => {\n   117→                    app.activity_log.scroll_down();\n   118→                }\n   119→                (KeyCode::Down, KeyModifiers::SHIFT) => {\n   120→                    app.activity_log.scroll_up();\n   121→                }\n   122→                // Scroll agent panel output (plain arrows)\n   123→                (KeyCode::Up, _) => {\n   124→                    app.panel_view.scroll_up();\n   125→                }\n   126→                (KeyCode::Down, _) => {\n   127→                    app.panel_view.scroll_down();\n   128→                }\n   129→                _ => {}\n   130→            }\n   131→        }\n   132→\n   133→        // Auto-exit when all sessions complete\n   134→        if app.all_done() {\n   135→            // Draw final state, then wait for quit key or timeout\n   136→            terminal.draw(|f| ui::draw(f, app))?;\n   137→\n   138→            let deadline = tokio::time::Instant::now() + Duration::from_secs(30);\n   139→            loop {\n   140→                let remaining = deadline - tokio::time::Instant::now();\n   141→                if remaining.is_zero() {\n   142→                    break;\n   143→                }\n   144→                if event::poll(remaining.min(Duration::from_millis(100)))?\n   145→                    && let Event::Key(key) = event::read()?\n   146→                {\n   147→                    match key.code {\n   148→                        // Only these keys exit\n   149→                        KeyCode::Char('q') | KeyCode::Esc | KeyCode::Enter => break,\n   150→                        // Arrows scroll the agent panel output\n   151→                        KeyCode::Up => app.panel_view.scroll_up(),\n   152→                        KeyCode::Down => app.panel_view.scroll_down(),\n   153→                        _ => {}\n   154→                    }\n   155→                    // Redraw after scroll\n   156→                    terminal.draw(|f| ui::draw(f, app))?;\n   157→                }\n   158→            }\n   159→            return Ok(());\n   160→        }\n   161→    }\n   162→}\n   163→\n   164→/// Print a summary of all sessions to stdout after the TUI exits.\n   165→fn print_summary(app: &App) {\n   166→    let sessions = app.pool.all_sessions();\n   167→    if sessions.is_empty() {\n   168→        return;\n   169→    }\n   170→\n   171→    println!();\n   172→    println!(\"=== Maestro Session Summary ===\");\n   173→    println!();\n   174→\n   175→    for session in &sessions {\n   176→        let label = match session.issue_number {\n   177→            Some(n) => format!(\"#{}\", n),\n   178→            None => session.id.to_string()[..8].to_string(),\n   179→        };\n   180→        println!(\n   181→            \"  {} {} {} ${:.2} {}\",\n   182→            session.status.symbol(),\n   183→            label,\n   184→            session.status.label(),\n   185→            session.cost_usd,\n   186→            session.elapsed_display(),\n   187→        );\n   188→\n   189→        if !session.last_message.is_empty() {\n   190→            println!(\"    Last: {}\", session.last_message);\n   191→        }\n   192→        if !session.files_touched.is_empty() {\n   193→            println!(\"    Files: {}\", session.files_touched.join(\", \"));\n   194→        }\n   195→        // Show recent activity log entries for errored sessions\n   196→        if session.status == crate::session::types::SessionStatus::Errored {\n   197→            for entry in session\n   198→                .activity_log\n   199→                .iter()\n   200→                .rev()\n   201→                .take(3)\n   202→                .collect::<Vec<_>>()\n   203→                .into_iter()\n   204→                .rev()\n   205→            {\n   206→                println!(\"    > {}\", entry.message);\n   207→            }\n   208→        }\n   209→    }\n   210→\n   211→    println!();\n   212→    println!(\n   213→        \"Total cost: ${:.2}\",\n   214→        sessions.iter().map(|s| s.cost_usd).sum::<f64>()\n   215→    );\n   216→    println!();\n   217→}\n   218→"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"25bb9283-bd01-40b1-987b-bc35af4b05db","timestamp":"2026-03-24T20:20:33.328Z"}
