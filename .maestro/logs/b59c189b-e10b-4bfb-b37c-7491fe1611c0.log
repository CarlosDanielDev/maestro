rash\n    62→        #[arg(long)]\n    63→        resume: bool,\n    64→    },\n    65→    /// Show queued/pending issues from GitHub\n    66→    Queue,\n    67→    /// Add an issue to the work queue manually\n    68→    Add {\n    69→        /// Issue number to add\n    70→        issue_number: u64,\n    71→    },\n    72→    /// Show current state without TUI\n    73→    Status,\n    74→    /// Show spending report\n    75→    Cost,\n    76→    /// Initialize maestro.toml in current directory\n    77→    Init,\n    78→    /// Clean orphaned worktrees left by crashed sessions\n    79→    Clean {\n    80→        /// Show what would be cleaned without actually doing it\n    81→        #[arg(long)]\n    82→        dry_run: bool,\n    83→    },\n    84→    /// Show session transcript logs\n    85→    Logs {\n    86→        /// Show full log for a specific session ID\n    87→        #[arg(long)]\n    88→        session: Option<String>,\n    89→        /// Export as JSON\n    90→        #[arg(long)]\n    91→        export: Option<String>,\n    92→    },\n    93→}\n    94→\n    95→#[tokio::main]\n    96→async fn main() -> anyhow::Result<()> {\n    97→    // Init logging (to file, not terminal — TUI owns stdout)\n    98→    tracing_subscriber::fmt()\n    99→        .with_env_filter(\"maestro=debug\")\n   100→        .with_writer(|| {\n   101→            std::fs::OpenOptions::new()\n   102→                .create(true)\n   103→                .append(true)\n   104→                .open(\"maestro.log\")\n   105→                .unwrap_or_else(|_| {\n   106→                    std::fs::OpenOptions::new()\n   107→                        .write(true)\n   108→                        .open(\"/dev/null\")\n   109→                        .unwrap()\n   110→                })\n   111→        })\n   112→        .init();\n   113→\n   114→    let cli = Cli::parse();\n   115→\n   116→    match cli.command {\n   117→        Some(Commands::Init) => cmd_init(),\n   118→        Some(Commands::Clean { dry_run }) => cmd_clean(dry_run),\n   119→        Some(Commands::Logs { session, export }) => cmd_logs(session, export),\n   120→        Some(Commands::Status) => cmd_status(),\n   121→        Some(Commands::Cost) => cmd_cost(),\n   122→        Some(Commands::Queue) => cmd_queue().await,\n   123→        Some(Commands::Add { issue_number }) => cmd_add(issue_number).await,\n   124→        Some(Commands::Run {\n   125→            prompt,\n   126→            issue,\n   127→            milestone,\n   128→            model,\n   129→            max_concurrent,\n   130→            resume,\n   131→        }) => cmd_run(prompt, issue, milestone, model, max_concurrent, resume).await,\n   132→        // Default: launch TUI with no sessions (dashboard mode)\n   133→        None => cmd_dashboard().await,\n   134→    }\n   135→}\n   136→\n   137→fn cmd_init() -> anyhow::Result<()> {\n   138→    let path = std::path::PathBuf::from(\"maestro.toml\");\n   139→    if path.exists() {\n   140→        println!(\"maestro.toml already exists.\");\n   141→        return Ok(());\n   142→    }\n   143→\n   144→    let content = r#\"[project]\n   145→repo = \"\"\n   146→base_branch = \"main\"\n   147→\n   148→[sessions]\n   149→max_concurrent = 3\n   150→stall_timeout_secs = 300\n   151→default_model = \"opus\"\n   152→default_mode = \"orchestrator\"\n   153→permission_mode = \"bypassPermissions\"  # Options: default, acceptEdits, bypassPermissions, dontAsk, plan, auto\n   154→allowed_tools = []                      # Empty = all tools. Example: [\"Bash\", \"Read\", \"Write\", \"Edit\"]\n   155→\n   156→[budget]\n   157→per_session_usd = 5.0\n   158→total_usd = 50.0\n   159→alert_threshold_pct = 80\n   160→\n   161→[github]\n   162→issue_filter_labels = [\"maestro:ready\"]\n   163→auto_pr = true\n   164→auto_merge = false                      # Set to true to auto-merge PRs after CI + review pass\n   165→merge_method = \"squash\"                 # Options: merge, squash, rebase\n   166→cache_ttl_secs = 300\n   167→\n   168→[gates]\n   169→enabled = true\n   170→test_command = \"cargo test\"\n   171→ci_poll_interval_secs = 30\n   172→ci_max_wait_secs = 1800\n   173→\n   174→[notifications]\n   175→desktop = true\n   176→slack = false\n   177→\n   178→[review]\n   179→enabled = false\n   180→command = \"gh pr review {pr_number} --comment --body 'Automated review by Maestro'\"\n   181→# reviewers = [\n   182→#   { name = \"claude\", command = \"claude --print 'review PR #{pr_number}'\", required = true },\n   183→#   { name = \"codex\", command = \"codex review {pr_number}\", required = false },\n   184→# ]\n   185→\n   186→[concurrency]\n   187→heavy_task_labels = []                  # Labels that mark a task as resource-intensive\n   188→heavy_task_limit = 2                    # Max concurrent heavy tasks\n   189→\n   190→[monitoring]\n   191→work_tick_interval_secs = 10\n   192→\"#;\n   193→\n   194→    std::fs::write(&path, content)?;\n   195→    println!(\"Created maestro.toml\");\n   196→    Ok(())\n   197→}\n   198→\n   199→fn cmd_status() -> anyhow::Result<()> {\n   200→    let store = StateStore::new(StateStore::default_path());\n   201→    let state = store.load()?;\n   202→\n   203→    if state.sessions.is_empty() {\n   204→        println!(\"No sessions recorded.\");\n   205→        return Ok(());\n   206→    }\n   207→\n   208→    println!(\n   209→        \"Sessions: {} total, {} active\",\n   210→        state.sessions.len(),\n   211→        state.active_sessions().len()\n   212→    );\n   213→    println!(\"Total cost: ${:.2}\", state.total_cost_usd);\n   214→    println!();\n   215→\n   216→    for session in &state.sessions {\n   217→        let label = match session.issue_number {\n   218→            Some(n) => format!(\"#{}\", n),\n   219→            None => session.id.to_string()[..8].to_string(),\n   220→        };\n   221→        println!(\n   222→            \"  {} {} {} ${:.2} {}\",\n   223→            session.status.symbol(),\n   224→            label,\n   225→            session.status.label(),\n   226→            session.cost_usd,\n   227→            session.elapsed_display(),\n   228→        );\n   229→    }\n   230→\n   231→    Ok(())\n   232→}\n   233→\n   234→fn cmd_cost() -> anyhow::Result<()> {\n   235→    let store = StateStore::new(StateStore::default_path());\n   236→    let state = store.load()?;\n   237→\n   238→    println!(\"=== Maestro Spending Report ===\");\n   239→    println!(\"Total: ${:.2}\", state.total_cost_usd);\n   240→    println!();\n   241→\n   242→    for session in &state.sessions {\n   243→        let label = match session.issue_number {\n   244→            Some(n) => format!(\"#{:<6}\", n),\n   245→            None => session.id.to_string()[..8].to_string(),\n   246→        };\n   247→        println!(\n   248→            \"  {} ${:.2} ({})\",\n   249→            label,\n   250→            session.cost_usd,\n   251→            session.status.label(),\n   252→        );\n   253→    }\n   254→\n   255→    Ok(())\n   256→}\n   257→\n   258→async fn cmd_queue() -> anyhow::Result<()> {\n   259→    let config = Config::find_and_load()?;\n   260→    let client = GhCliClient::new();\n   261→    let label_refs: Vec<&str> = config\n   262→        .github\n   263→        .issue_filter_labels\n   264→        .iter()\n   265→        .map(|s| s.as_str())\n   266→        .collect();\n   267→    let issues = client.list_issues(&label_refs).await?;\n   268→\n   269→    if issues.is_empty() {\n   270→        println!(\n   271→            \"No issues found with labels: {:?}\",\n   272→            config.github.issue_filter_labels\n   273→        );\n   274→        return Ok(());\n   275→    }\n   276→\n   277→    let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n   278→    let assigner = WorkAssigner::new(items);\n   279→\n   280→    println!(\n   281→        \"{:<10} {:<8} {:<50} {:<10} {:<15}\",\n   282→        \"Priority\", \"Issue\", \"Title\", \"Status\", \"Blocked By\"\n   283→    );\n   284→    println!(\"{}\", \"-\".repeat(93));\n   285→\n   286→    for item in assigner.all_items() {\n   287→        let blocked_str = if item.blocked_by.is_empty() {\n   288→            \"-\".to_string()\n   289→        } else {\n   290→            item.blocked_by\n   291→                .iter()\n   292→                .map(|n| format!(\"#{}\", n))\n   293→                .collect::<Vec<_>>()\n   294→                .join(\", \")\n   295→        };\n   296→        let title: String = if item.title().chars().count() > 48 {\n   297→            let truncated: String = item.title().chars().take(45).collect();\n   298→            format!(\"{}...\", truncated)\n   299→        } else {\n   300→            item.title().to_string()\n   301→        };\n   302→        let no_completed = std::collections::HashSet::new();\n   303→        let ready_str = if item.is_ready(&no_completed) {\n   304→            \"Ready\"\n   305→        } else {\n   306→            \"Blocked\"\n   307→        };\n   308→        println!(\n   309→            \"{:<10} #{:<7} {:<50} {:<10} {}\",\n   310→            format!(\"{:?}\", item.priority),\n   311→            item.number(),\n   312→            title,\n   313→            ready_str,\n   314→            blocked_str\n   315→        );\n   316→    }\n   317→\n   318→    let counts = assigner.count_by_status();\n   319→    println!(\n   320→        \"\\nTotal: {} issues ({} ready, {} blocked)\",\n   321→        assigner.total(),\n   322→        counts.pending,\n   323→        assigner.total() - counts.pending\n   324→    );\n   325→\n   326→    Ok(())\n   327→}\n   328→\n   329→async fn cmd_add(issue_number: u64) -> anyhow::Result<()> {\n   330→    let client = GhCliClient::new();\n   331→    // Add the maestro:ready label to the issue\n   332→    client.add_label(issue_number, \"maestro:ready\").await?;\n   333→    println!(\"Added 'maestro:ready' label to issue #{}\", issue_number);\n   334→    Ok(())\n   335→}\n   336→\n   337→fn cmd_logs(session: Option<String>, export: Option<String>) -> anyhow::Result<()> {\n   338→    let logger = session::logger::SessionLogger::new(session::logger::SessionLogger::default_dir());\n   339→\n   340→    if let Some(session_id_str) = session {\n   341→        let session_id: uuid::Uuid = session_id_str\n   342→            .parse()\n   343→            .map_err(|_| anyhow::anyhow!(\"Invalid session ID: {}\", session_id_str))?;\n   344→        let content = logger.read_log(session_id)?;\n   345→\n   346→        if export.as_deref() == Some(\"json\") {\n   347→            let lines: Vec<&str> = content.lines().collect();\n   348→            let json = serde_json::json!({\n   349→                \"session_id\": session_id_str,\n   350→                \"lines\": lines,\n   351→            });\n   352→            println!(\"{}\", serde_json::to_string_pretty(&json)?);\n   353→        } else {\n   354→            println!(\"{}\", content);\n   355→        }\n   356→    } else {\n   357→        let logs = logger.list_logs()?;\n   358→        if logs.is_empty() {\n   359→            println!(\"No session logs found.\");\n   360→            return Ok(());\n   361→        }\n   362→\n   363→        if export.as_deref() == Some(\"json\") {\n   364→            let entries: Vec<serde_json::Value> = logs\n   365→                .iter()\n   366→                .map(|l| {\n   367→                    serde_json::json!({\n   368→                        \"session_id\": l.session_id,\n   369→                        \"size_bytes\": l.size_bytes,\n   370→                        \"path\": l.path.display().to_string(),\n   371→                    })\n   372→                })\n   373→                .collect();\n   374→            println!(\"{}\", serde_json::to_string_pretty(&entries)?);\n   375→        } else {\n   376→            println!(\"{:<40} {:>10}\", \"Session ID\", \"Size\");\n   377→            println!(\"{}\", \"-\".repeat(52));\n   378→            for log in &logs {\n   379→                println!(\n   380→                    \"{:<40} {:>10}\",\n   381→                    log.session_id,\n   382→                    format_bytes(log.size_bytes)\n   383→                );\n   384→            }\n   385→            println!(\"\\n{} log(s) found.\", logs.len());\n   386→        }\n   387→    }\n   388→    Ok(())\n   389→}\n   390→\n   391→fn format_bytes(bytes: u64) -> String {\n   392→    if bytes < 1024 {\n   393→        format!(\"{}B\", bytes)\n   394→    } else if bytes < 1024 * 1024 {\n   395→        format!(\"{:.1}KB\", bytes as f64 / 1024.0)\n   396→    } else {\n   397→        format!(\"{:.1}MB\", bytes as f64 / (1024.0 * 1024.0))\n   398→    }\n   399→}\n   400→\n   401→fn cmd_clean(dry_run: bool) -> anyhow::Result<()> {\n   402→    let repo_root = std::env::current_dir()?;\n   403→    let mgr = session::cleanup::CleanupManager::new(&repo_root);\n   404→    let orphans = mgr.scan_orphans()?;\n   405→\n   406→    if orphans.is_empty() {\n   407→        println!(\"No orphaned worktrees found.\");\n   408→        return Ok(());\n   409→    }\n   410→\n   411→    println!(\"Found {} orphaned worktree(s):\", orphans.len());\n   412→    for orphan in &orphans {\n   413→        println!(\"  {} ({})\", orphan.name, orphan.path.display());\n   414→    }\n   415→\n   416→    if dry_run {\n   417→        println!(\"\\nDry run — no changes made.\");\n   418→    } else {\n   419→        let removed = mgr.remove_orphans(&orphans)?;\n   420→        println!(\"\\nRemoved {} worktree(s).\", removed);\n   421→    }\n   422→\n   423→    Ok(())\n   424→}\n   425→\n   426→async fn cmd_run(\n   427→    prompt: Option<String>,\n   428→    issue: Option<String>,\n   429→    milestone: Option<String>,\n   430→    model: Option<String>,\n   431→    max_concurrent_override: Option<usize>,\n   432→    resume: bool,\n   433→) -> anyhow::Result<()> {\n   434→    let config = Config::find_and_load()?;\n   435→    let model = model.unwrap_or(config.sessions.default_model.clone());\n   436→    let max_concurrent = max_concurrent_override.unwrap_or(config.sessions.max_concurrent);\n   437→\n   438→    let store = StateStore::new(StateStore::default_path());\n   439→    let repo_root = std::env::current_dir()?;\n   440→\n   441→    // Startup cleanup: remove orphaned worktrees (non-blocking)\n   442→    {\n   443→        let cleanup_mgr = session::cleanup::CleanupManager::new(&repo_root);\n   444→        if let Ok(orphans) = cleanup_mgr.scan_orphans()\n   445→            && !orphans.is_empty()\n   446→        {\n   447→            tracing::info!(\"Cleaning {} orphaned worktrees on startup\", orphans.len());\n   448→            let _ = cleanup_mgr.remove_orphans(&orphans);\n   449→        }\n   450→    }\n   451→\n   452→    // Startup log cleanup: remove logs older than 30 days\n   453→    {\n   454→        let logger =\n   455→            session::logger::SessionLogger::new(session::logger::SessionLogger::default_dir());\n   456→        if let Ok(removed) = logger.cleanup_old_logs(30)\n   457→            && removed > 0\n   458→        {\n   459→            tracing::info!(\"Cleaned {} old session logs\", removed);\n   460→        }\n   461→    }\n   462→    let worktree_mgr = Box::new(GitWorktreeManager::new(repo_root));\n   463→\n   464→    let mut app = App::new(\n   465→        store,\n   466→        max_concurrent,\n   467→        worktree_mgr,\n   468→        config.sessions.permission_mode.clone(),\n   469→        config.sessions.allowed_tools.clone(),\n   470→    );\n   471→\n   472→    // Wire up budget enforcer from config\n   473→    app.budget_enforcer = Some(crate::budget::BudgetEnforcer::new(\n   474→        config.budget.per_session_usd,\n   475→        config.budget.total_usd,\n   476→        config.budget.alert_threshold_pct,\n   477→    ));\n   478→\n   479→    // Wire up model router from config\n   480→    app.model_router = Some(crate::models::ModelRouter::new(\n   481→        config.models.routing.clone(),\n   482→        config.sessions.default_model.clone(),\n   483→    ));\n   484→\n   485→    // Wire up notification dispatcher from config\n   486→    app.notifications =\n   487→        crate::notifications::dispatcher::NotificationDispatcher::new(config.notifications.desktop);\n   488→\n   489→    // Resume from previous state if requested\n   490→    if resume {\n   491→        let mut recovered = 0;\n   492→        for session in &mut app.state.sessions {\n   493→            if matches!(\n   494→                session.status,\n   495→                session::types::SessionStatus::Running | session::types::SessionStatus::Spawning\n   496→            ) {\n   497→                session.status = session::types::SessionStatus::Errored;\n   498→                recovered += 1;\n   499→            }\n   500→        }\n   501→        if recovered > 0 {\n   502→            tracing::info!(\n   503→                \"Resume: marked {} incomplete sessions as errored (retry will pick them up)\",\n   504→                recovered\n   505→            );\n   506→        }\n   507→    }\n   508→\n   509→    // Determine what to run\n   510→    if let Some(prompt_text) = prompt {\n   511→        let session = Session::new(\n   512→            prompt_text,\n   513→            model,\n   514→            config.sessions.default_mode.clone(),\n   515→            None,\n   516→        );\n   517→        app.add_session(session).await?;\n   518→    } else if let Some(milestone_name) = milestone {\n   519→        // Fetch all issues in the milestone\n   520→        let client = GhCliClient::new();\n   521→        let issues = client.list_issues_by_milestone(&milestone_name).await?;\n   522→        if issues.is_empty() {\n   523→            anyhow::bail!(\"No open issues found in milestone '{}'\", milestone_name);\n   524→        }\n   525→\n   526→        let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n   527→        let assigner = WorkAssigner::new(items);\n   528→\n   529→        // Store assigner and config in app for work management\n   530→        app.work_assigner = Some(assigner);\n   531→        app.github_client = Some(Box::new(client));\n   532→        app.config = Some(config.clone());\n   533→    } else if let Some(issue_str) = issue {\n   534→        let client = GhCliClient::new();\n   535→\n   536→        // Parse comma-separated issue numbers and fetch full issue data\n   537→        for num_str in issue_str.split(',') {\n   538→            let num: u64 = num_str\n   539→                .trim()\n   540→                .parse()\n   541→                .map_err(|_| anyhow::anyhow!(\"Invalid issue number: {}\", num_str.trim()))?;\n   542→\n   543→            let gh_issue = client.get_issue(num).await?;\n   544→            let mut session = Session::new(\n   545→                gh_issue.unattended_prompt(),\n   546→                model.clone(),\n   547→                config.sessions.default_mode.clone(),\n   548→                Some(num),\n   549→            );\n   550→            session.issue_title = Some(gh_issue.title.clone());\n   551→\n   552→            // Cache issue data\n   553→            app.state.issue_cache.insert(num, gh_issue);\n   554→\n   555→            app.add_session(session).await?;\n   556→        }\n   557→\n   558→        // Set github client + config so label lifecycle and auto-PR work\n   559→        app.github_client = Some(Box::new(client));\n   560→        app.config = Some(config.clone());\n   561→    } else {\n   562→        // No prompt, issue, or milestone — auto-fetch maestro:ready issues\n   563→        let client = GhCliClient::new();\n   564→        let label_refs: Vec<&str> = config\n   565→            .github\n   566→            .issue_filter_labels\n   567→            .iter()\n   568→            .map(|s| s.as_str())\n   569→            .collect();\n   570→        let issues = client.list_issues(&label_refs).await?;\n   571→\n   572→        if issues.is_empty() {\n   573→            anyhow::bail!(\n   574→                \"No issues found with labels {:?}. Use --prompt or --issue instead.\",\n   575→                config.github.issue_filter_labels\n   576→            );\n   577→        }\n   578→\n   579→        let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n   580→        let assigner = WorkAssigner::new(items);\n   581→\n   582→        app.work_assigner = Some(assigner);\n   583→        app.github_client = Some(Box::new(client));\n   584→        app.config = Some(config.clone());\n   585→    }\n   586→\n   587→    // Launch TUI\n   588→    tui::run(app).await\n   589→}\n   590→\n   591→async fn cmd_dashboard() -> anyhow::Result<()> {\n   592→    let store = StateStore::new(StateStore::default_path());\n   593→    let repo_root = std::env::current_dir()?;\n   594→    let worktree_mgr = Box::new(GitWorktreeManager::new(repo_root));\n   595→    let app = App::new(\n   596→        store,\n   597→        3,\n   598→        worktree_mgr,\n   599→        \"bypassPermissions\".into(),\n   600→        Vec::new(),\n   601→    );\n   602→    tui::run(app).await\n   603→}\n   604→"}]},"parent_tool_use_id":null,"session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"816a7917-c9ad-4a55-bddc-c9d26b9cb47f","timestamp":"2026-03-24T20:21:24.345Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/carlos/projects/maestro/.maestro/worktrees/issue-5/src/main.rs","content":"mod budget;\nmod config;\nmod gates;\nmod git;\nmod github;\nmod models;\nmod notifications;\nmod prompts;\nmod review;\nmod session;\nmod state;\nmod tui;\nmod util;\nmod work;\n\nuse clap::{Parser, Subcommand};\nuse config::Config;\nuse github::client::{GhCliClient, GitHubClient};\nuse session::types::Session;\nuse session::worktree::GitWorktreeManager;\nuse state::store::StateStore;\nuse tui::app::App;\nuse work::assigner::WorkAssigner;\nuse work::types::WorkItem;\n\n#[derive(Parser)]\n#[command(\n    name = \"maestro\",\n    version,\n    about = \"Multi-session Claude Code orchestrator\"\n)]\nstruct Cli {\n    #[command(subcommand)]\n    command: Option<Commands>,\n}\n\n#[derive(Subcommand)]\nenum Commands {\n    /// Run sessions from GitHub issues or a prompt\n    Run {\n        /// Prompt to send to Claude\n        #[arg(short, long)]\n        prompt: Option<String>,\n\n        /// GitHub issue number(s), comma-separated\n        #[arg(short, long)]\n        issue: Option<String>,\n\n        /// Milestone to fetch all issues from\n        #[arg(short = 'M', long)]\n        milestone: Option<String>,\n\n        /// Model to use (opus, sonnet, haiku)\n        #[arg(short, long)]\n        model: Option<String>,\n\n        /// Max concurrent sessions (overrides config)\n        #[arg(long)]\n        max_concurrent: Option<usize>,\n\n        /// Resume from previous state after a crash\n        #[arg(long)]\n        resume: bool,\n    },\n    /// Show queued/pending issues from GitHub\n    Queue,\n    /// Add an issue to the work queue manually\n    Add {\n        /// Issue number to add\n        issue_number: u64,\n    },\n    /// Show current state without TUI\n    Status,\n    /// Show spending report\n    Cost,\n    /// Initialize maestro.toml in current directory\n    Init,\n    /// Clean orphaned worktrees left by crashed sessions\n    Clean {\n        /// Show what would be cleaned without actually doing it\n        #[arg(long)]\n        dry_run: bool,\n    },\n    /// Show session transcript logs\n    Logs {\n        /// Show full log for a specific session ID\n        #[arg(long)]\n        session: Option<String>,\n        /// Export as JSON\n        #[arg(long)]\n        export: Option<String>,\n    },\n}\n\n#[tokio::main]\nasync fn main() -> anyhow::Result<()> {\n    // Init logging (to file, not terminal — TUI owns stdout)\n    tracing_subscriber::fmt()\n        .with_env_filter(\"maestro=debug\")\n        .with_writer(|| {\n            std::fs::OpenOptions::new()\n                .create(true)\n                .append(true)\n                .open(\"maestro.log\")\n                .unwrap_or_else(|_| {\n                    std::fs::OpenOptions::new()\n                        .write(true)\n                        .open(\"/dev/null\")\n                        .unwrap()\n                })\n        })\n        .init();\n\n    let cli = Cli::parse();\n\n    match cli.command {\n        Some(Commands::Init) => cmd_init(),\n        Some(Commands::Clean { dry_run }) => cmd_clean(dry_run),\n        Some(Commands::Logs { session, export }) => cmd_logs(session, export),\n        Some(Commands::Status) => cmd_status(),\n        Some(Commands::Cost) => cmd_cost(),\n        Some(Commands::Queue) => cmd_queue().await,\n        Some(Commands::Add { issue_number }) => cmd_add(issue_number).await,\n        Some(Commands::Run {\n            prompt,\n            issue,\n            milestone,\n            model,\n            max_concurrent,\n            resume,\n        }) => cmd_run(prompt, issue, milestone, model, max_concurrent, resume).await,\n        // Default: launch TUI with no sessions (dashboard mode)\n        None => cmd_dashboard().await,\n    }\n}\n\nfn cmd_init() -> anyhow::Result<()> {\n    let path = std::path::PathBuf::from(\"maestro.toml\");\n    if path.exists() {\n        println!(\"maestro.toml already exists.\");\n        return Ok(());\n    }\n\n    let content = r#\"[project]\nrepo = \"\"\nbase_branch = \"main\"\n\n[sessions]\nmax_concurrent = 3\nstall_timeout_secs = 300\ndefault_model = \"opus\"\ndefault_mode = \"orchestrator\"\npermission_mode = \"bypassPermissions\"  # Options: default, acceptEdits, bypassPermissions, dontAsk, plan, auto\nallowed_tools = []                      # Empty = all tools. Example: [\"Bash\", \"Read\", \"Write\", \"Edit\"]\n\n[budget]\nper_session_usd = 5.0\ntotal_usd = 50.0\nalert_threshold_pct = 80\n\n[github]\nissue_filter_labels = [\"maestro:ready\"]\nauto_pr = true\nauto_merge = false                      # Set to true to auto-merge PRs after CI + review pass\nmerge_method = \"squash\"                 # Options: merge, squash, rebase\ncache_ttl_secs = 300\n\n[gates]\nenabled = true\ntest_command = \"cargo test\"\nci_poll_interval_secs = 30\nci_max_wait_secs = 1800\n\n[notifications]\ndesktop = true\nslack = false\n\n[review]\nenabled = false\ncommand = \"gh pr review {pr_number} --comment --body 'Automated review by Maestro'\"\n# reviewers = [\n#   { name = \"claude\", command = \"claude --print 'review PR #{pr_number}'\", required = true },\n#   { name = \"codex\", command = \"codex review {pr_number}\", required = false },\n# ]\n\n[concurrency]\nheavy_task_labels = []                  # Labels that mark a task as resource-intensive\nheavy_task_limit = 2                    # Max concurrent heavy tasks\n\n[monitoring]\nwork_tick_interval_secs = 10\n\"#;\n\n    std::fs::write(&path, content)?;\n    println!(\"Created maestro.toml\");\n    Ok(())\n}\n\nfn cmd_status() -> anyhow::Result<()> {\n    let store = StateStore::new(StateStore::default_path());\n    let state = store.load()?;\n\n    if state.sessions.is_empty() {\n        println!(\"No sessions recorded.\");\n        return Ok(());\n    }\n\n    println!(\n        \"Sessions: {} total, {} active\",\n        state.sessions.len(),\n        state.active_sessions().len()\n    );\n    println!(\"Total cost: ${:.2}\", state.total_cost_usd);\n    println!();\n\n    for session in &state.sessions {\n        let label = match session.issue_number {\n            Some(n) => format!(\"#{}\", n),\n            None => session.id.to_string()[..8].to_string(),\n        };\n        println!(\n            \"  {} {} {} ${:.2} {}\",\n            session.status.symbol(),\n            label,\n            session.status.label(),\n            session.cost_usd,\n            session.elapsed_display(),\n        );\n    }\n\n    Ok(())\n}\n\nfn cmd_cost() -> anyhow::Result<()> {\n    let store = StateStore::new(StateStore::default_path());\n    let state = store.load()?;\n\n    println!(\"=== Maestro Spending Report ===\");\n    println!(\"Total: ${:.2}\", state.total_cost_usd);\n    println!();\n\n    for session in &state.sessions {\n        let label = match session.issue_number {\n            Some(n) => format!(\"#{:<6}\", n),\n            None => session.id.to_string()[..8].to_string(),\n        };\n        println!(\n            \"  {} ${:.2} ({})\",\n            label,\n            session.cost_usd,\n            session.status.label(),\n        );\n    }\n\n    Ok(())\n}\n\nasync fn cmd_queue() -> anyhow::Result<()> {\n    let config = Config::find_and_load()?;\n    let client = GhCliClient::new();\n    let label_refs: Vec<&str> = config\n        .github\n        .issue_filter_labels\n        .iter()\n        .map(|s| s.as_str())\n        .collect();\n    let issues = client.list_issues(&label_refs).await?;\n\n    if issues.is_empty() {\n        println!(\n            \"No issues found with labels: {:?}\",\n            config.github.issue_filter_labels\n        );\n        return Ok(());\n    }\n\n    let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n    let assigner = WorkAssigner::new(items);\n\n    println!(\n        \"{:<10} {:<8} {:<50} {:<10} {:<15}\",\n        \"Priority\", \"Issue\", \"Title\", \"Status\", \"Blocked By\"\n    );\n    println!(\"{}\", \"-\".repeat(93));\n\n    for item in assigner.all_items() {\n        let blocked_str = if item.blocked_by.is_empty() {\n            \"-\".to_string()\n        } else {\n            item.blocked_by\n                .iter()\n                .map(|n| format!(\"#{}\", n))\n                .collect::<Vec<_>>()\n                .join(\", \")\n        };\n        let title: String = if item.title().chars().count() > 48 {\n            let truncated: String = item.title().chars().take(45).collect();\n            format!(\"{}...\", truncated)\n        } else {\n            item.title().to_string()\n        };\n        let no_completed = std::collections::HashSet::new();\n        let ready_str = if item.is_ready(&no_completed) {\n            \"Ready\"\n        } else {\n            \"Blocked\"\n        };\n        println!(\n            \"{:<10} #{:<7} {:<50} {:<10} {}\",\n            format!(\"{:?}\", item.priority),\n            item.number(),\n            title,\n            ready_str,\n            blocked_str\n        );\n    }\n\n    let counts = assigner.count_by_status();\n    println!(\n        \"\\nTotal: {} issues ({} ready, {} blocked)\",\n        assigner.total(),\n        counts.pending,\n        assigner.total() - counts.pending\n    );\n\n    Ok(())\n}\n\nasync fn cmd_add(issue_number: u64) -> anyhow::Result<()> {\n    let client = GhCliClient::new();\n    // Add the maestro:ready label to the issue\n    client.add_label(issue_number, \"maestro:ready\").await?;\n    println!(\"Added 'maestro:ready' label to issue #{}\", issue_number);\n    Ok(())\n}\n\nfn cmd_logs(session: Option<String>, export: Option<String>) -> anyhow::Result<()> {\n    let logger = session::logger::SessionLogger::new(session::logger::SessionLogger::default_dir());\n\n    if let Some(session_id_str) = session {\n        let session_id: uuid::Uuid = session_id_str\n            .parse()\n            .map_err(|_| anyhow::anyhow!(\"Invalid session ID: {}\", session_id_str))?;\n        let content = logger.read_log(session_id)?;\n\n        if export.as_deref() == Some(\"json\") {\n            let lines: Vec<&str> = content.lines().collect();\n            let json = serde_json::json!({\n                \"session_id\": session_id_str,\n                \"lines\": lines,\n            });\n            println!(\"{}\", serde_json::to_string_pretty(&json)?);\n        } else {\n            println!(\"{}\", content);\n        }\n    } else {\n        let logs = logger.list_logs()?;\n        if logs.is_empty() {\n            println!(\"No session logs found.\");\n            return Ok(());\n        }\n\n        if export.as_deref() == Some(\"json\") {\n            let entries: Vec<serde_json::Value> = logs\n                .iter()\n                .map(|l| {\n                    serde_json::json!({\n                        \"session_id\": l.session_id,\n                        \"size_bytes\": l.size_bytes,\n                        \"path\": l.path.display().to_string(),\n                    })\n                })\n                .collect();\n            println!(\"{}\", serde_json::to_string_pretty(&entries)?);\n        } else {\n            println!(\"{:<40} {:>10}\", \"Session ID\", \"Size\");\n            println!(\"{}\", \"-\".repeat(52));\n            for log in &logs {\n                println!(\n                    \"{:<40} {:>10}\",\n                    log.session_id,\n                    format_bytes(log.size_bytes)\n                );\n            }\n            println!(\"\\n{} log(s) found.\", logs.len());\n        }\n    }\n    Ok(())\n}\n\nfn format_bytes(bytes: u64) -> String {\n    if bytes < 1024 {\n        format!(\"{}B\", bytes)\n    } else if bytes < 1024 * 1024 {\n        format!(\"{:.1}KB\", bytes as f64 / 1024.0)\n    } else {\n        format!(\"{:.1}MB\", bytes as f64 / (1024.0 * 1024.0))\n    }\n}\n\nfn cmd_clean(dry_run: bool) -> anyhow::Result<()> {\n    let repo_root = std::env::current_dir()?;\n    let mgr = session::cleanup::CleanupManager::new(&repo_root);\n    let orphans = mgr.scan_orphans()?;\n\n    if orphans.is_empty() {\n        println!(\"No orphaned worktrees found.\");\n        return Ok(());\n    }\n\n    println!(\"Found {} orphaned worktree(s):\", orphans.len());\n    for orphan in &orphans {\n        println!(\"  {} ({})\", orphan.name, orphan.path.display());\n    }\n\n    if dry_run {\n        println!(\"\\nDry run — no changes made.\");\n    } else {\n        let removed = mgr.remove_orphans(&orphans)?;\n        println!(\"\\nRemoved {} worktree(s).\", removed);\n    }\n\n    Ok(())\n}\n\nasync fn cmd_run(\n    prompt: Option<String>,\n    issue: Option<String>,\n    milestone: Option<String>,\n    model: Option<String>,\n    max_concurrent_override: Option<usize>,\n    resume: bool,\n) -> anyhow::Result<()> {\n    let config = Config::find_and_load()?;\n    let model = model.unwrap_or(config.sessions.default_model.clone());\n    let max_concurrent = max_concurrent_override.unwrap_or(config.sessions.max_concurrent);\n\n    let store = StateStore::new(StateStore::default_path());\n    let repo_root = std::env::current_dir()?;\n\n    // Startup cleanup: remove orphaned worktrees (non-blocking)\n    {\n        let cleanup_mgr = session::cleanup::CleanupManager::new(&repo_root);\n        if let Ok(orphans) = cleanup_mgr.scan_orphans()\n            && !orphans.is_empty()\n        {\n            tracing::info!(\"Cleaning {} orphaned worktrees on startup\", orphans.len());\n            let _ = cleanup_mgr.remove_orphans(&orphans);\n        }\n    }\n\n    // Startup log cleanup: remove logs older than 30 days\n    {\n        let logger =\n            session::logger::SessionLogger::new(session::logger::SessionLogger::default_dir());\n        if let Ok(removed) = logger.cleanup_old_logs(30)\n            && removed > 0\n        {\n            tracing::info!(\"Cleaned {} old session logs\", removed);\n        }\n    }\n    let worktree_mgr = Box::new(GitWorktreeManager::new(repo_root));\n\n    let mut app = App::new(\n        store,\n        max_concurrent,\n        worktree_mgr,\n        config.sessions.permission_mode.clone(),\n        config.sessions.allowed_tools.clone(),\n    );\n\n    // Wire up budget enforcer from config\n    app.budget_enforcer = Some(crate::budget::BudgetEnforcer::new(\n        config.budget.per_session_usd,\n        config.budget.total_usd,\n        config.budget.alert_threshold_pct,\n    ));\n\n    // Wire up model router from config\n    app.model_router = Some(crate::models::ModelRouter::new(\n        config.models.routing.clone(),\n        config.sessions.default_model.clone(),\n    ));\n\n    // Wire up notification dispatcher from config\n    app.notifications =\n        crate::notifications::dispatcher::NotificationDispatcher::new(config.notifications.desktop);\n\n    // Resume from previous state if requested\n    if resume {\n        let mut recovered = 0;\n        for session in &mut app.state.sessions {\n            if matches!(\n                session.status,\n                session::types::SessionStatus::Running | session::types::SessionStatus::Spawning\n            ) {\n                session.status = session::types::SessionStatus::Errored;\n                recovered += 1;\n            }\n        }\n        if recovered > 0 {\n            tracing::info!(\n                \"Resume: marked {} incomplete sessions as errored (retry will pick them up)\",\n                recovered\n            );\n        }\n    }\n\n    // Determine what to run\n    if let Some(prompt_text) = prompt {\n        let session = Session::new(\n            prompt_text,\n            model,\n            config.sessions.default_mode.clone(),\n            None,\n        );\n        app.add_session(session).await?;\n    } else if let Some(milestone_name) = milestone {\n        // Fetch all issues in the milestone\n        let client = GhCliClient::new();\n        let issues = client.list_issues_by_milestone(&milestone_name).await?;\n        if issues.is_empty() {\n            anyhow::bail!(\"No open issues found in milestone '{}'\", milestone_name);\n        }\n\n        let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n        let assigner = WorkAssigner::new(items);\n\n        // Store assigner and config in app for work management\n        app.work_assigner = Some(assigner);\n        app.github_client = Some(Box::new(client));\n        app.config = Some(config.clone());\n    } else if let Some(issue_str) = issue {\n        let client = GhCliClient::new();\n\n        // Parse comma-separated issue numbers and fetch full issue data\n        for num_str in issue_str.split(',') {\n            let num: u64 = num_str\n                .trim()\n                .parse()\n                .map_err(|_| anyhow::anyhow!(\"Invalid issue number: {}\", num_str.trim()))?;\n\n            let gh_issue = client.get_issue(num).await?;\n            let mut session = Session::new(\n                gh_issue.unattended_prompt(),\n                model.clone(),\n                config.sessions.default_mode.clone(),\n                Some(num),\n            );\n            session.issue_title = Some(gh_issue.title.clone());\n\n            // Cache issue data\n            app.state.issue_cache.insert(num, gh_issue);\n\n            app.add_session(session).await?;\n        }\n\n        // Set github client + config so label lifecycle and auto-PR work\n        app.github_client = Some(Box::new(client));\n        app.config = Some(config.clone());\n    } else {\n        // No prompt, issue, or milestone — auto-fetch maestro:ready issues\n        let client = GhCliClient::new();\n        let label_refs: Vec<&str> = config\n            .github\n            .issue_filter_labels\n            .iter()\n            .map(|s| s.as_str())\n            .collect();\n        let issues = client.list_issues(&label_refs).await?;\n\n        if issues.is_empty() {\n            anyhow::bail!(\n                \"No issues found with labels {:?}. Use --prompt or --issue instead.\",\n                config.github.issue_filter_labels\n            );\n        }\n\n        let items: Vec<WorkItem> = issues.into_iter().map(WorkItem::from_issue).collect();\n        let assigner = WorkAssigner::new(items);\n\n        app.work_assigner = Some(assigner);\n        app.github_client = Some(Box::new(client));\n        app.config = Some(config.clone());\n    }\n\n    // Launch TUI\n    tui::run(app).await\n}\n\nasync fn cmd_dashboard() -> anyhow::Result<()> {\n    let store = StateStore::new(StateStore::default_path());\n    let repo_root = std::env::current_dir()?;\n    let worktree_mgr = Box::new(GitWorktreeManager::new(repo_root));\n    let app = App::new(\n        store,\n        3,\n        worktree_mgr,\n        \"bypassPermissions\".into(),\n        Vec::new(),\n    );\n    tui::run(app).await\n}\n","numLines":604,"startLine":1,"totalLines":604}}}
