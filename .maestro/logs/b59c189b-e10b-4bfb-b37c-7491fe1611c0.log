[2026-03-24T20:20:37.274Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GZRQdPg3XaJuBByX5MjmtA","type":"tool_result","content":"     1→use super::types::MaestroState;\n     2→use anyhow::{Context, Result};\n     3→use std::path::{Path, PathBuf};\n     4→\n     5→pub struct StateStore {\n     6→    path: PathBuf,\n     7→}\n     8→\n     9→impl StateStore {\n    10→    pub fn new(path: PathBuf) -> Self {\n    11→        Self { path }\n    12→    }\n    13→\n    14→    pub fn default_path() -> PathBuf {\n    15→        PathBuf::from(\"maestro-state.json\")\n    16→    }\n    17→\n    18→    pub fn load(&self) -> Result<MaestroState> {\n    19→        if !self.path.exists() {\n    20→            return Ok(MaestroState::default());\n    21→        }\n    22→        let content = std::fs::read_to_string(&self.path)\n    23→            .with_context(|| format!(\"reading state from {}\", self.path.display()))?;\n    24→        serde_json::from_str(&content)\n    25→            .with_context(|| format!(\"parsing state from {}\", self.path.display()))\n    26→    }\n    27→\n    28→    pub fn save(&self, state: &MaestroState) -> Result<()> {\n    29→        let content = serde_json::to_string_pretty(state).context(\"serializing state\")?;\n    30→        // Write to temp file then rename for atomicity\n    31→        let tmp = self.path.with_extension(\"json.tmp\");\n    32→        std::fs::write(&tmp, &content)\n    33→            .with_context(|| format!(\"writing state to {}\", tmp.display()))?;\n    34→        std::fs::rename(&tmp, &self.path)\n    35→            .with_context(|| format!(\"renaming {} to {}\", tmp.display(), self.path.display()))?;\n    36→        Ok(())\n    37→    }\n    38→\n    39→    pub fn path(&self) -> &Path {\n    40→        &self.path\n    41→    }\n    42→}\n    43→"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"be91deca-bf32-413c-aff9-eb63f7eac382","timestamp":"2026-03-24T20:20:36.883Z"}
