lization.\n    39→    DependencyGraph,\n    40→}\n    41→\n    42→struct PendingIssueCompletion {\n    43→    issue_number: u64,\n    44→    success: bool,\n    45→    cost_usd: f64,\n    46→    files_touched: Vec<String>,\n    47→    worktree_branch: Option<String>,\n    48→    worktree_path: Option<std::path::PathBuf>,\n    49→}\n    50→\n    51→pub struct App {\n    52→    pub pool: SessionPool,\n    53→    pub activity_log: ActivityLog,\n    54→    pub panel_view: PanelView,\n    55→    pub state: MaestroState,\n    56→    pub store: StateStore,\n    57→    pub running: bool,\n    58→    pub total_cost: f64,\n    59→    pub start_time: chrono::DateTime<chrono::Utc>,\n    60→    pub event_tx: mpsc::UnboundedSender<SessionEvent>,\n    61→    pub event_rx: mpsc::UnboundedReceiver<SessionEvent>,\n    62→    /// Work assigner for GitHub issue-based runs. None for prompt-only runs.\n    63→    pub work_assigner: Option<WorkAssigner>,\n    64→    /// GitHub client for label updates and PR creation.\n    65→    pub github_client: Option<Box<dyn GitHubClient>>,\n    66→    /// Config reference for base_branch, auto_pr, etc.\n    67→    pub config: Option<Config>,\n    68→    /// Pending issue completions to process in the next async check_completions tick.\n    69→    pending_issue_completions: Vec<PendingIssueCompletion>,\n    70→    /// Health monitor for stall detection.\n    71→    pub health_monitor: Box<dyn HealthCheck>,\n    72→    /// Budget enforcer for cost limits.\n    73→    pub budget_enforcer: Option<BudgetEnforcer>,\n    74→    /// Model router for task-based model selection.\n    75→    pub model_router: Option<ModelRouter>,\n    76→    /// Progress tracker for per-session phase tracking.\n    77→    pub progress_tracker: ProgressTracker,\n    78→    /// Notification dispatcher for interruption system.\n    79→    pub notifications: NotificationDispatcher,\n    80→    /// Current TUI display mode.\n    81→    pub tui_mode: TuiMode,\n    82→    /// Session