bal check\n   341→        match enforcer.check_global(self.total_cost) {\n   342→            BudgetAction::Kill => {\n   343→                self.activity_log.push_simple(\n   344→                    \"MAESTRO\".into(),\n   345→                    format!(\n   346→                        \"GLOBAL BUDGET EXCEEDED: ${:.2}/${:.2} — stopping all sessions\",\n   347→                        self.total_cost,\n   348→                        enforcer.total_limit()\n   349→                    ),\n   350→                    LogLevel::Error,\n   351→                );\n   352→                self.running = false;\n   353→            }\n   354→            BudgetAction::Alert(pct) => {\n   355→                if !enforcer.global_alert_sent() {\n   356→                    enforcer.mark_global_alert_sent();\n   357→                    self.activity_log.push_simple(\n   358→                        \"MAESTRO\".into(),\n   359→                        format!(\"Global budget warning: {}% used\", pct),\n   360→                        LogLevel::Warn,\n   361→                    );\n   362→                }\n   363→            }\n   364→            BudgetAction::Ok => {}\n   365→        }\n   366→    }\n   367→\n   368→    /// Check for completed sessions and promote queued ones.\n   369→    pub async fn check_completions(&mut self) -> anyhow::Result<()> {\n   370→        // Process pending issue completions (gates, git push, label updates, PR creation)\n   371→        let pending = std::mem::take(&mut self.pending_issue_completions);\n   372→        let gates_config = self.config.as_ref().map(|c| c.gates.clone());\n   373→\n   374→        for mut completion in pending {\n   375→            // Run completion gates before accepting the result\n   376→            if completion.success\n   377→                && let (Some(gates_cfg), Some(wt_path)) = (&gates_config, &completion.worktree_path)\n   378→                && gates_cfg.enabled\n   379→            {\n   380→                let gates = vec![CompletionGate::TestsPass {\n   381→                    command: gates_cfg.test_command.clone(),\n   382→                }];\n   383→                let gate_runner = GateRunner;\n   384→                let results = gate_runner.run_gates(&gates, wt_path);\n   385→\n   386→                if !runner::all_gates_passed(&results) {\n   387→                    let failures: Vec<String> = results\n   388→                        .iter()\n   389→                        .filter(|r| !r.passed)\n   390→                        .map(|r| r.message.clone())\n   391→                        .collect();\n   392→                    self.activity_log.push_simple(\n   393→                        format!(\"#{}\", completion.issue_number),\n   394→                        format!(\"Gate failed: {}\", failures.join(\"; \")),\n   395→                        LogLevel::Error,\n   396→                    );\n   397→                    // Mark as failed — retry system will pick it up\n   398→                    completion.success = false;\n   399→                } else {\n   400→                    self.activity_log.push_simple(\n   401→                        format!(\"#{}\", completion.issue_number),\n   402→                        \"All gates passed\".into(),\n   403→                        LogLevel::Info,\n   404→                    );\n   405→                }\n   406→            }\n   407→\n   408→            // If successful and we have a worktree, commit and push changes\n   409→            if completion.success\n   410→                && let (Some(branch), Some(wt_path)) =\n   411→                    (&completion.worktree_branch, &completion.worktree_path)\n   412→            {\n   413→                let git_ops = crate::git::CliGitOps;\n   414→                let commit_msg = format!(\n   415→                    \"feat: implement changes for issue #{}\",\n   416→                    completion.issue_number\n   417→                );\n   418→                match git_ops.commit_and_push(wt_path, branch, &commit_msg) {\n   419→                    Ok(()) => {\n   420→                        self.activity_log.push_simple(\n   421→                            format!(\"#{}\", completion.issue_number),\n   422→                            format!(\"Pushed to branch {}\", branch),\n   423→                            LogLevel::Info,\n   424→                        );\n   425→                    }\n   426→                    Err(e) => {\n   427→                        self.activity_log.push_simple(\n   428→                            format!(\"#{}\", completion.issue_number),\n   429→                            format!(\"Git push failed: {}\", e),\n   430→                            LogLevel::Error,\n   431→                        );\n   432→                    }\n   433→                }\n   434→            }\n   435→\n   436→            self.on_issue_session_completed(\n   437→                completion.issue_number,\n   438→                completion.success,\n   439→                completion.cost_usd,\n   440→                completion.files_touched,\n   441→                completion.worktree_branch,\n   442→            )\n   443→            .await;\n   444→        }\n   445→\n   446→        // Stall detection: check for sessions that haven't produced events\n   447→        let stall_timeout = self\n   448→            .config\n   449→            .as_ref()\n   450→            .map(|c| Duration::from_secs(c.sessions.stall_timeout_secs))\n   451→            .unwrap_or(Duration::from_secs(300));\n   452→\n   453→        let stalled_ids = self.health_monitor.check_stalls(stall_timeout);\n   454→        for id in &stalled_ids {\n   455→            if let Some(managed) = self.pool.get_active_mut(*id)\n   456→                && managed.session.status == SessionStatus::Running\n   457→            {\n   458→                managed.session.status = SessionStatus::Stalled;\n   459→                let label = session_label(&managed.session);\n   460→                self.activity_log.push_simple(\n   461→                    label,\n   462→                    format!(\n   463→                        \"Session stalled (no activity for {}s)\",\n   464→                        stall_timeout.as_secs()\n   465→                    ),\n   466→                    LogLevel::Error,\n   467→                );\n   468→            }\n   469→        }\n   470→\n   471→        // Retry eligible sessions (stalled or errored) before finalizing\n   472→        let retry_policy = self\n   473→            .config\n   474→            .as_ref()\n   475→            .map(|c| RetryPolicy::new(c.sessions.max_retries, c.sessions.retry_cooldown_secs));\n   476→\n   477→        let retryable_ids: Vec<uuid::Uuid> = self\n   478→            .pool\n   479→            .all_sessions()\n   480→            .iter()\n   481→            .filter(|s| matches!(s.status, SessionStatus::Stalled | SessionStatus::Errored))\n   482→            .map(|s| s.id)\n   483→            .collect();\n   484→\n   485→        let mut retry_sessions = Vec::new();\n   486→        for id in &retryable_ids {\n   487→            if let Some(policy) = &retry_policy\n   488→                && let Some(managed) = self.pool.get_active_mut(*id)\n   489→                && policy.should_retry(&managed.session)\n   490→            {\n   491→                let label = session_label(&managed.session);\n   492→                // Gather progress and last error for rich retry context\n   493→                let progress = self.progress_tracker.get(id).cloned();\n   494→                let last_error = managed\n   495→                    .session\n   496→                    .activity_log\n   497→                    .iter()\n   498→                    .rev()\n   499→                    .find(|e| e.message.starts_with(\"ERROR:\") || e.message.contains(\"failed\"))\n   500→                    .map(|e| e.message.clone());\n   501→                let retry = policy.prepare_retry(\n   502→                    &managed.session,\n   503→                    progress.as_ref(),\n   504→                    last_error.as_deref(),\n   505→                );\n   506→                managed.session.status = SessionStatus::Retrying;\n   507→                self.activity_log.push_simple(\n   508→                    label,\n   509→                    format!(\n   510→                        \"Retrying (attempt {}/{})\",\n   511→                        retry.retry_count, policy.max_retries\n   512→                    ),\n   513→                    LogLevel::Warn,\n   514→                );\n   515→                retry_sessions.push(retry);\n   516→            }\n   517→        }\n   518→\n   519→        // Enqueue retry sessions\n   520→        for session in retry_sessions {\n   521→            self.add_session(session).await?;\n   522→        }\n   523→\n   524→        // Find terminal sessions in the active list (including Retrying which is now done)\n   525→        let completed_ids: Vec<uuid::Uuid> = self\n   526→            .pool\n   527→            .all_sessions()\n   528→            .iter()\n   529→            .filter(|s| s.status.is_terminal() || s.status == SessionStatus::Retrying)\n   530→            .map(|s| s.id)\n   531→            .collect();\n   532→\n   533→        // Only process sessions that are actually in the active list\n   534→        for id in &completed_ids {\n   535→            if self.pool.get_active_mut(*id).is_some() {\n   536→                self.pool.on_session_completed(*id);\n   537→                self.health_monitor.remove(*id);\n   538→                self.progress_tracker.remove(id);\n   539→            }\n   540→        }\n   541→\n   542→        // Medium tier: work assigner tick (every ~10s)\n   543→        let work_tick_interval = self\n   544→            .config\n   545→            .as_ref()\n   546→            .map(|c| Duration::from_secs(c.monitoring.work_tick_interval_secs))\n   547→            .unwrap_or(Duration::from_secs(10));\n   548→\n   549→        if self.last_work_tick.elapsed() >= work_tick_interval {\n   550→            self.last_work_tick = Instant::now();\n   551→            // Tick the work assigner to fill available slots from GitHub issues\n   552→            self.tick_work_assigner().await?;\n   553→        }\n   554→\n   555→        // Slow tier: CI status polling (every ~30s)\n   556→        self.poll_ci_status();\n   557→\n   558→        // Try to promote queued sessions\n   559→        let promoted_ids = self.pool.try_promote();\n   560→        if !promoted_ids.is_empty() {\n   561→            let tx = self.pool.event_tx();\n   562→            for id in promoted_ids {\n   563→                if let Some(managed) = self.pool.get_active_mut(id) {\n   564→                    let label = session_label(&managed.session);\n   565→                    self.activity_log.push_simple(\n   566→                        label.clone(),\n   567→                        \"Spawning session...\".into(),\n   568→                        LogLevel::Info,\n   569→                    );\n   570→                    if let Err(e) = managed.spawn(tx.clone()).await {\n   571→                        self.activity_log.push_simple(\n   572→                            label,\n   573→                            format!(\"Spawn failed: {}\", e),\n   574→                            LogLevel::Error,\n   575→                        );\n   576→                    } else {\n   577→                        self.activity_log.push_simple(\n   578→                            label,\n   579→                            \"Session started\".into(),\n   580→                            LogLevel::Info,\n   581→                        );\n   582→                    }\n   583→                }\n   584→            }\n   585→        }\n   586→\n   587→        self.sync_state();\n   588→        Ok(())\n   589→    }\n   590→\n   591→    /// Pause all running sessions.\n   592→    #[cfg(unix)]\n   593→    pub fn pause_all(&self) {\n   594→        self.pool.pause_all();\n   595→    }\n   596→\n   597→    /// Resume all paused sessions.\n   598→    #[cfg(unix)]\n   599→    pub fn resume_all(&self) {\n   600→        self.pool.resume_all();\n   601→    }\n   602→\n   603→    /// Kill all sessions.\n   604→    pub async fn kill_all(&mut self) {\n   605→        self.pool.kill_all().await;\n   606→        self.sync_state();\n   607→    }\n   608→\n   609→    /// Check if all sessions are done.\n   610→    pub fn all_done(&self) -> bool {\n   611→        self.pool.all_done()\n   612→    }\n   613→\n   614→    pub fn active_count(&self) -> usize {\n   615→        self.pool.active_count()\n   616→    }\n   617→\n   618→    /// Assign ready work items from the assigner to session slots.\n   619→    pub async fn tick_work_assigner(&mut self) -> anyhow::Result<()> {\n   620→        // Collect ready items and mark them in-progress (scoped borrow)\n   621→        let ready_items = {\n   622→            let Some(assigner) = self.work_assigner.as_mut() else {\n   623→                return Ok(());\n   624→            };\n   625→            let Some(config) = self.config.as_ref() else {\n   626→                return Ok(());\n   627→            };\n   628→\n   629→            let available_slots = self\n   630→                .pool\n   631→                .max_concurrent()\n   632→                .saturating_sub(self.pool.active_count());\n   633→            if available_slots == 0 {\n   634→                return Ok(());\n   635→            }\n   636→\n   637→            let heavy_labels = &config.concurrency.heavy_task_labels;\n   638→            let heavy_limit = config.concurrency.heavy_task_limit;\n   639→\n   640→            // Get all ready items, then filter by heavy task limit\n   641→            let all_ready = assigner.next_ready(available_slots);\n   642→            let mut items: Vec<(u64, String, String, String, String)> = Vec::new();\n   643→            let mut heavy_count_projected = 0usize;\n   644→\n   645→            for item in all_ready {\n   646→                let is_heavy = !heavy_labels.is_empty()\n   647→                    && item.issue.labels.iter().any(|l| heavy_labels.contains(l));\n   648→\n   649→                if is_heavy && heavy_count_projected >= heavy_limit {\n   650→                    // Skip — heavy task limit reached\n   651→                    continue;\n   652→                }\n   653→\n   654→                let prompt = PromptBuilder::build_issue_prompt(&item.issue, config);\n   655→                let mode = item\n   656→                    .mode\n   657→                    .map(|m| m.as_config_str().to_string())\n   658→                    .unwrap_or_else(|| config.sessions.default_mode.clone());\n   659→                let model = self\n   660→                    .model_router\n   661→                    .as_ref()\n   662→                    .map(|r| r.resolve(&item.issue).to_string())\n   663→                    .unwrap_or_else(|| config.sessions.default_model.clone());\n   664→\n   665→                if is_heavy {\n   666→                    heavy_count_projected += 1;\n   667→                }\n   668→                items.push((\n   669→                    item.issue.number,\n   670→                    prompt,\n   671→                    mode,\n   672→                    item.issue.title.clone(),\n   673→                    model,\n   674→                ));\n   675→            }\n   676→\n   677→            // Mark in-progress within this scope\n   678→            for (issue_number, _, _, _, _) in &items {\n   679→                assigner.mark_in_progress(*issue_number);\n   680→            }\n   681→\n   682→            items\n   683→        };\n   684→\n   685→        let items = ready_items;\n   686→\n   687→        for (issue_number, prompt, mode, title, model) in items {\n   688→            // Update GitHub labels (non-fatal on error)\n   689→            if let Some(client) = &self.github_client {\n   690→                let label_mgr = LabelManager::new(client.as_ref());\n   691→                if let Err(e) = label_mgr.mark_in_progress(issue_number).await {\n   692→                    self.activity_log.push_simple(\n   693→                        format!(\"#{}\", issue_number),\n   694→                        format!(\"Label update failed: {}\", e),\n   695→                        LogLevel::Error,\n   696→                    );\n   697→                }\n   698→            }\n   699→"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"e914b7d4-b956-4076-97f8-cfa6114e900e","timestamp":"2026-03-24T20:20:30.370Z"}
