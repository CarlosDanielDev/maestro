[2026-03-24T20:20:37.495Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0143xVf8MYAxtxgWHAMwCyKs","type":"tool_result","content":"     1→use crate::github::types::{GhIssue, Priority, SessionMode};\n     2→use serde::{Deserialize, Serialize};\n     3→use std::collections::HashSet;\n     4→\n     5→#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\n     6→#[serde(rename_all = \"snake_case\")]\n     7→pub enum WorkStatus {\n     8→    Pending,\n     9→    Blocked,\n    10→    InProgress,\n    11→    Done,\n    12→    Failed,\n    13→}\n    14→\n    15→#[derive(Debug, Clone, Serialize, Deserialize)]\n    16→pub struct WorkItem {\n    17→    pub priority: Priority,\n    18→    pub mode: Option<SessionMode>,\n    19→    pub status: WorkStatus,\n    20→    /// Cached blockers (computed once from issue labels + body).\n    21→    pub blocked_by: Vec<u64>,\n    22→    /// The original issue data.\n    23→    pub issue: GhIssue,\n    24→}\n    25→\n    26→impl WorkItem {\n    27→    pub fn from_issue(issue: GhIssue) -> Self {\n    28→        let priority = issue.priority();\n    29→        let mode = issue.session_mode();\n    30→        let blocked_by = issue.all_blockers();\n    31→\n    32→        Self {\n    33→            priority,\n    34→            mode,\n    35→            status: WorkStatus::Pending,\n    36→            blocked_by,\n    37→            issue,\n    38→        }\n    39→    }\n    40→\n    41→    /// Convenience accessor for issue number.\n    42→    pub fn number(&self) -> u64 {\n    43→        self.issue.number\n    44→    }\n    45→\n    46→    /// Convenience accessor for issue title.\n    47→    pub fn title(&self) -> &str {\n    48→        &self.issue.title\n    49→    }\n    50→\n    51→    /// A work item is ready if its status is Pending and all blockers are in the completed set.\n    52→    pub fn is_ready(&self, completed: &HashSet<u64>) -> bool {\n    53→        self.status == WorkStatus::Pending && self.blocked_by.iter().all(|b| completed.contains(b))\n    54→    }\n    55→}\n    56→\n    57→#[cfg(test)]\n    58→mod tests {\n    59→    use super::*;\n    60→\n    61→    fn make_gh_issue(number: u64, labels: &[&str], body: &str) -> GhIssue {\n    62→        GhIssue {\n    63→            number,\n    64→            title: format!(\"Issue #{}\", number),\n    65→            body: body.to_string(),\n    66→            labels: labels.iter().map(|s| s.to_string()).collect(),\n    67→            state: \"open\".to_string(),\n    68→            html_url: format!(\"https://github.com/o/r/issues/{}\", number),\n    69→        }\n    70→    }\n    71→\n    72→    // WorkItem::from_issue\n    73→\n    74→    #[test]\n    75→    fn from_issue_captures_number_and_title() {\n    76→        let issue = make_gh_issue(42, &[\"maestro:ready\"], \"\");\n    77→        let item = WorkItem::from_issue(issue);\n    78→        assert_eq!(item.number(), 42);\n    79→        assert_eq!(item.title(), \"Issue #42\");\n    80→    }\n    81→\n    82→    #[test]\n    83→    fn from_issue_extracts_p0_priority() {\n    84→        let issue = make_gh_issue(1, &[\"priority:P0\", \"maestro:ready\"], \"\");\n    85→        let item = WorkItem::from_issue(issue);\n    86→        assert_eq!(item.priority, Priority::P0);\n    87→    }\n    88→\n    89→    #[test]\n    90→    fn from_issue_extracts_p1_priority() {\n    91→        let issue = make_gh_issue(2, &[\"priority:P1\"], \"\");\n    92→        let item = WorkItem::from_issue(issue);\n    93→        assert_eq!(item.priority, Priority::P1);\n    94→    }\n    95→\n    96→    #[test]\n    97→    fn from_issue_defaults_priority_to_p2() {\n    98→        let issue = make_gh_issue(3, &[\"maestro:ready\"], \"\");\n    99→        let item = WorkItem::from_issue(issue);\n   100→        assert_eq!(item.priority, Priority::P2);\n   101→    }\n   102→\n   103→    #[test]\n   104→    fn from_issue_extracts_session_mode_orchestrator() {\n   105→        let issue = make_gh_issue(4, &[\"mode:orchestrator\"], \"\");\n   106→        let item = WorkItem::from_issue(issue);\n   107→        assert_eq!(item.mode, Some(SessionMode::Orchestrator));\n   108→    }\n   109→\n   110→    #[test]\n   111→    fn from_issue_extracts_session_mode_vibe() {\n   112→        let issue = make_gh_issue(5, &[\"mode:vibe\"], \"\");\n   113→        let item = WorkItem::from_issue(issue);\n   114→        assert_eq!(item.mode, Some(SessionMode::Vibe));\n   115→    }\n   116→\n   117→    #[test]\n   118→    fn from_issue_mode_none_when_no_mode_label() {\n   119→        let issue = make_gh_issue(6, &[\"maestro:ready\"], \"\");\n   120→        let item = WorkItem::from_issue(issue);\n   121→        assert_eq!(item.mode, None);\n   122→    }\n   123→\n   124→    #[test]\n   125→    fn from_issue_collects_blockers_from_labels() {\n   126→        let issue = make_gh_issue(10, &[\"blocked-by:#3\", \"blocked-by:#7\"], \"\");\n   127→        let item = WorkItem::from_issue(issue);\n   128→        let mut blockers = item.blocked_by.clone();\n   129→        blockers.sort();\n   130→        assert_eq!(blockers, vec![3u64, 7u64]);\n   131→    }\n   132→\n   133→    #[test]\n   134→    fn from_issue_collects_blockers_from_body() {\n   135→        let issue = make_gh_issue(10, &[], \"blocked-by: #5\\nblocked-by: #9\");\n   136→        let item = WorkItem::from_issue(issue);\n   137→        let mut blockers = item.blocked_by.clone();\n   138→        blockers.sort();\n   139→        assert_eq!(blockers, vec![5u64, 9u64]);\n   140→    }\n   141→\n   142→    #[test]\n   143→    fn from_issue_deduplicates_blockers_from_labels_and_body() {\n   144→        let issue = make_gh_issue(10, &[\"blocked-by:#2\"], \"blocked-by: #2\\nblocked-by: #4\");\n   145→        let item = WorkItem::from_issue(issue);\n   146→        let mut blockers = item.blocked_by.clone();\n   147→        blockers.sort();\n   148→        assert_eq!(blockers, vec![2u64, 4u64]);\n   149→    }\n   150→\n   151→    #[test]\n   152→    fn from_issue_initial_status_is_pending() {\n   153→        let issue = make_gh_issue(1, &[\"maestro:ready\"], \"\");\n   154→        let item = WorkItem::from_issue(issue);\n   155→        assert_eq!(item.status, WorkStatus::Pending);\n   156→    }\n   157→\n   158→    // WorkItem::is_ready\n   159→\n   160→    #[test]\n   161→    fn is_ready_true_when_pending_and_no_blockers() {\n   162→        let issue = make_gh_issue(1, &[\"maestro:ready\"], \"\");\n   163→        let item = WorkItem::from_issue(issue);\n   164→        assert!(item.is_ready(&HashSet::new()));\n   165→    }\n   166→\n   167→    #[test]\n   168→    fn is_ready_false_when_blocked_by_pending_issue() {\n   169→        let issue = make_gh_issue(2, &[\"blocked-by:#1\"], \"\");\n   170→        let item = WorkItem::from_issue(issue);\n   171→        assert!(!item.is_ready(&HashSet::new()));\n   172→    }\n   173→\n   174→    #[test]\n   175→    fn is_ready_true_when_all_blockers_completed() {\n   176→        let issue = make_gh_issue(2, &[\"blocked-by:#1\"], \"\");\n   177→        let item = WorkItem::from_issue(issue);\n   178→        assert!(item.is_ready(&HashSet::from([1u64])));\n   179→    }\n   180→\n   181→    #[test]\n   182→    fn is_ready_false_when_status_is_not_pending() {\n   183→        let issue = make_gh_issue(1, &[\"maestro:ready\"], \"\");\n   184→        let mut item = WorkItem::from_issue(issue);\n   185→        item.status = WorkStatus::InProgress;\n   186→        assert!(!item.is_ready(&HashSet::new()));\n   187→    }\n   188→\n   189→    #[test]\n   190→    fn is_ready_false_when_one_of_multiple_blockers_incomplete() {\n   191→        let issue = make_gh_issue(5, &[\"blocked-by:#1\", \"blocked-by:#2\"], \"\");\n   192→        let item = WorkItem::from_issue(issue);\n   193→        assert!(!item.is_ready(&HashSet::from([1u64])));\n   194→    }\n   195→\n   196→    #[test]\n   197→    fn is_ready_true_when_all_multiple_blockers_completed() {\n   198→        let issue = make_gh_issue(5, &[\"blocked-by:#1\", \"blocked-by:#2\"], \"\");\n   199→        let item = WorkItem::from_issue(issue);\n   200→        assert!(item.is_ready(&HashSet::from([1u64, 2u64])));\n   201→    }\n   202→}\n   203→"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"5f20282b-79f4-4aec-88bb-6871adb405a1","timestamp":"2026-03-24T20:20:37.244Z"}
