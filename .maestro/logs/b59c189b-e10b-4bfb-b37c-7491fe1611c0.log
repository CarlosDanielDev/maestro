[2026-03-24T20:20:33.956Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LyKNRTS8SyswitnsjTyhy7","type":"tool_result","content":"     1→use std::collections::VecDeque;\n     2→use tokio::sync::mpsc;\n     3→use uuid::Uuid;\n     4→\n     5→use super::manager::{ManagedSession, SessionEvent};\n     6→use super::types::{Session, SessionStatus};\n     7→use super::worktree::WorktreeManager;\n     8→use crate::state::file_claims::FileClaimManager;\n     9→\n    10→pub struct SessionPool {\n    11→    max_concurrent: usize,\n    12→    queue: VecDeque<Session>,\n    13→    active: Vec<ManagedSession>,\n    14→    finished: Vec<ManagedSession>,\n    15→    worktree_mgr: Box<dyn WorktreeManager + Send>,\n    16→    pub file_claims: FileClaimManager,\n    17→    event_tx: mpsc::UnboundedSender<SessionEvent>,\n    18→    /// Permission mode passed to Claude CLI sessions.\n    19→    permission_mode: String,\n    20→    /// Allowed tools whitelist passed to Claude CLI sessions.\n    21→    allowed_tools: Vec<String>,\n    22→}\n    23→\n    24→impl SessionPool {\n    25→    pub fn new(\n    26→        max_concurrent: usize,\n    27→        worktree_mgr: Box<dyn WorktreeManager + Send>,\n    28→        event_tx: mpsc::UnboundedSender<SessionEvent>,\n    29→    ) -> Self {\n    30→        Self {\n    31→            max_concurrent,\n    32→            queue: VecDeque::new(),\n    33→            active: Vec::new(),\n    34→            finished: Vec::new(),\n    35→            worktree_mgr,\n    36→            file_claims: FileClaimManager::new(),\n    37→            event_tx,\n    38→            permission_mode: \"bypassPermissions\".to_string(),\n    39→            allowed_tools: Vec::new(),\n    40→        }\n    41→    }\n    42→\n    43→    /// Get the max concurrent session limit.\n    44→    pub fn max_concurrent(&self) -> usize {\n    45→        self.max_concurrent\n    46→    }\n    47→\n    48→    /// Set the permission mode for new sessions.\n    49→    pub fn set_permission_mode(&mut self, mode: String) {\n    50→        self.permission_mode = mode;\n    51→    }\n    52→\n    53→    /// Set the allowed tools whitelist for new sessions.\n    54→    pub fn set_allowed_tools(&mut self, tools: Vec<String>) {\n    55→        self.allowed_tools = tools;\n    56→    }\n    57→\n    58→    /// Enqueue a session. It will be promoted when capacity allows.\n    59→    pub fn enqueue(&mut self, session: Session) {\n    60→        self.queue.push_back(session);\n    61→    }\n    62→\n    63→    /// Try to promote queued sessions into active slots.\n    64→    /// Creates worktrees and prepares ManagedSessions.\n    65→    /// Returns the IDs of sessions that were promoted and need spawning.\n    66→    pub fn try_promote(&mut self) -> Vec<Uuid> {\n    67→        let mut promoted = Vec::new();\n    68→\n    69→        while self.active.len() < self.max_concurrent {\n    70→            let Some(mut session) = self.queue.pop_front() else {\n    71→                break;\n    72→            };\n    73→\n    74→            let slug = session_slug(&session);\n    75→\n    76→            // Try to create worktree (non-fatal — runs in cwd if it fails)\n    77→            let branch_name = format!(\"maestro/{}\", slug);\n    78→            let (worktree_path, branch) = match self.worktree_mgr.create(&slug) {\n    79→                Ok(path) => {\n    80→                    session.log_activity(format!(\"Worktree created: {}\", path.display()));\n    81→                    (Some(path), Some(branch_name))\n    82→                }\n    83→                Err(e) => {\n    84→                    let msg = format!(\"Worktree skipped (running in cwd): {}\", e);\n    85→                    tracing::warn!(\"{}\", msg);\n    86→                    session.log_activity(msg);\n    87→                    (None, None)\n    88→                }\n    89→            };\n    90→\n    91→            // Build system prompt with file claims for other sessions\n    92→            let system_prompt = self.file_claims.build_system_prompt(session.id);\n    93→\n    94→            session.status = SessionStatus::Queued; // Still queued until spawned\n    95→            let mut managed =\n    96→                ManagedSession::with_worktree(session, worktree_path, branch, system_prompt);\n    97→            managed.permission_mode = Some(self.permission_mode.clone());\n    98→            managed.allowed_tools = self.allowed_tools.clone();\n    99→            let id = managed.session.id;\n   100→            self.active.push(managed);\n   101→            promoted.push(id);\n   102→        }\n   103→\n   104→        promoted\n   105→    }\n   106→\n   107→    /// Handle a session reaching terminal state: move to finished, cleanup worktree.\n   108→    pub fn on_session_completed(&mut self, session_id: Uuid) {\n   109→        if let Some(idx) = self.active.iter().position(|m| m.session.id == session_id) {\n   110→            let managed = self.active.remove(idx);\n   111→            let slug = session_slug(&managed.session);\n   112→\n   113→            // Release all file claims for this session\n   114→            self.file_claims.release_all(session_id);\n   115→\n   116→            // Cleanup worktree\n   117→            let _ = self.worktree_mgr.remove(&slug);\n   118→\n   119→            self.finished.push(managed);\n   120→        }\n   121→    }\n   122→\n   123→    /// Get all sessions for display: active first, then finished, then queued.\n   124→    pub fn all_sessions(&self) -> Vec<&Session> {\n   125→        let mut out: Vec<&Session> = Vec::new();\n   126→        for m in &self.active {\n   127→            out.push(&m.session);\n   128→        }\n   129→        for m in &self.finished {\n   130→            out.push(&m.session);\n   131→        }\n   132→        for s in &self.queue {\n   133→            out.push(s);\n   134→        }\n   135→        out\n   136→    }\n   137→\n   138→    /// Mutable access to a managed session by ID (active only).\n   139→    pub fn get_active_mut(&mut self, session_id: Uuid) -> Option<&mut ManagedSession> {\n   140→        self.active.iter_mut().find(|m| m.session.id == session_id)\n   141→    }\n   142→\n   143→    /// Mutable access to a session by ID across all buckets.\n   144→    pub fn get_session_mut(&mut self, session_id: Uuid) -> Option<&mut Session> {\n   145→        if let Some(m) = self.active.iter_mut().find(|m| m.session.id == session_id) {\n   146→            return Some(&mut m.session);\n   147→        }\n   148→        if let Some(m) = self\n   149→            .finished\n   150→            .iter_mut()\n   151→            .find(|m| m.session.id == session_id)\n   152→        {\n   153→            return Some(&mut m.session);\n   154→        }\n   155→        if let Some(s) = self.queue.iter_mut().find(|s| s.id == session_id) {\n   156→            return Some(s);\n   157→        }\n   158→        None\n   159→    }\n   160→\n   161→    pub fn active_count(&self) -> usize {\n   162→        self.active.len()\n   163→    }\n   164→\n   165→    pub fn queued_count(&self) -> usize {\n   166→        self.queue.len()\n   167→    }\n   168→\n   169→    pub fn total_count(&self) -> usize {\n   170→        self.active.len() + self.finished.len() + self.queue.len()\n   171→    }\n   172→\n   173→    pub fn all_done(&self) -> bool {\n   174→        self.total_count() > 0 && self.active.is_empty() && self.queue.is_empty()\n   175→    }\n   176→\n   177→    pub async fn kill_all(&mut self) {\n   178→        for managed in &mut self.active {\n   179→            if !managed.session.status.is_terminal() {\n   180→                let _ = managed.kill().await;\n   181→            }\n   182→        }\n   183→        // Move all active to finished\n   184→        self.finished.append(&mut self.active);\n   185→        // Clear queue\n   186→        self.queue.clear();\n   187→    }\n   188→\n   189→    #[cfg(unix)]\n   190→    pub fn pause_all(&self) {\n   191→        for managed in &self.active {\n   192→            if managed.session.status == SessionStatus::Running {\n   193→                let _ = managed.pause();\n   194→            }\n   195→        }\n   196→    }\n   197→\n   198→    #[cfg(unix)]\n   199→    pub fn resume_all(&self) {\n   200→        for managed in &self.active {\n   201→            if managed.session.status == SessionStatus::Paused {\n   202→                let _ = managed.resume();\n   203→            }\n   204→        }\n   205→    }\n   206→\n   207→    /// Get the event sender for spawning sessions.\n   208→    pub fn event_tx(&self) -> mpsc::UnboundedSender<SessionEvent> {\n   209→        self.event_tx.clone()\n   210→    }\n   211→}\n   212→\n   213→fn session_slug(session: &Session) -> String {\n   214→    match session.issue_number {\n   215→        Some(n) => format!(\"issue-{}\", n),\n   216→        None => format!(\"session-{}\", &session.id.to_string()[..8]),\n   217→    }\n   218→}\n   219→\n   220→#[cfg(test)]\n   221→mod tests {\n   222→    use super::*;\n   223→    use crate::session::worktree::MockWorktreeManager;\n   224→\n   225→    fn make_pool(max: usize) -> SessionPool {\n   226→        let (tx, _rx) = mpsc::unbounded_channel();\n   227→        SessionPool::new(max, Box::new(MockWorktreeManager::new()), tx)\n   228→    }\n   229→\n   230→    fn make_session(prompt: &str) -> Session {\n   231→        Session::new(\n   232→            prompt.to_string(),\n   233→            \"opus\".to_string(),\n   234→            \"orchestrator\".to_string(),\n   235→            None,\n   236→        )\n   237→    }\n   238→\n   239→    fn make_session_with_issue(prompt: &str, issue: u64) -> Session {\n   240→        Session::new(\n   241→            prompt.to_string(),\n   242→            \"opus\".to_string(),\n   243→            \"orchestrator\".to_string(),\n   244→            Some(issue),\n   245→        )\n   246→    }\n   247→\n   248→    #[test]\n   249→    fn enqueue_adds_to_queue() {\n   250→        let mut pool = make_pool(2);"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"e8018722-fd90-4389-86b2-47c0ee19d73f","timestamp":"2026-03-24T20:20:33.871Z"}
