[2026-03-24T20:21:25.746Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S6bfurL249expy69GgCRVq","type":"tool_result","content":"     1→use crate::tui::app::{App, TuiMode};\n     2→use crate::tui::dep_graph;\n     3→use crate::tui::detail;\n     4→use chrono::Utc;\n     5→use ratatui::{\n     6→    Frame,\n     7→    layout::{Constraint, Direction, Layout, Rect},\n     8→    style::{Color, Modifier, Style},\n     9→    text::{Line, Span},\n    10→    widgets::{Block, Borders, Paragraph},\n    11→};\n    12→\n    13→/// Render the entire TUI.\n    14→pub fn draw(f: &mut Frame, app: &App) {\n    15→    let chunks = Layout::default()\n    16→        .direction(Direction::Vertical)\n    17→        .constraints([\n    18→            Constraint::Length(3),  // status bar\n    19→            Constraint::Min(10),    // main content\n    20→            Constraint::Length(10), // activity log\n    21→            Constraint::Length(1),  // help bar\n    22→        ])\n    23→        .split(f.area());\n    24→\n    25→    draw_status_bar(f, app, chunks[0]);\n    26→\n    27→    // Render main content based on TUI mode\n    28→    match app.tui_mode {\n    29→        TuiMode::Overview => {\n    30→            let sessions = app.pool.all_sessions();\n    31→            app.panel_view.draw(f, &sessions, chunks[1]);\n    32→        }\n    33→        TuiMode::Detail(idx) => {\n    34→            let sessions = app.pool.all_sessions();\n    35→            if let Some(session) = sessions.get(idx) {\n    36→                detail::draw_detail(f, session, &app.progress_tracker, chunks[1]);\n    37→            } else {\n    38→                // Invalid index, fall back to panels\n    39→                app.panel_view.draw(f, &sessions, chunks[1]);\n    40→            }\n    41→        }\n    42→        TuiMode::DependencyGraph => {\n    43→            dep_graph::draw_dep_graph(f, app.work_assigner.as_ref(), chunks[1]);\n    44→        }\n    45→    }\n    46→\n    47→    // Delegate to activity log widget\n    48→    app.activity_log.draw(f, chunks[2]);\n    49→\n    50→    // Draw notification banner overlay if any\n    51→    let banners = app.notifications.active_banners();\n    52→    if !banners.is_empty() {\n    53→        draw_notification_banner(f, banners[0], chunks[2]);\n    54→    }\n    55→\n    56→    draw_help_bar(f, app, chunks[3]);\n    57→}\n    58→\n    59→fn draw_status_bar(f: &mut Frame, app: &App, area: Rect) {\n    60→    let elapsed = Utc::now() - app.start_time;\n    61→    let elapsed_str = format!(\n    62→        \"{:02}:{:02}:{:02}\",\n    63→        elapsed.num_hours(),\n    64→        elapsed.num_minutes() % 60,\n    65→        elapsed.num_seconds() % 60\n    66→    );\n    67→\n    68→    let active = app.active_count();\n    69→    let total = app.pool.total_count();\n    70→\n    71→    let budget_display = match &app.budget_enforcer {\n    72→        Some(enforcer) => format!(\" ${:.2}/${:.2} \", app.total_cost, enforcer.total_limit()),\n    73→        None => format!(\" ${:.2} spent \", app.total_cost),\n    74→    };\n    75→\n    76→    let budget_color = match &app.budget_enforcer {\n    77→        Some(enforcer) => {\n    78→            let pct = if enforcer.total_limit() > 0.0 {\n    79→                ((app.total_cost / enforcer.total_limit()) * 100.0) as u8\n    80→            } else {\n    81→                0\n    82→            };\n    83→            if pct >= 90 { Color::Red } else { Color::Yellow }\n    84→        }\n    85→        None => Color::Yellow,\n    86→    };\n    87→\n    88→    let text = Line::from(vec![\n    89→        Span::styled(\n    90→            \" MAESTRO v0.1.0 \",\n    91→            Style::default()\n    92→                .fg(Color::Black)\n    93→                .bg(Color::Green)\n    94→                .add_modifier(Modifier::BOLD),\n    95→        ),\n    96→        Span::raw(\"  \"),\n    97→        Span::styled(\n    98→            format!(\n    99→                \" {} agent{} ({} active) \",\n   100→                total,\n   101→                if total != 1 { \"s\" } else { \"\" },\n   102→                active\n   103→            ),\n   104→            Style::default().fg(Color::Cyan),\n   105→        ),\n   106→        Span::raw(\"  \"),\n   107→        Span::styled(budget_display, Style::default().fg(budget_color)),\n   108→        Span::raw(\"  \"),\n   109→        Span::styled(\n   110→            format!(\" {} \", elapsed_str),\n   111→            Style::default().fg(Color::White),\n   112→        ),\n   113→    ]);\n   114→\n   115→    let block = Block::default()\n   116→        .borders(Borders::ALL)\n   117→        .border_style(Style::default().fg(Color::Green))\n   118→        .title_alignment(ratatui::layout::Alignment::Center);\n   119→\n   120→    let paragraph = Paragraph::new(text).block(block);\n   121→    f.render_widget(paragraph, area);\n   122→}\n   123→\n   124→fn draw_notification_banner(\n   125→    f: &mut Frame,\n   126→    notification: &crate::notifications::types::Notification,\n   127→    area: Rect,\n   128→) {\n   129→    let color = match notification.level {\n   130→        crate::notifications::types::InterruptLevel::Critical => Color::Red,\n   131→        crate::notifications::types::InterruptLevel::Blocker => Color::LightRed,\n   132→        _ => Color::Yellow,\n   133→    };\n   134→\n   135→    let banner = Paragraph::new(Line::from(vec![\n   136→        Span::styled(\n   137→            format!(\" {} \", notification.level.label()),\n   138→            Style::default()\n   139→                .fg(Color::Black)\n   140→                .bg(color)\n   141→                .add_modifier(Modifier::BOLD),\n   142→        ),\n   143→        Span::raw(\" \"),\n   144→        Span::styled(\n   145→            &notification.title,\n   146→            Style::default().fg(color).add_modifier(Modifier::BOLD),\n   147→        ),\n   148→        Span::raw(\": \"),\n   149→        Span::styled(&notification.message, Style::default().fg(Color::White)),\n   150→        Span::styled(\"  [d]ismiss\", Style::default().fg(Color::DarkGray)),\n   151→    ]));\n   152→    f.render_widget(banner, area);\n   153→}\n   154→\n   155→fn draw_help_bar(f: &mut Frame, app: &App, area: Rect) {\n   156→    let mode_label = match app.tui_mode {\n   157→        TuiMode::Overview => \"Overview\",\n   158→        TuiMode::Detail(_) => \"Detail\",\n   159→        TuiMode::DependencyGraph => \"Dependencies\",\n   160→    };\n   161→\n   162→    let help = Line::from(vec![\n   163→        Span::styled(\n   164→            format!(\" {} \", mode_label),\n   165→            Style::default().fg(Color::Black).bg(Color::DarkGray),\n   166→        ),\n   167→        Span::raw(\" \"),\n   168→        Span::styled(\"[q]\", Style::default().fg(Color::Yellow)),\n   169→        Span::raw(\"uit \"),\n   170→        Span::styled(\"[Tab]\", Style::default().fg(Color::Yellow)),\n   171→        Span::raw(\"mode \"),\n   172→        Span::styled(\"[1-9]\", Style::default().fg(Color::Yellow)),\n   173→        Span::raw(\"detail \"),\n   174→        Span::styled(\"[Esc]\", Style::default().fg(Color::Yellow)),\n   175→        Span::raw(\"back \"),\n   176→        Span::styled(\"[p]\", Style::default().fg(Color::Yellow)),\n   177→        Span::raw(\"ause \"),\n   178→        Span::styled(\"[k]\", Style::default().fg(Color::Yellow)),\n   179→        Span::raw(\"ill \"),\n   180→        Span::styled(\"[↑↓]\", Style::default().fg(Color::Yellow)),\n   181→        Span::raw(\"scroll\"),\n   182→    ]);\n   183→    f.render_widget(Paragraph::new(help), area);\n   184→}\n   185→"}]},"parent_tool_use_id":null,"session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"9c69002b-9427-41e9-92e1-2a8583dea093","timestamp":"2026-03-24T20:21:25.422Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/carlos/projects/maestro/.maestro/worktrees/issue-5/src/tui/ui.rs","content":"use crate::tui::app::{App, TuiMode};\nuse crate::tui::dep_graph;\nuse crate::tui::detail;\nuse chrono::Utc;\nuse ratatui::{\n    Frame,\n    layout::{Constraint, Direction, Layout, Rect},\n    style::{Color, Modifier, Style},\n    text::{Line, Span},\n    widgets::{Block, Borders, Paragraph},\n};\n\n/// Render the entire TUI.\npub fn draw(f: &mut Frame, app: &App) {\n    let chunks = Layout::default()\n        .direction(Direction::Vertical)\n        .constraints([\n            Constraint::Length(3),  // status bar\n            Constraint::Min(10),    // main content\n            Constraint::Length(10), // activity log\n            Constraint::Length(1),  // help bar\n        ])\n        .split(f.area());\n\n    draw_status_bar(f, app, chunks[0]);\n\n    // Render main content based on TUI mode\n    match app.tui_mode {\n        TuiMode::Overview => {\n            let sessions = app.pool.all_sessions();\n            app.panel_view.draw(f, &sessions, chunks[1]);\n        }\n        TuiMode::Detail(idx) => {\n            let sessions = app.pool.all_sessions();\n            if let Some(session) = sessions.get(idx) {\n                detail::draw_detail(f, session, &app.progress_tracker, chunks[1]);\n            } else {\n                // Invalid index, fall back to panels\n                app.panel_view.draw(f, &sessions, chunks[1]);\n            }\n        }\n        TuiMode::DependencyGraph => {\n            dep_graph::draw_dep_graph(f, app.work_assigner.as_ref(), chunks[1]);\n        }\n    }\n\n    // Delegate to activity log widget\n    app.activity_log.draw(f, chunks[2]);\n\n    // Draw notification banner overlay if any\n    let banners = app.notifications.active_banners();\n    if !banners.is_empty() {\n        draw_notification_banner(f, banners[0], chunks[2]);\n    }\n\n    draw_help_bar(f, app, chunks[3]);\n}\n\nfn draw_status_bar(f: &mut Frame, app: &App, area: Rect) {\n    let elapsed = Utc::now() - app.start_time;\n    let elapsed_str = format!(\n        \"{:02}:{:02}:{:02}\",\n        elapsed.num_hours(),\n        elapsed.num_minutes() % 60,\n        elapsed.num_seconds() % 60\n    );\n\n    let active = app.active_count();\n    let total = app.pool.total_count();\n\n    let budget_display = match &app.budget_enforcer {\n        Some(enforcer) => format!(\" ${:.2}/${:.2} \", app.total_cost, enforcer.total_limit()),\n        None => format!(\" ${:.2} spent \", app.total_cost),\n    };\n\n    let budget_color = match &app.budget_enforcer {\n        Some(enforcer) => {\n            let pct = if enforcer.total_limit() > 0.0 {\n                ((app.total_cost / enforcer.total_limit()) * 100.0) as u8\n            } else {\n                0\n            };\n            if pct >= 90 { Color::Red } else { Color::Yellow }\n        }\n        None => Color::Yellow,\n    };\n\n    let text = Line::from(vec![\n        Span::styled(\n            \" MAESTRO v0.1.0 \",\n            Style::default()\n                .fg(Color::Black)\n                .bg(Color::Green)\n                .add_modifier(Modifier::BOLD),\n        ),\n        Span::raw(\"  \"),\n        Span::styled(\n            format!(\n                \" {} agent{} ({} active) \",\n                total,\n                if total != 1 { \"s\" } else { \"\" },\n                active\n            ),\n            Style::default().fg(Color::Cyan),\n        ),\n        Span::raw(\"  \"),\n        Span::styled(budget_display, Style::default().fg(budget_color)),\n        Span::raw(\"  \"),\n        Span::styled(\n            format!(\" {} \", elapsed_str),\n            Style::default().fg(Color::White),\n        ),\n    ]);\n\n    let block = Block::default()\n        .borders(Borders::ALL)\n        .border_style(Style::default().fg(Color::Green))\n        .title_alignment(ratatui::layout::Alignment::Center);\n\n    let paragraph = Paragraph::new(text).block(block);\n    f.render_widget(paragraph, area);\n}\n\nfn draw_notification_banner(\n    f: &mut Frame,\n    notification: &crate::notifications::types::Notification,\n    area: Rect,\n) {\n    let color = match notification.level {\n        crate::notifications::types::InterruptLevel::Critical => Color::Red,\n        crate::notifications::types::InterruptLevel::Blocker => Color::LightRed,\n        _ => Color::Yellow,\n    };\n\n    let banner = Paragraph::new(Line::from(vec![\n        Span::styled(\n            format!(\" {} \", notification.level.label()),\n            Style::default()\n                .fg(Color::Black)\n                .bg(color)\n                .add_modifier(Modifier::BOLD),\n        ),\n        Span::raw(\" \"),\n        Span::styled(\n            &notification.title,\n            Style::default().fg(color).add_modifier(Modifier::BOLD),\n        ),\n        Span::raw(\": \"),\n        Span::styled(&notification.message, Style::default().fg(Color::White)),\n        Span::styled(\"  [d]ismiss\", Style::default().fg(Color::DarkGray)),\n    ]));\n    f.render_widget(banner, area);\n}\n\nfn draw_help_bar(f: &mut Frame, app: &App, area: Rect) {\n    let mode_label = match app.tui_mode {\n        TuiMode::Overview => \"Overview\",\n        TuiMode::Detail(_) => \"Detail\",\n        TuiMode::DependencyGraph => \"Dependencies\",\n    };\n\n    let help = Line::from(vec![\n        Span::styled(\n            format!(\" {} \", mode_label),\n            Style::default().fg(Color::Black).bg(Color::DarkGray),\n        ),\n        Span::raw(\" \"),\n        Span::styled(\"[q]\", Style::default().fg(Color::Yellow)),\n        Span::raw(\"uit \"),\n        Span::styled(\"[Tab]\", Style::default().fg(Color::Yellow)),\n        Span::raw(\"mode \"),\n        Span::styled(\"[1-9]\", Style::default().fg(Color::Yellow)),\n        Span::raw(\"detail \"),\n        Span::styled(\"[Esc]\", Style::default().fg(Color::Yellow)),\n        Span::raw(\"back \"),\n        Span::styled(\"[p]\", Style::default().fg(Color::Yellow)),\n        Span::raw(\"ause \"),\n        Span::styled(\"[k]\", Style::default().fg(Color::Yellow)),\n        Span::raw(\"ill \"),\n        Span::styled(\"[↑↓]\", Style::default().fg(Color::Yellow)),\n        Span::raw(\"scroll\"),\n    ]);\n    f.render_widget(Paragraph::new(help), area);\n}\n","numLines":185,"startLine":1,"totalLines":185}}}
