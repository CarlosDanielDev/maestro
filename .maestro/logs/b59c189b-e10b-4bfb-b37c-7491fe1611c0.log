[2026-03-24T20:21:32.314Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vyx2srCBcULK2TaUfz57sT","type":"tool_result","content":"     1→use crate::budget::{BudgetAction, BudgetCheck, BudgetEnforcer};\n     2→use crate::config::Config;\n     3→use crate::gates::runner::{self, GateCheck, GateRunner};\n     4→use crate::gates::types::CompletionGate;\n     5→use crate::git::GitOps;\n     6→use crate::github::ci::{CiChecker, CiStatus, PendingPrCheck};\n     7→use crate::github::client::GitHubClient;\n     8→use crate::github::labels::LabelManager;\n     9→use crate::github::pr::PrCreator;\n    10→use crate::models::ModelRouter;\n    11→use crate::notifications::dispatcher::NotificationDispatcher;\n    12→use crate::prompts::PromptBuilder;\n    13→use crate::session::health::{HealthCheck, HealthMonitor};\n    14→use crate::session::logger::SessionLogger;\n    15→use crate::session::manager::SessionEvent;\n    16→use crate::session::pool::SessionPool;\n    17→use crate::session::retry::RetryPolicy;\n    18→use crate::session::types::{Session, SessionStatus, StreamEvent};\n    19→use crate::session::worktree::WorktreeManager;\n    20→use crate::state::file_claims::{ClaimResult, FILE_CONFLICT_SENTINEL};\n    21→use crate::state::progress::ProgressTracker;\n    22→use crate::state::store::StateStore;\n    23→use crate::state::types::MaestroState;\n    24→use crate::tui::activity_log::{ActivityLog, LogLevel};\n    25→use crate::tui::panels::PanelView;\n    26→use crate::work::assigner::WorkAssigner;\n    27→use chrono::Utc;\n    28→use std::time::{Duration, Instant};\n    29→use tokio::sync::mpsc;\n    30→\n    31→/// TUI display mode.\n    32→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    33→pub enum TuiMode {\n    34→    /// Default overview with side-by-side panels.\n    35→    Overview,\n    36→    /// Detail view for a specific session (by index in the session list).\n    37→    Detail(usize),\n    38→    /// Dependency graph visualization.\n    39→    DependencyGraph,\n    40→}\n    41→\n    42→struct PendingIssueCompletion {\n    43→    issue_number: u64,\n    44→    success: bool,\n    45→    cost_usd: f64,\n    46→    files_touched: Vec<String>,\n    47→    worktree_branch: Option<String>,\n    48→    worktree_path: Option<std::path::PathBuf>,\n    49→}\n    50→\n    51→pub struct App {\n    52→    pub pool: SessionPool,\n    53→    pub activity_log: ActivityLog,\n    54→    pub panel_view: PanelView,\n    55→    pub state: MaestroState,\n    56→    pub store: StateStore,\n    57→    pub running: bool,\n    58→    pub total_cost: f64,\n    59→    pub start_time: chrono::DateTime<chrono::Utc>,\n    60→    pub event_tx: mpsc::UnboundedSender<SessionEvent>,\n    61→    pub event_rx: mpsc::UnboundedReceiver<SessionEvent>,\n    62→    /// Work assigner for GitHub issue-based runs. None for prompt-only runs.\n    63→    pub work_assigner: Option<WorkAssigner>,\n    64→    /// GitHub client for label updates and PR creation.\n    65→    pub github_client: Option<Box<dyn GitHubClient>>,\n    66→    /// Config reference for base_branch, auto_pr, etc.\n    67→    pub config: Option<Config>,\n    68→    /// Pending issue completions to process in the next async check_completions tick.\n    69→    pending_issue_completions: Vec<PendingIssueCompletion>,\n    70→    /// Health monitor for stall detection.\n    71→    pub health_monitor: Box<dyn HealthCheck>,\n    72→    /// Budget enforcer for cost limits.\n    73→    pub budget_enforcer: Option<BudgetEnforcer>,\n    74→    /// Model router for task-based model selection.\n    75→    pub model_router: Option<ModelRouter>,\n    76→    /// Progress tracker for per-session phase tracking.\n    77→    pub progress_tracker: ProgressTracker,\n    78→    /// Notification dispatcher for interruption system.\n    79→    pub notifications: NotificationDispatcher,\n    80→    /// Current TUI display mode.\n    81→    pub tui_mode: TuiMode,\n    82→    /// Session