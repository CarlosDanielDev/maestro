_checks: Vec::new(),\n   128→            last_ci_poll: Instant::now(),\n   129→            last_work_tick: Instant::now(),\n   130→        }\n   131→    }\n   132→\n   133→    /// Add a session and try to promote/spawn it.\n   134→    pub async fn add_session(&mut self, session: Session) -> anyhow::Result<()> {\n   135→        let label = session_label(&session);\n   136→        self.activity_log\n   137→            .push_simple(label.clone(), \"Enqueuing session...\".into(), LogLevel::Info);\n   138→\n   139→        self.pool.enqueue(session);\n   140→\n   141→        // Try to promote and spawn\n   142→        let promoted_ids = self.pool.try_promote();\n   143→        let tx = self.pool.event_tx();\n   144→        for id in promoted_ids {\n   145→            if let Some(managed) = self.pool.get_active_mut(id) {\n   146→                let session_label = session_label(&managed.session);\n   147→                self.activity_log.push_simple(\n   148→                    session_label.clone(),\n   149→                    \"Spawning session...\".into(),\n   150→                    LogLevel::Info,\n   151→                );\n   152→                if let Err(e) = managed.spawn(tx.clone()).await {\n   153→                    self.activity_log.push_simple(\n   154→                        session_label,\n   155→                        format!(\"Spawn failed: {}\", e),\n   156→                        LogLevel::Error,\n   157→                    );\n   158→                } else {\n   159→                    self.activity_log.push_simple(\n   160→                        session_label,\n   161→                        \"Session started\".into(),\n   162→                        LogLevel::Info,\n   163→                    );\n   164→                }\n   165→            }\n   166→        }\n   167→\n   168→        self.sync_state();\n   169→        Ok(())\n   170→    }\n   171→\n   172→    /// Process a stream event from a session.\n   173→    pub fn handle_session_event(&mut self, evt: SessionEvent) {\n   174→        let session_id = evt.session_id;\n   175→\n   176→        // Log event to session transcript\n   177→        let _ = self.session_logger.log_event(session_id, &evt.event);\n   178→\n   179→        // Record activity for stall detection\n   180→        self.health_monitor.record_activity(session_id);\n   181→\n   182→        // File claim processing for mutating tools\n   183→        if let StreamEvent::ToolUse {\n   184→            ref tool,\n   185→            file_path: Some(ref path),\n   186→            ..\n   187→        } = evt.event\n   188→            && matches!(tool.as_str(), \"Write\" | \"Edit\")\n   189→        {\n   190→            let result = self.pool.file_claims.claim(path, session_id);\n   191→            if let ClaimResult::Conflict { owner } = result {\n   192→                let label = format!(\"S-{}\", &session_id.to_string()[..8]);\n   193→                self.activity_log.push_simple(\n   194→                    label,\n   195→                    format!(\n   196→                        \"CONFLICT: {} claimed by S-{}\",\n   197→                        path,\n   198→                        &owner.to_string()[..8]\n   199→                    ),\n   200→                    LogLevel::Error,\n   201→                );\n   202→            }\n   203→        }\n   204→\n   205→        // Sentinel detection\n   206→        if let StreamEvent::AssistantMessage { ref text } = evt.event\n   207→            && text.contains(FILE_CONFLICT_SENTINEL)\n   208→        {\n   209→            let label = format!(\"S-{}\", &session_id.to_string()[..8]);\n   210→            self.activity_log.push_simple(\n   211→                label,\n   212→                \"FILE_CONFLICT sentinel detected!\".into(),\n   213→                LogLevel::Error,\n   214→            );\n   215→        }\n   216→\n   217→        // Delegate event handling to pool's managed session\n   218→        if let Some(managed) = self.pool.get_active_mut(session_id) {\n   219→            managed.handle_event(&evt.event);\n   220→            let label = session_label(&managed.session);\n   221→\n   222→            match &evt.event {\n   223→                StreamEvent::ToolUse {\n   224→                    tool, file_path, ..\n   225→                } => {\n   226→                    self.activity_log\n   227→                        .push_simple(label, format!(\"Using {}\", tool), LogLevel::Tool);\n   228→                    // Track progress phase\n   229→                    let progress = self.progress_tracker.get_or_create(session_id);\n   230→                    progress.on_tool_use(tool, file_path.as_deref());\n   231→                }\n   232→                StreamEvent::AssistantMessage { text } => {\n   233→                    let preview = if text.len() > 60 {\n   234→                        let end = truncate_at_char_boundary(text, 60);\n   235→                        format!(\"{}…\", &text[..end])\n   236→                    } else {\n   237→                        text.clone()\n   238→                    };\n   239→                    if !preview.is_empty() {\n   240→                        self.activity_log.push_simple(\n   241→                            label,\n   242→                            format!(\"\\\"{}\\\"\", preview),\n   243→                            LogLevel::Info,\n   244→                        );\n   245→                    }\n   246→                    // Track progress phase from message content\n   247→                    let progress = self.progress_tracker.get_or_create(session_id);\n   248→                    progress.on_message(text);\n   249→                }\n   250→                StreamEvent::Completed { cost_usd } => {\n   251→                    self.activity_log.push_simple(\n   252→                        label,\n   253→                        format!(\"Completed (${:.2})\", cost_usd),\n   254→                        LogLevel::Info,\n   255→                    );\n   256→                    // Queue issue completion for async processing\n   257→                    if let Some(issue_num) = managed.session.issue_number {\n   258→                        self.pending_issue_completions.push(PendingIssueCompletion {\n   259→                            issue_number: issue_num,\n   260→                            success: true,\n   261→                            cost_usd: *cost_usd,\n   262→                            files_touched: managed.session.files_touched.clone(),\n   263→                            worktree_branch: managed.branch_name.clone(),\n   264→                            worktree_path: managed.worktree_path.clone(),\n   265→                        });\n   266→                    }\n   267→                }\n   268→                StreamEvent::Error { message } => {\n   269→                    self.activity_log.push_simple(\n   270→                        label,\n   271→                        format!(\"ERROR: {}\", message),\n   272→                        LogLevel::Error,\n   273→                    );\n   274→                    // Queue issue failure for async processing\n   275→                    if let Some(issue_num) = managed.session.issue_number {\n   276→                        self.pending_issue_completions.push(PendingIssueCompletion {\n   277→                            issue_number: issue_num,\n   278→                            success: false,\n   279→                            cost_usd: managed.session.cost_usd,\n   280→                            files_touched: managed.session.files_touched.clone(),\n   281→                            worktree_branch: managed.branch_name.clone(),\n   282→                            worktree_path: managed.worktree_path.clone(),\n   283→                        });\n   284→                    }\n   285→                }\n   286→                _ => {}\n   287→            }\n   288→        }\n   289→\n   290→        // Budget enforcement on cost updates\n   291→        self.check_budget(session_id);\n   292→\n   293→        self.sync_state();\n   294→    }\n   295→\n   296→    /// Check budget limits for a session and globally. Kill sessions if over budget.\n   297→    fn check_budget(&mut self, session_id: uuid::Uuid) {\n   298→        let Some(ref mut enforcer) = self.budget_enforcer else {\n   299→            return;\n   300→        };"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"b6421744-9a87-4d75-9a8a-6c83d0fcd546","timestamp":"2026-03-24T20:20:26.497Z"}
[2026-03-24T20:20:26.537Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NuM87gEXJW37t4YAW6sL4b","type":"tool_result","content":"     1→use crate::tui::app::{App, TuiMode};\n     2→use crate::tui::dep_graph;\n     3→use crate::tui::detail;\n     4→use chrono::Utc;\n     5→use ratatui::{\n     6→    Frame,\n     7→    layout::{Constraint, Direction, Layout, Rect},\n     8→    style::{Color, Modifier, Style},\n     9→    text::{Line, Span},\n    10→    widgets::{Block, Borders, Paragraph},\n    11→};\n    12→\n    13→/// Render the entire TUI.\n    14→pub fn draw(f: &mut Frame, app: &App) {\n    15→    let chunks = Layout::default()\n    16→        .direction(Direction::Vertical)\n    17→        .constraints([\n    18→            Constraint::Length(3),  // status bar\n    19→            Constraint::Min(10),    // main content\n    20→            Constraint::Length(10), // activity log\n    21→            Constraint::Length(1),  // help bar\n    22→        ])\n    23→        .split(f.area());\n    24→\n    25→    draw_status_bar(f, app, chunks[0]);\n    26→\n    27→    // Render main content based on TUI mode\n    28→    match app.tui_mode {\n    29→        TuiMode::Overview => {\n    30→            let sessions = app.pool.all_sessions();\n    31→            app.panel_view.draw(f, &sessions, chunks[1]);\n    32→        }\n    33→        TuiMode::Detail(idx) => {\n    34→            let sessions = app.pool.all_sessions();\n    35→            if let Some(session) = sessions.get(idx) {\n    36→                detail::draw_detail(f, session, &app.progress_tracker, chunks[1]);\n    37→            } else {\n    38→                // Invalid index, fall back to panels\n    39→                app.panel_view.draw(f, &sessions, chunks[1]);\n    40→            }\n    41→        }\n    42→        TuiMode::DependencyGraph => {\n    43→            dep_graph::draw_dep_graph(f, app.work_assigner.as_ref(), chunks[1]);\n    44→        }\n    45→    }\n    46→\n    47→    // Delegate to activity log widget\n    48→    app.activity_log.draw(f, chunks[2]);\n    49→\n    50→    // Draw notification banner overlay if any\n    51→    let banners = app.notifications.active_banners();\n    52→    if !banners.is_empty() {\n    53→        draw_notification_banner(f, banners[0], chunks[2]);\n    54→    }\n    55→\n    56→    draw_help_bar(f, app, chunks[3]);\n    57→}\n    58→\n    59→fn draw_status_bar(f: &mut Frame, app: &App, area: Rect) {\n    60→    let elapsed = Utc::now() - app.start_time;\n    61→    let elapsed_str = format!(\n    62→        \"{:02}:{:02}:{:02}\",\n    63→        elapsed.num_hours(),\n    64→        elapsed.num_minutes() % 60,\n    65→        elapsed.num_seconds() % 60\n    66→    );\n    67→\n    68→    let active = app.active_count();\n    69→    let total = app.pool.total_count();\n    70→\n    71→    let budget_display = match &app.budget_enforcer {\n    72→        Some(enforcer) => format!(\" ${:.2}/${:.2} \", app.total_cost, enforcer.total_limit()),\n    73→        None => format!(\" ${:.2} spent \", app.total_cost),\n    74→    };\n    75→\n    76→    let budget_color = match &app.budget_enforcer {\n    77→        Some(enforcer) => {\n    78→            let pct = if enforcer.total_limit() > 0.0 {\n    79→                ((app.total_cost / enforcer.total_limit()) * 100.0) as u8\n    80→            } else {\n    81→                0\n    82→            };\n    83→            if pct >= 90 { Color::Red } else { Color::Yellow }\n    84→        }\n    85→        None => Color::Yellow,\n    86→    };\n    87→\n    88→    let text = Line::from(vec![\n    89→        Span::styled(\n    90→            \" MAESTRO v0.1.0 \",\n    91→            Style::default()\n    92→                .fg(Color::Black)\n    93→                .bg(Color::Green)\n    94→                .add_modifier(Modifier::BOLD),\n    95→        ),\n    96→        Span::raw(\"  \"),\n    97→        Span::styled(\n    98→            format!(\n    99→                \" {} agent{} ({} active) \",\n   100→                total,\n   101→                if total != 1 { \"s\" } else { \"\" },\n   102→                active\n   103→            ),\n   104→            Style::default().fg(Color::Cyan),\n   105→        ),\n   106→        Span::raw(\"  \"),\n   107→        Span::styled(budget_display, Style::default().fg(budget_color)),\n   108→        Span::raw(\"  \"),\n   109→        Span::styled(\n   110→            format!(\" {} \", elapsed_str),\n   111→            Style::default().fg(Color::White),\n   112→        ),\n   113→    ]);\n   114→\n   115→    let block = Block::default()\n   116→        .borders(Borders::ALL)\n   117→        .border_style(Style::default().fg(Color::Green))\n   118→        .title_alignment(ratatui::layout::Alignment::Center);\n   119→\n   120→    let paragraph = Paragraph::new(text).block(block);\n   121→    f.render_widget(paragraph, area);\n   122→}\n   123→\n   124→fn draw_notification_banner(\n   125→    f: &mut Frame,\n   126→    notification: &crate::notifications::types::Notification,\n   127→    area: Rect,\n   128→) {\n   129→    let color = match notification.level {\n   130→        crate::notifications::types::InterruptLevel::Critical => Color::Red,\n   131→        crate::notifications::types::InterruptLevel::Blocker => Color::LightRed,\n   132→        _ => Color::Yellow,\n   133→    };\n   134→\n   135→    let banner = Paragraph::new(Line::from(vec![\n   136→        Span::styled(\n   137→            format!(\" {} \", notification.level.label()),\n   138→            Style::default()\n   139→                .fg(Color::Black)\n   140→                .bg(color)\n   141→                .add_modifier(Modifier::BOLD),\n   142→        ),\n   143→        Span::raw(\" \"),\n   144→        Span::styled(\n   145→            &notification.title,\n   146→            Style::default().fg(color).add_modifier(Modifier::BOLD),\n   147→        ),\n   148→        Span::raw(\": \"),\n   149→        Span::styled(&notification.message, Style::default().fg(Color::White)),\n   150→        Span::styled(\"  [d]ismiss\", Style::default().fg(Color::DarkGray)),\n   151→    ]));\n   152→    f.render_widget(banner, area);\n   153→}\n   154→\n   155→fn draw_help_bar(f: &mut Frame, app: &App, area: Rect) {\n   156→    let mode_label = match app.tui_mode {\n   157→        TuiMode::Overview => \"Overview\",\n   158→        TuiMode::Detail(_) => \"Detail\",\n   159→        TuiMode::DependencyGraph => \"Dependencies\",\n   160→    };\n   161→\n   162→    let help = Line::from(vec![\n   163→        Span::styled(\n   164→            format!(\" {} \", mode_label),\n   165→            Style::default().fg(Color::Black).bg(Color::DarkGray),\n   166→        ),\n   167→        Span::raw(\" \"),\n   168→        Span::styled(\"[q]\", Style::default().fg(Color::Yellow)),\n   169→        Span::raw(\"uit \"),\n   170→        Span::styled(\"[Tab]\", Style::default().fg(Color::Yellow)),\n   171→        Span::raw(\"mode \"),\n   172→        Span::styled(\"[1-9]\", Style::default().fg(Color::Yellow)),\n   173→        Span::raw(\"detail \"),\n   174→        Span::styled(\"[Esc]\", Style::default().fg(Color::Yellow)),\n   175→        Span::raw(\"back \"),\n   176→        Span::styled(\"[p]\", Style::default().fg(Color::Yellow)),\n   177→        Span::raw(\"ause \"),\n   178→        Span::styled(\"[k]\", Style::default().fg(Color::Yellow)),\n   179→        Span::raw(\"ill \"),\n   180→        Span::styled(\"[↑↓]\", Style::default().fg(Color::Yellow)),\n   181→        Span::raw(\"scroll\"),\n   182→    ]);\n   183→    f.render_widget(Paragraph::new(help), area);\n   184→}\n   185→"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"1f0ec107-de5d-45db-86b0-0725b4f8e91a","timestamp":"2026-03-24T20:20:26.338Z"}
