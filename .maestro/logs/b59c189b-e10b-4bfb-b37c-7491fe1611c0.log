[2026-03-24T20:20:40.468Z] UNKNOWN: {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016GXqn4ibZjcLhBJqNENEMa","type":"tool_result","content":"     1→use std::collections::HashSet;\n     2→use uuid::Uuid;\n     3→\n     4→/// Action the enforcer recommends after a budget check.\n     5→#[derive(Debug, Clone, PartialEq)]\n     6→pub enum BudgetAction {\n     7→    /// Within budget, no action needed.\n     8→    Ok,\n     9→    /// Budget threshold crossed — emit a warning. Contains the current percentage.\n    10→    Alert(u8),\n    11→    /// Budget exceeded — kill the session or all sessions.\n    12→    Kill,\n    13→}\n    14→\n    15→/// Trait for budget enforcement, enabling mock injection in tests.\n    16→pub trait BudgetCheck: Send {\n    17→    /// Check whether a single session has exceeded its per-session budget.\n    18→    fn check_session(&self, session_cost: f64) -> BudgetAction;\n    19→\n    20→    /// Check whether the global budget has been exceeded.\n    21→    fn check_global(&self, total_cost: f64) -> BudgetAction;\n    22→\n    23→    /// Record that an alert has been sent for a given session to avoid duplicates.\n    24→    /// Returns `true` if this is a new alert (not previously sent).\n    25→    fn record_alert(&mut self, session_id: Uuid) -> bool;\n    26→}\n    27→\n    28→/// Production budget enforcer backed by config values.\n    29→pub struct BudgetEnforcer {\n    30→    per_session_usd: f64,\n    31→    total_usd: f64,\n    32→    alert_threshold_pct: u8,\n    33→    alerted_sessions: HashSet<Uuid>,\n    34→    global_alert_sent: bool,\n    35→}\n    36→\n    37→impl BudgetEnforcer {\n    38→    pub fn new(per_session_usd: f64, total_usd: f64, alert_threshold_pct: u8) -> Self {\n    39→        Self {\n    40→            per_session_usd,\n    41→            total_usd,\n    42→            alert_threshold_pct,\n    43→            alerted_sessions: HashSet::new(),\n    44→            global_alert_sent: false,\n    45→        }\n    46→    }\n    47→\n    48→    fn compute_action(&self, spent: f64, limit: f64) -> BudgetAction {\n    49→        if limit <= 0.0 {\n    50→            return BudgetAction::Ok;\n    51→        }\n    52→        let pct = ((spent / limit) * 100.0) as u8;\n    53→        if spent >= limit {\n    54→            BudgetAction::Kill\n    55→        } else if pct >= self.alert_threshold_pct {\n    56→            BudgetAction::Alert(pct)\n    57→        } else {\n    58→            BudgetAction::Ok\n    59→        }\n    60→    }\n    61→}\n    62→\n    63→impl BudgetCheck for BudgetEnforcer {\n    64→    fn check_session(&self, session_cost: f64) -> BudgetAction {\n    65→        self.compute_action(session_cost, self.per_session_usd)\n    66→    }\n    67→\n    68→    fn check_global(&self, total_cost: f64) -> BudgetAction {\n    69→        self.compute_action(total_cost, self.total_usd)\n    70→    }\n    71→\n    72→    fn record_alert(&mut self, session_id: Uuid) -> bool {\n    73→        self.alerted_sessions.insert(session_id)\n    74→    }\n    75→}\n    76→\n    77→impl BudgetEnforcer {\n    78→    /// Whether a global alert has already been sent (to deduplicate).\n    79→    pub fn global_alert_sent(&self) -> bool {\n    80→        self.global_alert_sent\n    81→    }\n    82→\n    83→    /// Mark global alert as sent.\n    84→    pub fn mark_global_alert_sent(&mut self) {\n    85→        self.global_alert_sent = true;\n    86→    }\n    87→\n    88→    /// Get per-session limit for display.\n    89→    pub fn per_session_limit(&self) -> f64 {\n    90→        self.per_session_usd\n    91→    }\n    92→\n    93→    /// Get total limit for display.\n    94→    pub fn total_limit(&self) -> f64 {\n    95→        self.total_usd\n    96→    }\n    97→}\n    98→\n    99→#[cfg(test)]\n   100→mod tests {\n   101→    use super::*;\n   102→\n   103→    #[test]\n   104→    fn check_session_ok_when_under_budget() {\n   105→        let enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   106→        assert_eq!(enforcer.check_session(2.0), BudgetAction::Ok);\n   107→    }\n   108→\n   109→    #[test]\n   110→    fn check_session_alert_at_threshold() {\n   111→        let enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   112→        assert_eq!(enforcer.check_session(4.0), BudgetAction::Alert(80));\n   113→    }\n   114→\n   115→    #[test]\n   116→    fn check_session_kill_at_limit() {\n   117→        let enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   118→        assert_eq!(enforcer.check_session(5.0), BudgetAction::Kill);\n   119→    }\n   120→\n   121→    #[test]\n   122→    fn check_session_kill_over_limit() {\n   123→        let enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   124→        assert_eq!(enforcer.check_session(6.0), BudgetAction::Kill);\n   125→    }\n   126→\n   127→    #[test]\n   128→    fn check_global_ok_when_under_budget() {\n   129→        let enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   130→        assert_eq!(enforcer.check_global(10.0), BudgetAction::Ok);\n   131→    }\n   132→\n   133→    #[test]\n   134→    fn check_global_alert_at_threshold() {\n   135→        let enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   136→        assert_eq!(enforcer.check_global(40.0), BudgetAction::Alert(80));\n   137→    }\n   138→\n   139→    #[test]\n   140→    fn check_global_kill_at_limit() {\n   141→        let enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   142→        assert_eq!(enforcer.check_global(50.0), BudgetAction::Kill);\n   143→    }\n   144→\n   145→    #[test]\n   146→    fn check_global_kill_over_limit() {\n   147→        let enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   148→        assert_eq!(enforcer.check_global(55.0), BudgetAction::Kill);\n   149→    }\n   150→\n   151→    #[test]\n   152→    fn zero_limit_always_ok() {\n   153→        let enforcer = BudgetEnforcer::new(0.0, 0.0, 80);\n   154→        assert_eq!(enforcer.check_session(100.0), BudgetAction::Ok);\n   155→        assert_eq!(enforcer.check_global(100.0), BudgetAction::Ok);\n   156→    }\n   157→\n   158→    #[test]\n   159→    fn record_alert_returns_true_first_time() {\n   160→        let mut enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   161→        let id = Uuid::new_v4();\n   162→        assert!(enforcer.record_alert(id));\n   163→    }\n   164→\n   165→    #[test]\n   166→    fn record_alert_returns_false_on_duplicate() {\n   167→        let mut enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   168→        let id = Uuid::new_v4();\n   169→        enforcer.record_alert(id);\n   170→        assert!(!enforcer.record_alert(id));\n   171→    }\n   172→\n   173→    #[test]\n   174→    fn global_alert_sent_initially_false() {\n   175→        let enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   176→        assert!(!enforcer.global_alert_sent());\n   177→    }\n   178→\n   179→    #[test]\n   180→    fn mark_global_alert_sent_sets_flag() {\n   181→        let mut enforcer = BudgetEnforcer::new(5.0, 50.0, 80);\n   182→        enforcer.mark_global_alert_sent();\n   183→        assert!(enforcer.global_alert_sent());\n   184→    }\n   185→\n   186→    #[test]\n   187→    fn alert_at_90_percent_with_80_threshold() {\n   188→        let enforcer = BudgetEnforcer::new(10.0, 100.0, 80);\n   189→        assert_eq!(enforcer.check_session(9.0), BudgetAction::Alert(90));\n   190→        assert_eq!(enforcer.check_global(90.0), BudgetAction::Alert(90));\n   191→    }\n   192→}\n   193→"}]},"parent_tool_use_id":"toolu_01Dy6snuCMx3gaurdBryFGRh","session_id":"aee246ba-d48a-45db-9f9e-2baf98ff22c0","uuid":"53f82b13-460b-4776-94ed-9400cc360795","timestamp":"2026-03-24T20:20:40.442Z"}
